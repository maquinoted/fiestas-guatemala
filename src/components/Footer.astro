---
// Footer.astro
---

<footer class="bg-[#243447] text-white pt-16 pb-12 px-6 md:px-10 text-[11px]">
  <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12 md:gap-8 font-light">
    
    <div class="flex flex-col items-center md:items-start space-y-4 opacity-70">
      <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-10 brightness-0 invert" />
      <div class="text-center md:text-left space-y-2">
        <p class="leading-relaxed">Boulevard Los Próceres 24-69, zona 10<br/>Ciudad de Guatemala</p>
        <p class="font-bold text-[#a68a56] text-sm tracking-widest">2302-2201</p>
      </div>
    </div>

    <div class="text-center md:text-left">
      <h4 class="text-[#a68a56] uppercase text-[9px] font-black tracking-[0.2em] mb-6">Explorar</h4>
      <ul class="space-y-3 opacity-50 list-none p-0">
        <li><a href="/mariachis" class="hover:text-white transition-colors no-underline">Mariachis</a></li>
        <li><a href="/salones-de-fiestas" class="hover:text-white transition-colors no-underline">Salones de Fiestas</a></li>
        <li><a href="/pasteles" class="hover:text-white transition-colors no-underline">Pasteles y Repostería</a></li>
      </ul>
    </div>

    <div class="text-center md:text-left">
      <h4 class="text-[#a68a56] uppercase text-[9px] font-black tracking-[0.2em] mb-6">Comunidad</h4>
      <ul class="space-y-3 opacity-50 list-none p-0">
        <li><a href="/nosotros" class="hover:text-white transition-colors no-underline">Sobre Nosotros</a></li>
        <li><a href="/contacto" class="hover:text-white transition-colors no-underline">Anuncia tu Negocio</a></li>
        <li><a href="/sos" class="text-red-400/80 hover:text-red-400 transition-colors no-underline font-bold">Botón SOS</a></li>
      </ul>
    </div>

    <div class="flex flex-col items-center md:items-end justify-between gap-8 md:gap-0">
      <div class="flex gap-4">
        <a href="#" class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#a68a56] hover:border-[#a68a56] transition-all text-white no-underline text-xs">f</a>
        <a href="#" class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#a68a56] hover:border-[#a68a56] transition-all text-white no-underline text-xs">i</a>
      </div>
      <div class="text-center md:text-right">
        <p class="text-[9px] opacity-30 font-black uppercase tracking-widest mb-1">Guatemala, C.A.</p>
        <p class="text-[9px] opacity-30 font-bold uppercase tracking-tighter">© 2026 fiestasGuatemala.com</p>
      </div>
    </div>

  </div>
</footer>