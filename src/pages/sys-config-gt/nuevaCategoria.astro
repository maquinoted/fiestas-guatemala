---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

let mensaje = "";
let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const nombre = data.get("nombre") as string;
    const icono = data.get("icono") as string;
    const descripcion = data.get("descripcion") as string;

    const slug = nombre.toLowerCase()
      .trim()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^a-z0-9\s-]/g, "")
      .replace(/[\s-]+/g, "-")
      .replace(/^-+|-+$/g, "");

    await sql`
      INSERT INTO categorias (nombre, slug, icono, descripcion)
      VALUES (${nombre}, ${slug}, ${icono}, ${descripcion})
    `;

    // 🔥 Redirigimos a la lista de categorías
    return Astro.redirect('/sys-config-gt/categorias');

  } catch (e: any) {
    console.error(e);
    error = true;
    // 🔥 Atrapamos el error de slug duplicado
    if (e.message.includes('unique_category_slug') || e.code === '23505') {
      mensaje = "¡Huy mijo! Ese nombre ya existe como categoría. Probá con uno diferente.";
    } else {
      mensaje = "Error al guardar. Revisa que no falten datos.";
    }
  }
}
---

<Layout title="Nueva Categoría | Admin">
  <div class="bg-[#F8F9FA] min-h-screen p-6 md:p-12 font-sans text-[#243447]">
    <div class="max-w-2xl mx-auto">
      <header class="mb-10 flex justify-between items-end">
        <div>
          <a href="/sys-config-gt/categorias" class="text-[10px] font-black uppercase tracking-widest text-[#705930]">← Volver a Categorías</a>
          <h1 class="text-4xl font-black mt-2 italic text-[#243447]">Nueva Categoría 📂</h1>
        </div>
      </header>

      <form method="POST" class="bg-white p-8 md:p-12 rounded-[40px] shadow-2xl space-y-8 border border-gray-100">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="md:col-span-3">
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Nombre Comercial</label>
            <input type="text" name="nombre" required placeholder="Ej: Mariachis" class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-bold text-lg" />
          </div>
          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 text-center tracking-widest">Icono</label>
            <input type="text" name="icono" required placeholder="🎺" class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-bold text-center text-2xl" />
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Descripción SEO (Meta-Tag)</label>
          <textarea name="descripcion" rows="4" placeholder="Esta descripción aparecerá en Google..." class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none text-sm leading-relaxed"></textarea>
        </div>

        <button type="submit" class="w-full bg-[#243447] text-white py-6 rounded-[25px] font-black uppercase text-[12px] tracking-widest shadow-xl hover:bg-black transition-all">
          Registrar Categoría 🚀
        </button>

        {error && (
          <div class="bg-red-50 p-4 rounded-2xl text-center text-red-500 font-bold uppercase text-[10px] border border-red-100">
            {mensaje}
          </div>
        )}
      </form>
    </div>
  </div>
</Layout>