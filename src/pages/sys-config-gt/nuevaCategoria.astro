---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

let mensaje = "";
let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    
    // 🔥 Aseguramos que los valores no sean null y quitamos espacios
    const nombre = (data.get("nombre") as string || "").trim();
    const icono = (data.get("icono") as string || "").trim();
    const descripcion = (data.get("descripcion") as string || "").trim();

    if (!nombre || !icono) {
      throw new Error("NOMBRE_ICONO_REQUERIDO");
    }

    // GENERACIÓN AUTOMÁTICA DEL SLUG
    const slug = nombre.toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^a-z0-9\s-]/g, "")
      .replace(/[\s-]+/g, "-")
      .replace(/^-+|-+$/g, "");

    // INSERT EN LA BASE DE DATOS
    // 🔥 Agregamos el || '' por si la descripción viene vacía
    await sql`
      INSERT INTO categorias (nombre, slug, icono, descripcion)
      VALUES (${nombre}, ${slug}, ${icono}, ${descripcion || ''})
    `;

    return Astro.redirect('/sys-config-gt/categorias');

  } catch (e: any) {
    console.error("Error completo:", e);
    error = true;

    // 🔥 Detección inteligente de errores
    if (e.message === "NOMBRE_ICONO_REQUERIDO") {
      mensaje = "¡Mijo! El nombre y el icono son obligatorios.";
    } else if (e.code === '23505' || e.message.includes('unique_category_slug')) {
      mensaje = "¡Esa categoría ya existe! El nombre o el slug están duplicados.";
    } else if (e.message.includes('column "descripcion" does not exist')) {
      mensaje = "Error: La columna 'descripcion' no existe en tu tabla de la base de datos.";
    } else {
      // 🔥 Mostramos el error real para saber qué está pasando
      mensaje = "Error de Base de Datos: " + e.message;
    }
  }
}
---

<Layout title="Nueva Categoría | Admin">
  <div class="bg-[#F8F9FA] min-h-screen p-6 md:p-12 font-sans text-[#243447]">
    <div class="max-w-2xl mx-auto">
      <header class="mb-10 flex justify-between items-end">
        <div>
          <a href="/sys-config-gt/categorias" class="text-[10px] font-black uppercase tracking-widest text-[#705930]">← Volver a Categorías</a>
          <h1 class="text-4xl font-black mt-2 italic text-[#243447]">Nueva Categoría 📂</h1>
        </div>
      </header>

      <form method="POST" class="bg-white p-8 md:p-12 rounded-[40px] shadow-2xl space-y-8 border border-gray-100">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="md:col-span-3">
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Nombre Comercial</label>
            <input type="text" name="nombre" required placeholder="Ej: Mariachis" class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-bold text-lg focus:ring-2 focus:ring-[#705930] transition-all" />
          </div>
          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 text-center tracking-widest">Icono</label>
            <input type="text" name="icono" required placeholder="🎺" class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-bold text-center text-2xl focus:ring-2 focus:ring-[#705930] transition-all" />
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Descripción SEO (Meta-Tag)</label>
          <textarea name="descripcion" rows="4" placeholder="Esta descripción aparecerá en Google..." class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none text-sm leading-relaxed focus:ring-2 focus:ring-[#705930] transition-all"></textarea>
        </div>

        <button type="submit" class="w-full bg-[#243447] text-white py-6 rounded-[25px] font-black uppercase text-[12px] tracking-widest shadow-xl hover:bg-black hover:-translate-y-1 transition-all active:scale-95">
          Registrar Categoría 🚀
        </button>

        {error && (
          <div class="bg-red-50 p-6 rounded-3xl text-center text-red-600 border border-red-100 shadow-inner">
            <p class="text-[10px] font-black uppercase tracking-widest mb-1">¡Huy mijo, algo salió mal!</p>
            <p class="text-xs font-bold leading-relaxed">{mensaje}</p>
          </div>
        )}
      </form>
    </div>
  </div>
</Layout>