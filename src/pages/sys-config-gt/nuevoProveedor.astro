---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

// 1. DATOS DE DB
let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} AND p.activo = true LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const otrosVecinos = await sql`
      SELECT nombre, slug, imagen_url, precio_desde FROM proveedores 
      WHERE categoria_slug = ${categoriaSlug} AND municipio = ${p.municipio} 
      AND slug != ${p.slug} AND activo = true LIMIT 3
    `;
    vecinos = otrosVecinos.rows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

const dbEmoji = p.categoria_emoji || '✨';
const nombreMunicipio = p.municipio || p.departamento;

// 🔥 TÍTULO SEO: Emoji DESPUÉS del nombre
const tituloSEO = `${p.nombre} ${dbEmoji} en ${nombreMunicipio} | Q${p.precio_desde} | FiestasGuatemala.com`;
const descriptionSEO = `✅ Perfil Verificado: ${p.nombre} en ${nombreMunicipio}. Especialistas en ${p.categoria_nombre} con precios desde Q${p.precio_desde}.`;

const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const fotoFinal = p.imagen_url || '/placeholder.jpg';

// 🔥 2. RESTAURACIÓN DE LOS 3 SCHEMAS (Estrellas, FAQ, Breadcrumb)
const schemaMarkup = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": p.nombre,
    "image": fotoFinal,
    "telephone": p.telefono,
    "priceRange": `Q${p.precio_desde}+`,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "125"
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": p.municipio,
      "addressRegion": p.departamento,
      "addressCountry": "GT"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": `¿Precios de ${p.nombre}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Los precios de ${p.nombre} en ${p.municipio} inician desde Q${p.precio_desde}.`
      }
    }]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteBase },
      { "@type": "ListItem", "position": 2, "name": p.categoria_nombre, "item": `${siteBase}/${categoriaSlug}` },
      { "@type": "ListItem", "position": 3, "name": p.nombre, "item": canonicalURL }
    ]
  }
];

const whatsappLink = `https://wa.me/502${p.whatsapp || p.telefono}?text=${encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com...`)}`;
---

<Layout title={tituloSEO} description={descriptionSEO}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:image" content={fotoFinal} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-5xl mx-auto pt-4 pb-20 px-6">
      
      <header class="mb-6">
        <h1 class="text-2xl md:text-4xl font-serif text-[#243447] leading-tight truncate">
          {p.nombre} en {p.municipio}, {p.departamento}
        </h1>

        <nav class="flex items-center gap-2 text-[10px] uppercase font-bold text-[#8b7355] my-2">
          <a href="/" class="hover:text-[#243447]">Inicio</a> <span>/</span>
          <a href={`/${categoriaSlug}`} class="hover:text-[#243447]">{p.categoria_nombre}</a> <span>/</span>
          <span class="text-[#a68a56]">{p.nombre}</span>
        </nav>

        <div class="text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold">
          Actualizado Marzo 2026
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
        
        <div class="md:col-span-4">
          <div class="rounded-[30px] overflow-hidden shadow-xl border-4 border-white aspect-square md:aspect-auto md:h-[300px]">
            <img src={fotoFinal} class="w-full h-full object-cover" alt={p.nombre} fetchpriority="high" />
          </div>
          
          <div class="mt-4 grid grid-cols-2 gap-2">
            <a href={whatsappLink} class="bg-[#25D366] text-white text-center py-3 rounded-xl font-black text-[10px] uppercase shadow-md">WhatsApp</a>
            <a href={`tel:+502${p.telefono}`} class="bg-[#243447] text-white text-center py-3 rounded-xl font-black text-[10px] uppercase shadow-md">Llamar</a>
          </div>
        </div>

        <div class="md:col-span-8 space-y-4">
          <div class="bg-white p-6 md:p-8 rounded-[35px] shadow-sm border border-white">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xl">📍</span>
              <p class="text-[11px] font-bold text-[#243447] uppercase tracking-widest">{p.municipio}, {p.departamento}</p>
            </div>

            <div class="inline-flex items-center gap-2 bg-[#fcfaf3] border border-[#a68a56]/20 px-4 py-2 rounded-full mb-4">
              <span class="text-[#a68a56] text-xs">★</span>
              <span class="text-[9px] font-black uppercase tracking-tighter text-[#8b7355]">Perfil Verificado por FiestasGuatemala.com</span>
            </div>

            <p class="text-lg md:text-xl leading-relaxed italic text-gray-600 font-light">
              "{p.descripcion || `Servicio profesional de ${p.categoria_nombre} para todo tipo de eventos.`}"
            </p>

            <div class="mt-6 pt-6 border-t border-gray-100 flex justify-between items-end">
              <div>
                <p class="text-[9px] font-black uppercase text-gray-400 mb-1">Inversión desde</p>
                <p class="text-4xl font-serif text-[#a68a56]">Q{p.precio_desde}</p>
              </div>
              <div class="text-[20px]">{dbEmoji}</div>
            </div>
          </div>
        </div>
      </div>

      {vecinos.length > 0 && (
        <section class="mt-20 pt-10 border-t border-[#8b7355]/10">
          <h2 class="text-2xl font-serif text-[#243447] mb-8">Otros recomendados en {p.municipio}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            {vecinos.map(v => (
              <a href={`/${categoriaSlug}/${v.slug}`} class="group no-underline bg-white p-4 rounded-[30px] shadow-sm border border-gray-50">
                <div class="h-40 rounded-[20px] overflow-hidden mb-4">
                  <img src={v.imagen_url || '/placeholder.jpg'} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt={v.nombre} />
                </div>
                <h4 class="font-serif text-[#243447] text-lg">{v.nombre}</h4>
                <p class="text-[10px] text-[#a68a56] font-black uppercase">Desde Q{v.precio_desde}</p>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
    <Footer />
  </div>
</Layout>

<script define:vars={{ pId: p.id }}>
  const track = (tipo) => {
    fetch('/api/click', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ proveedorId: pId, tipo }), keepalive: true }).catch(() => {});
  };
  track('vista_perfil');
</script>