---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';
import { put } from '@vercel/blob';

// 1. Traemos la info de la DB para los selects
const { rows: categoriasDB } = await sql`SELECT slug, nombre FROM categorias ORDER BY nombre ASC`;
const { rows: departamentosDB } = await sql`SELECT id, nombre FROM departamentos ORDER BY nombre ASC`;
const { rows: municipiosDB } = await sql`SELECT id, nombre, departamento_id FROM municipios ORDER BY nombre ASC`;

let mensaje = "";
let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    
    const nombre = data.get("nombre") as string;
    
    // GENERACIÓN AUTOMÁTICA DEL SLUG
    const slug = nombre
      .toLowerCase()
      .trim()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^a-z0-9\s-]/g, "")
      .replace(/[\s-]+/g, "-")
      .replace(/^-+|-+$/g, "");

    const descripcion = data.get("descripcion") as string;
    const telefono = data.get("telefono") as string;
    const whatsapp = data.get("whatsapp") as string;
    const categoria = data.get("categoria") as string;
    
    // 🔥 CORRECCIÓN: Agarramos el NOMBRE del departamento, no el ID
    const depto = data.get("departamento_nombre") as string;
    const municipio = data.get("municipio") as string;
    
    const precio = parseInt(data.get("precio")?.toString() || "0");
    const es_premium = data.get("es_premium") === "on";
    const activo = data.get("activo") === "on";
    const fotoFile = data.get("foto") as File;

    let fotoUrl = "";

    if (fotoFile && fotoFile.size > 0) {
      const extension = fotoFile.name.split('.').pop();
      const fileName = `${categoria}_${slug}_guatemala.${extension}`;
      const blob = await put(fileName, fotoFile, {
        access: 'public',
        token: process.env.BLOB_READ_WRITE_TOKEN
      });
      fotoUrl = blob.url;
    }

    // 🚀 INSERT COMPLETO
    await sql`
      INSERT INTO proveedores 
      (nombre, slug, descripcion, telefono, whatsapp, municipio, departamento, categoria_slug, precio_desde, imagen_url, es_premium, activo)
      VALUES 
      (${nombre}, ${slug}, ${descripcion}, ${telefono}, ${whatsapp}, ${municipio}, ${depto}, ${categoria}, ${precio}, ${fotoUrl}, ${es_premium}, ${activo})
    `;

    // 🔥 REDIRECCIÓN ESTRATÉGICA: Vamos directo a ver el resultado final
    return Astro.redirect(`/${categoria}/${slug}`);

  } catch (e) {
    console.error(e);
    error = true;
    mensaje = "Error al guardar. Revisá que el nombre no esté duplicado o la conexión a la DB.";
  }
}
---

<Layout title="Admin: Nuevo Registro Oficial">
  <div class="bg-[#F8F9FA] min-h-screen p-6 md:p-12 font-sans text-[#243447]">
    <div class="max-w-4xl mx-auto">
      
      <header class="mb-10 flex justify-between items-end">
        <div>
          <a href="/sys-config-gt/proveedores" class="text-[10px] font-black uppercase tracking-widest text-[#AD946D] hover:underline">← Volver al Panel</a>
          <h1 class="text-4xl font-black mt-2 italic">Alta de Proveedor ✍️</h1>
        </div>
        <span class="bg-[#243447] text-white text-[9px] font-black px-4 py-2 rounded-full uppercase tracking-widest">Modo Administrador</span>
      </header>

      <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <div class="md:col-span-1 space-y-6">
          <div class="bg-white p-6 rounded-[30px] shadow-xl border border-gray-100">
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-4 tracking-widest">Imagen Principal</label>
            <input type="file" name="foto" accept="image/*" required class="text-xs text-gray-400 w-full file:bg-[#AD946D] file:text-white file:border-0 file:rounded-full file:px-4 file:py-2 file:font-black cursor-pointer" />
          </div>

          <div class="bg-white p-6 rounded-[30px] shadow-xl border border-gray-100 space-y-4">
            <label class="flex items-center justify-between cursor-pointer">
              <span class="text-[10px] font-black uppercase text-[#243447]">¿Perfil Verificado? ★</span>
              <input type="checkbox" name="es_premium" class="w-5 h-5 rounded text-[#AD946D]" />
            </label>
            <label class="flex items-center justify-between cursor-pointer border-t pt-4">
              <span class="text-[10px] font-black uppercase text-[#243447]">¿Activo? (Público)</span>
              <input type="checkbox" name="activo" checked class="w-5 h-5 rounded text-green-600" />
            </label>
          </div>
        </div>

        <div class="md:col-span-2 bg-white p-8 md:p-10 rounded-[40px] shadow-2xl space-y-6">
          
          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Nombre Comercial</label>
            <input type="text" name="nombre" required placeholder="Ej. Mariachis Los Bravos" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-[#AD946D]/20 font-bold" />
          </div>

          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Descripción del Servicio</label>
            <textarea name="descripcion" rows="3" required placeholder="Contale a Guate qué ofrecés..." class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-[#AD946D]/20 text-sm"></textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Teléfono</label>
              <input type="text" name="telefono" placeholder="2200-0000" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none outline-none" />
            </div>
            <div>
              <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">WhatsApp</label>
              <input type="text" name="whatsapp" placeholder="5555-5555" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none outline-none" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Categoría</label>
              <select name="categoria" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none outline-none font-bold">
                {categoriasDB.map(c => <option value={c.slug}>{c.nombre}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Precio Desde (Q)</label>
              <input type="number" name="precio" placeholder="0" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none outline-none font-black text-lg text-[#AD946D]" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Departamento</label>
              <select name="departamento" id="depto-select" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none outline-none">
                <option value="">Seleccionar...</option>
                {departamentosDB.map(d => <option value={d.id} data-nombre={d.nombre}>{d.nombre}</option>)}
              </select>
              <input type="hidden" name="departamento_nombre" id="depto-nombre" />
            </div>
            <div>
              <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Municipio</label>
              <select name="municipio" id="muni-select" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none outline-none font-medium">
                <option value="">Primero elige depto...</option>
              </select>
            </div>
          </div>

          <button type="submit" class="w-full bg-[#243447] text-white py-5 rounded-2xl font-black uppercase tracking-[0.2em] text-[11px] shadow-xl hover:bg-black transition-all active:scale-95">
            Guardar Proveedor Oficial 🚀
          </button>
          
          {error && <div class="bg-red-50 p-4 rounded-xl border border-red-100 text-center text-red-500 text-[10px] font-bold uppercase tracking-widest">{mensaje}</div>}
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ municipiosDB }}>
    const deptoSelect = document.getElementById('depto-select');
    const muniSelect = document.getElementById('muni-select');
    const deptoNombreInput = document.getElementById('depto-nombre');

    deptoSelect.addEventListener('change', () => {
      const deptoId = deptoSelect.value;
      const selectedOption = deptoSelect.options[deptoSelect.selectedIndex];
      
      // Actualizamos el nombre del depto para el backend
      deptoNombreInput.value = selectedOption.getAttribute('data-nombre');

      // Filtrar municipios por el ID del depto
      const filtrados = municipiosDB.filter(m => m.departamento_id == deptoId);
      
      muniSelect.innerHTML = filtrados.length 
        ? filtrados.map(m => `<option value="${m.nombre}">${m.nombre}</option>`).join('')
        : '<option value="">Primero elige depto...</option>';
    });
  </script>
</Layout>