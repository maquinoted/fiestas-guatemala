---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';
import { put } from '@vercel/blob';
import sharp from 'sharp'; 

// 1. Traemos la info de la DB para los selects
const { rows: categoriasDB } = await sql`SELECT slug, nombre FROM categorias ORDER BY nombre ASC`;
const { rows: departamentosDB } = await sql`SELECT id, nombre FROM departamentos ORDER BY nombre ASC`;
const { rows: municipiosDB } = await sql`SELECT id, nombre, departamento_id FROM municipios ORDER BY nombre ASC`;

let mensaje = "";
let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const nombre = data.get("nombre") as string;
    
    // GENERACIÓN AUTOMÁTICA DEL SLUG
    const slug = nombre.toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, "").replace(/[\s-]+/g, "-").replace(/^-+|-+$/g, "");

    const descripcion = data.get("descripcion") as string;
    const telefono = data.get("telefono") as string;
    const whatsapp = data.get("whatsapp") as string;
    const categoria = data.get("categoria") as string;
    
    const depto = data.get("departamento_nombre") as string;
    const municipio = data.get("municipio") as string;
    
    const precio = parseInt(data.get("precio")?.toString() || "0");
    const es_premium = data.get("es_premium") === "on";
    const activo = data.get("activo") === "on";
    const fotoFile = data.get("foto") as File;

    let fotoUrl = "";

    if (fotoFile && fotoFile.size > 0) {
      const buffer = Buffer.from(await fotoFile.arrayBuffer());
      const optimizedBuffer = await sharp(buffer)
        .resize(1000, 1000, { fit: 'inside', withoutEnlargement: true })
        .webp({ quality: 80 })
        .toBuffer();

      const fileName = `${categoria}_${slug}_guatemala.webp`;
      const blob = await put(fileName, optimizedBuffer, {
        access: 'public',
        contentType: 'image/webp',
        token: process.env.BLOB_READ_WRITE_TOKEN
      });
      fotoUrl = blob.url;
    }

    // 🚀 INTENTO DE INSERCIÓN CON EL NUEVO CANDADO
    await sql`
      INSERT INTO proveedores 
      (nombre, slug, descripcion, telefono, whatsapp, municipio, departamento, categoria_slug, precio_desde, imagen_url, es_premium, activo)
      VALUES 
      (${nombre}, ${slug}, ${descripcion}, ${telefono}, ${whatsapp}, ${municipio}, ${depto}, ${categoria}, ${precio}, ${fotoUrl}, ${es_premium}, ${activo})
    `;

    return Astro.redirect('/sys-config-gt/proveedores');

  } catch (e: any) {
    console.error(e);
    error = true;
    
    // 🔥 BLOQUEO DE DUPLICADOS POR WHATSAPP
    if (e.message.includes('unique_whatsapp')) {
      mensaje = "¡Huy mijo! Ese número de WhatsApp ya está registrado. No se permiten proveedores duplicados.";
    } else {
      mensaje = "Error al guardar. Revisa que no falten datos obligatorios.";
    }
  }
}
---

<Layout title="Admin: Nuevo Registro Oficial">
  <div class="bg-[#F8F9FA] min-h-screen p-6 md:p-12 font-sans text-[#243447]">
    <div class="max-w-4xl mx-auto">
      <header class="mb-10 flex justify-between items-end">
        <div>
          <a href="/sys-config-gt/proveedores" class="text-[10px] font-black uppercase tracking-widest text-[#AD946D]">← Volver</a>
          <h1 class="text-4xl font-black mt-2 italic">Alta de Proveedor ✍️</h1>
        </div>
      </header>

      <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="md:col-span-1 space-y-6">
          <div class="bg-white p-6 rounded-[30px] shadow-xl border border-gray-100">
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-4">Imagen Principal</label>
            <input type="file" name="foto" accept="image/*" required class="text-xs w-full cursor-pointer" />
          </div>

          <div class="bg-white p-6 rounded-[30px] shadow-xl border border-gray-100 space-y-4">
            <label class="flex items-center justify-between cursor-pointer">
              <span class="text-[10px] font-black uppercase text-[#243447]">¿Perfil Verificado?</span>
              <input type="checkbox" name="es_premium" class="w-5 h-5 rounded" />
            </label>
            <label class="flex items-center justify-between cursor-pointer border-t pt-4">
              <span class="text-[10px] font-black uppercase text-[#243447]">¿Activo?</span>
              <input type="checkbox" name="activo" checked class="w-5 h-5 rounded" />
            </label>
          </div>
        </div>

        <div class="md:col-span-2 bg-white p-8 rounded-[40px] shadow-2xl space-y-6">
          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Nombre Comercial</label>
            <input type="text" name="nombre" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-bold" />
          </div>

          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Descripción</label>
            <textarea name="descripcion" rows="3" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none text-sm"></textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <input type="text" name="telefono" placeholder="Teléfono" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none" />
            <input type="text" name="whatsapp" placeholder="WhatsApp" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-bold italic text-[#243447]" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <select name="categoria" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-bold">
              {categoriasDB.map(c => <option value={c.slug}>{c.nombre}</option>)}
            </select>
            <input type="number" name="precio" placeholder="Precio Desde" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-black text-[#AD946D]" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <select name="departamento" id="depto-select" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none">
                <option value="">Departamento...</option>
                {departamentosDB.map(d => <option value={d.id} data-nombre={d.nombre}>{d.nombre}</option>)}
              </select>
              <input type="hidden" name="departamento_nombre" id="depto-nombre" />
            </div>
            <select name="municipio" id="muni-select" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-medium">
              <option value="">Municipio...</option>
            </select>
          </div>

          <button type="submit" class="w-full bg-[#243447] text-white py-5 rounded-2xl font-black uppercase text-[11px] shadow-xl hover:bg-black transition-all">
            Guardar Proveedor 🚀
          </button>
          
          {error && (
            <div class="bg-red-50 p-4 rounded-xl text-center text-red-500 font-bold uppercase text-[10px] border border-red-100 animate-pulse">
              {mensaje}
            </div>
          )}
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ municipiosDB }}>
    const deptoSelect = document.getElementById('depto-select');
    const muniSelect = document.getElementById('muni-select');
    const deptoNombreInput = document.getElementById('depto-nombre');

    deptoSelect.addEventListener('change', () => {
      const deptoId = deptoSelect.value;
      const selectedOption = deptoSelect.options[deptoSelect.selectedIndex];
      deptoNombreInput.value = selectedOption.getAttribute('data-nombre');

      const filtrados = municipiosDB.filter(m => m.departamento_id == deptoId);
      muniSelect.innerHTML = filtrados.length 
        ? filtrados.map(m => `<option value="${m.nombre}">${m.nombre}</option>`).join('')
        : '<option value="">Municipio...</option>';
    });
  </script>
</Layout>