---
// TEST_ID: VERIFICACION_MANUAL_812
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} AND p.activo = true LIMIT 1
  `;
  p = rows[0];
  if (p) {
    const { rows: vRows } = await sql`SELECT nombre, slug, imagen_url, precio_desde FROM proveedores WHERE categoria_slug = ${categoriaSlug} AND municipio = ${p.municipio} AND slug != ${p.slug} AND activo = true LIMIT 3`;
    vecinos = vRows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

const dbEmoji = p.categoria_emoji || '✨';
const nombreMunicipio = p.municipio || p.departamento;

// 🔥 TÍTULO: Emoji después del nombre
const tituloSEO = `${p.nombre} ${dbEmoji} en ${nombreMunicipio} | Q${p.precio_desde}`;

const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const fotoFinal = p.imagen_url || '/placeholder.jpg';

// 🔥 SCHEMAS RESTAURADOS (Los 3 más importantes)
const schemaMarkup = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": p.nombre,
    "image": fotoFinal,
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142" },
    "address": { "@type": "PostalAddress", "addressLocality": p.municipio, "addressRegion": p.departamento, "addressCountry": "GT" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{ "@type": "Question", "name": `¿Precio de ${p.nombre}?`, "acceptedAnswer": { "@type": "Answer", "text": `Inicia desde Q${p.precio_desde}.` } }]
  }
];

const whatsappLink = `https://wa.me/502${p.whatsapp || p.telefono}?text=Hola...`;
---

<Layout title={tituloSEO} description={`Perfil de ${p.nombre}`}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-5xl mx-auto pt-4 pb-20 px-4">
      
      <header class="mb-4 border-b pb-4">
        <h1 class="text-xl md:text-2xl font-serif font-bold truncate">
          {p.nombre} en {p.municipio}, {p.departamento}
        </h1>
        <nav class="text-[9px] uppercase font-bold text-[#8b7355] my-1">
          <a href="/">Inicio</a> / <a href={`/${categoriaSlug}`}>{p.categoria_nombre}</a> / {p.nombre}
        </nav>
        <div class="text-[8px] uppercase font-black opacity-40 italic">
          Actualizado Marzo 2026
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <div class="md:col-span-4 lg:col-span-3">
          <div class="rounded-3xl overflow-hidden shadow-lg border-4 border-white aspect-square md:aspect-auto md:h-64">
            <img src={fotoFinal} class="w-full h-full object-cover" alt={p.nombre} />
          </div>
        </div>

        <div class="md:col-span-8 lg:col-span-9">
          <div class="bg-white p-6 rounded-[35px] shadow-sm border border-white">
            <p class="text-[10px] font-black uppercase mb-3 flex items-center gap-1">📍 {p.municipio}</p>
            
            <div class="bg-[#243447] text-white text-[8px] font-black px-3 py-1 rounded-full inline-block mb-4 uppercase">
              ★ Perfil Verificado
            </div>

            <p class="text-lg italic font-serif text-gray-700">"{p.descripcion}"</p>

            <div class="mt-6 pt-4 border-t flex justify-between items-center">
              <p class="text-3xl font-serif text-[#a68a56] font-bold">Q{p.precio_desde}</p>
              <a href={whatsappLink} class="bg-[#25D366] text-white px-5 py-2 rounded-xl font-bold text-[10px] uppercase">WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script>
  // 🕵️ PRUEBA DE FUEGO: Mirá esto en la consola del navegador (F12)
  console.log("🚀 Versión: Side-By-Side 8:12PM");
</script>