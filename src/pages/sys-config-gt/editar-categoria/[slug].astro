---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { slug } = Astro.params;

// 1. Cargar datos actuales
const { rows } = await sql`SELECT * FROM categorias WHERE slug = ${slug}`;
const cat = rows[0];

if (!cat) return Astro.redirect('/sys-config-gt/categorias');

let mensaje = "";
let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const nombre = data.get("nombre") as string;
    const icono = data.get("icono") as string;
    const descripcion = data.get("descripcion") as string;

    await sql`
      UPDATE categorias 
      SET nombre = ${nombre}, icono = ${icono}, descripcion = ${descripcion}
      WHERE slug = ${slug}
    `;
    return Astro.redirect('/sys-config-gt/categorias');
  } catch (e) {
    error = true;
    mensaje = "Error al actualizar la categoría.";
  }
}
---

<Layout title={`Editar Categoría: ${cat.nombre}`}>
  <div class="bg-[#F8F9FA] min-h-screen p-6 md:p-12">
    <div class="max-w-2xl mx-auto">
      <header class="mb-10">
        <a href="/sys-config-gt/categorias" class="text-[10px] font-black uppercase tracking-widest text-[#705930]">← Cancelar</a>
        <h1 class="text-4xl font-black mt-2 italic text-[#243447]">Editar {cat.nombre}</h1>
      </header>

      <form method="POST" class="bg-white p-8 md:p-12 rounded-[40px] shadow-2xl space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="md:col-span-3">
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Nombre</label>
            <input type="text" name="nombre" value={cat.nombre} required class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-bold text-lg" />
          </div>
          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 text-center">Icono</label>
            <input type="text" name="icono" value={cat.icono} required class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-bold text-center text-2xl" />
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Descripción SEO</label>
          <textarea name="descripcion" rows="4" class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none text-sm leading-relaxed">{cat.descripcion}</textarea>
        </div>

        <button type="submit" class="w-full bg-[#243447] text-white py-6 rounded-[25px] font-black uppercase text-[12px] tracking-widest shadow-xl hover:bg-black transition-all">
          Guardar Cambios 🚀
        </button>
      </form>
    </div>
  </div>
</Layout>