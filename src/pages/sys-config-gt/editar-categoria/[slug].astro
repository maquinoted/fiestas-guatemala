---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { slug } = Astro.params;

// 1. Cargar datos actuales (incluyendo la imagen)
const { rows } = await sql`SELECT * FROM categorias WHERE slug = ${slug}`;
const cat = rows[0];

if (!cat) return Astro.redirect('/sys-config-gt/categorias');

let mensaje = "";
let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const nombre = (data.get("nombre") as string || "").trim();
    const icono = (data.get("icono") as string || "").trim();
    const descripcion = (data.get("descripcion") as string || "").trim();
    const imagen_url = (data.get("imagen_url") as string || "").trim(); // 🔥 NUEVO

    // 🔥 Actualizamos la base de datos con el nuevo campo
    await sql`
      UPDATE categorias 
      SET nombre = ${nombre}, 
          icono = ${icono}, 
          descripcion = ${descripcion},
          imagen_url = ${imagen_url}
      WHERE slug = ${slug}
    `;
    return Astro.redirect('/sys-config-gt/categorias');
  } catch (e: any) {
    console.error(e);
    error = true;
    mensaje = "Huy mijo, no se pudo actualizar: " + e.message;
  }
}
---

<Layout title={`Editar Categoría: ${cat.nombre}`}>
  <div class="bg-[#F8F9FA] min-h-screen p-6 md:p-12 font-sans text-[#243447]">
    <div class="max-w-2xl mx-auto">
      
      <header class="mb-10">
        <a href="/sys-config-gt/categorias" class="text-[10px] font-black uppercase tracking-widest text-[#705930]">← Cancelar y Volver</a>
        <h1 class="text-4xl font-black mt-2 italic text-[#243447]">Editar Estructura</h1>
        <p class="text-[10px] font-mono text-gray-400 mt-1 uppercase">ID ÚNICO (SLUG): {cat.slug}</p>
      </header>

      <form method="POST" class="bg-white p-8 md:p-12 rounded-[40px] shadow-2xl space-y-8 border border-gray-100">
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="md:col-span-3">
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Nombre Visible</label>
            <input type="text" name="nombre" value={cat.nombre} required class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-bold text-lg focus:ring-2 focus:ring-[#705930] transition-all" />
          </div>
          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 text-center tracking-widest">Icono</label>
            <input type="text" name="icono" value={cat.icono} required class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-bold text-center text-2xl focus:ring-2 focus:ring-[#705930] transition-all" />
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">URL del Banner (Imagen Principal)</label>
          <input 
            type="url" 
            name="imagen_url" 
            value={cat.imagen_url} 
            placeholder="https://tusitio.com/imagen.webp" 
            class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none font-medium text-sm focus:ring-2 focus:ring-[#705930] transition-all" 
          />
          <p class="text-[9px] text-gray-400 mt-2 italic font-medium">✨ Pro tip de Claudia: Usá WebP de 1200x630px para que brille en Google.</p>
        </div>

        <div>
          <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 tracking-widest">Descripción SEO</label>
          <textarea name="descripcion" rows="4" class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none text-sm leading-relaxed focus:ring-2 focus:ring-[#705930] transition-all">{cat.descripcion}</textarea>
        </div>

        <button type="submit" class="w-full bg-[#243447] text-white py-6 rounded-[25px] font-black uppercase text-[12px] tracking-[0.2em] shadow-xl hover:bg-black hover:-translate-y-1 transition-all active:scale-95">
          Guardar Cambios en {cat.nombre} 🚀
        </button>

        {error && (
          <div class="bg-red-50 p-4 rounded-2xl text-center text-red-600 border border-red-100 text-[10px] font-black uppercase">
            {mensaje}
          </div>
        )}
      </form>
      
      <div class="mt-8 pt-8 border-t border-gray-100 flex items-center justify-between">
         <p class="text-[9px] text-gray-400 font-bold uppercase tracking-widest">FiestasGuatemala.com • Core Engine</p>
         <span class="text-xs grayscale opacity-30">🇬🇹</span>
      </div>
    </div>
  </div>
</Layout>