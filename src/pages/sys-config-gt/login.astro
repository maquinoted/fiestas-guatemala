---
// src/pages/sys-config-gt/login.astro
export const prerender = false;
import Layout from '../../layouts/Layout.astro';

// 1. Si ya tiene la cookie, que pase de una vez a trabajar
const auth = Astro.cookies.get("claudia_auth")?.value;
if (auth === "autorizado") return Astro.redirect('/sys-config-gt/proveedores');

let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    // Limpiamos espacios en blanco por si el teclado puso uno de más
    const userInput = data.get("user")?.toString().trim();
    const passInput = data.get("pass")?.toString().trim();

    // 2. USAMOS process.env (La forma correcta para secretos en Vercel/SSR)
    const envUser = process.env.ADMIN_USER;
    const envPass = process.env.ADMIN_PASS;

    if (userInput === envUser && passInput === envPass && envUser !== undefined) {
      Astro.cookies.set("claudia_auth", "autorizado", { 
        path: "/", 
        httpOnly: true, 
        secure: true, 
        sameSite: 'lax', // Ayuda con el error de Cross-site
        maxAge: 60 * 60 * 24 // 24 horas
      });
      return Astro.redirect('/sys-config-gt/proveedores');
    } else {
      error = true;
      console.log("Intento de acceso fallido"); // Esto solo lo ves vos en los logs de Vercel
    }
  } catch (e) {
    console.error("Error en el sistema de login:", e);
  }
}
---

<Layout title="Acceso | Oficina Central">
  <div class="min-h-screen bg-[#243447] flex items-center justify-center px-6">
    <div class="max-w-md w-full bg-white rounded-[40px] p-10 shadow-2xl">
      <div class="text-center mb-8">
        <img src="/Logo-Fiestas-Guatemala.jpg" class="h-12 mx-auto mb-4" alt="Logo" />
        <h1 class="text-2xl font-serif text-[#243447]">Oficina Central</h1>
        <p class="text-gray-400 text-[10px] uppercase font-bold tracking-widest mt-2">Identificación Requerida</p>
      </div>

      <form method="POST" class="space-y-4">
        <div>
          <input 
            type="text" 
            name="user" 
            placeholder="Usuario" 
            required
            class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none outline-none ring-2 ring-transparent focus:ring-[#AD946D]/20 transition-all text-[#243447]" 
          />
        </div>
        <div>
          <input 
            type="password" 
            name="pass" 
            placeholder="Contraseña" 
            required
            class="w-full px-6 py-4 rounded-2xl bg-gray-50 border-none outline-none ring-2 ring-transparent focus:ring-[#AD946D]/20 transition-all text-[#243447]" 
          />
        </div>
        
        {error && (
          <div class="bg-red-50 p-4 rounded-2xl border border-red-100 animate-pulse">
            <p class="text-red-500 text-[10px] font-bold text-center uppercase tracking-widest">
              Credenciales Incorrectas
            </p>
          </div>
        )}

        <button type="submit" class="w-full bg-[#AD946D] text-white py-4 rounded-2xl font-black uppercase tracking-[0.2em] text-[11px] hover:bg-[#243447] transition-all shadow-lg active:scale-95">
          Entrar a la Oficina
        </button>
      </form>
      
      <p class="text-center mt-8 text-[9px] text-gray-300 uppercase tracking-widest">
        Propiedad de fiestasGuatemala.com
      </p>
    </div>
  </div>
</Layout>