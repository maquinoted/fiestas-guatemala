---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

// 🚀 CONSULTA REFORZADA: Agrupa clics y los une con la tabla proveedores
const { rows: stats } = await sql`
  SELECT 
    p.nombre,
    COUNT(CASE WHEN c.tipo = 'whatsapp' THEN 1 END) as whatsapp,
    COUNT(CASE WHEN c.tipo = 'llamada' THEN 1 END) as llamadas,
    COUNT(CASE WHEN c.tipo = 'vista' THEN 1 END) as vistas
  FROM proveedores p
  LEFT JOIN clics c ON p.id = c.proveedor_id
  GROUP BY p.id, p.nombre
  ORDER BY vistas DESC
`;
---

<Layout title="Dashboard de Clics">
  <div class="p-8 bg-white min-h-screen font-sans">
    <div class="max-w-6xl mx-auto">
      <header class="mb-10 flex justify-between items-center border-b pb-8">
        <div>
          <h1 class="text-4xl font-black italic text-[#243447]">Estadísticas Reales 📈</h1>
          <p class="text-xs font-bold text-[#AD946D] uppercase tracking-widest mt-1">Control de rendimiento y leads</p>
        </div>
        <a href="/sys-config-gt/proveedores" class="bg-gray-100 px-6 py-3 rounded-full text-[10px] font-black uppercase">← Proveedores</a>
      </header>
      
      <div class="bg-white rounded-[40px] shadow-2xl overflow-hidden border border-gray-100">
        <table class="w-full text-left">
          <thead class="bg-[#243447] text-white uppercase text-[10px] font-black tracking-widest">
            <tr>
              <th class="p-8">Nombre del Proveedor</th>
              <th class="p-8 text-center border-l border-white/10">Vistas</th>
              <th class="p-8 text-center border-l border-white/10">WhatsApp</th>
              <th class="p-8 text-center border-l border-white/10">Llamadas</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {stats.map(s => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="p-8 font-bold text-[#243447] text-lg">{s.nombre}</td>
                <td class="p-8 text-center font-black text-blue-600 text-2xl">{s.vistas || 0}</td>
                <td class="p-8 text-center font-black text-green-600 text-2xl">{s.whatsapp || 0}</td>
                <td class="p-8 text-center font-black text-orange-600 text-2xl">{s.llamadas || 0}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>