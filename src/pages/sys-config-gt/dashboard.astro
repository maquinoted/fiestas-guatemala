---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

// Consultamos los clics agrupados por proveedor y tipo
const { rows: stats } = await sql`
  SELECT 
    p.nombre,
    COUNT(CASE WHEN c.tipo = 'whatsapp' THEN 1 END) as whatsapp,
    COUNT(CASE WHEN c.tipo = 'llamada' THEN 1 END) as llamadas,
    COUNT(CASE WHEN c.tipo = 'vista' THEN 1 END) as vistas
  FROM proveedores p
  LEFT JOIN clics c ON p.id = c.proveedor_id
  GROUP BY p.id, p.nombre
  ORDER BY vistas DESC
`;
---

<Layout title="Dashboard de Clics">
  <div class="p-8 bg-gray-50 min-h-screen">
    <h1 class="text-3xl font-black mb-8">Rendimiento de Proveedores 📈</h1>
    
    <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
      <table class="w-full text-left">
        <thead class="bg-[#243447] text-white uppercase text-[10px] font-black">
          <tr>
            <th class="p-6">Proveedor</th>
            <th class="p-6 text-center">Vistas</th>
            <th class="p-6 text-center">WhatsApp</th>
            <th class="p-6 text-center">Llamadas</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {stats.map(s => (
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="p-6 font-bold text-[#243447]">{s.nombre}</td>
              <td class="p-6 text-center font-black text-blue-600">{s.vistas}</td>
              <td class="p-6 text-center font-black text-green-600">{s.whatsapp}</td>
              <td class="p-6 text-center font-black text-orange-600">{s.llamadas}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>