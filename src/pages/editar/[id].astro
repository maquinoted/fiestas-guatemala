---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';
import { put } from '@vercel/blob';
import sharp from 'sharp';

const { id } = Astro.params;

// 1. Traemos los datos actuales del proveedor y catálogos
const { rows } = await sql`SELECT * FROM proveedores WHERE id = ${id}`;
const p = rows[0];

if (!p) return Astro.redirect('/sys-config-gt/proveedores');

const { rows: categoriasDB } = await sql`SELECT slug, nombre FROM categorias ORDER BY nombre ASC`;
const { rows: departamentosDB } = await sql`SELECT id, nombre FROM departamentos ORDER BY nombre ASC`;
const { rows: municipiosDB } = await sql`SELECT id, nombre, departamento_id FROM municipios ORDER BY nombre ASC`;

let mensaje = "";
let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const nombre = data.get("nombre") as string;
    const descripcion = data.get("descripcion") as string;
    const telefono = data.get("telefono") as string;
    const whatsapp = data.get("whatsapp") as string;
    const categoria = data.get("categoria") as string;
    const depto = data.get("departamento_nombre") as string;
    const municipio = data.get("municipio") as string;
    const precio = parseInt(data.get("precio")?.toString() || "0");
    const es_premium = data.get("es_premium") === "on";
    const activo = data.get("activo") === "on";
    const fotoFile = data.get("foto") as File;

    let fotoUrl = p.imagen_url; // Por defecto mantenemos la vieja

    // Si subió una foto nueva, la procesamos
    if (fotoFile && fotoFile.size > 0) {
      const buffer = Buffer.from(await fotoFile.arrayBuffer());
      const optimizedBuffer = await sharp(buffer)
        .resize(1000, 1000, { fit: 'inside', withoutEnlargement: true })
        .webp({ quality: 80 })
        .toBuffer();

      // Generamos slug para el nombre del archivo
      const slugName = nombre.toLowerCase().trim().replace(/[^a-z0-9]/g, '-');
      const fileName = `${categoria}_${slugName}_${Date.now()}.webp`;
      
      const blob = await put(fileName, optimizedBuffer, {
        access: 'public',
        contentType: 'image/webp',
        token: process.env.BLOB_READ_WRITE_TOKEN
      });
      fotoUrl = blob.url;
    }

    // 🚀 ACTUALIZACIÓN EN LA BASE DE DATOS
    await sql`
      UPDATE proveedores SET 
        nombre = ${nombre},
        descripcion = ${descripcion},
        telefono = ${telefono},
        whatsapp = ${whatsapp},
        municipio = ${municipio},
        departamento = ${depto},
        categoria_slug = ${categoria},
        precio_desde = ${precio},
        imagen_url = ${fotoUrl},
        es_premium = ${es_premium},
        activo = ${activo}
      WHERE id = ${id}
    `;

    return Astro.redirect('/sys-config-gt/proveedores');
  } catch (e) {
    console.error(e);
    error = true;
    mensaje = "Error al actualizar. Revisa los datos.";
  }
}
---

<Layout title={`Editar: ${p.nombre}`}>
  <div class="bg-[#F8F9FA] min-h-screen p-6 md:p-12 font-sans text-[#243447]">
    <div class="max-w-4xl mx-auto">
      <header class="mb-10 flex justify-between items-end">
        <div>
          <a href="/sys-config-gt/proveedores" class="text-[10px] font-black uppercase tracking-widest text-[#AD946D]">← Cancelar</a>
          <h1 class="text-4xl font-black mt-2 italic">Editar Perfil ✏️</h1>
        </div>
      </header>

      <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="md:col-span-1 space-y-6">
          <div class="bg-white p-6 rounded-[30px] shadow-xl border border-gray-100">
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-4">Imagen Actual</label>
            <img src={p.imagen_url} class="w-full aspect-square object-cover rounded-2xl mb-4 shadow-sm" />
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Cambiar Foto (Opcional)</label>
            <input type="file" name="foto" accept="image/*" class="text-xs w-full cursor-pointer" />
          </div>

          <div class="bg-white p-6 rounded-[30px] shadow-xl border border-gray-100 space-y-4">
            <label class="flex items-center justify-between cursor-pointer">
              <span class="text-[10px] font-black uppercase text-[#243447]">¿Perfil Verificado?</span>
              <input type="checkbox" name="es_premium" checked={p.es_premium} class="w-5 h-5 rounded" />
            </label>
            <label class="flex items-center justify-between cursor-pointer border-t pt-4">
              <span class="text-[10px] font-black uppercase text-[#243447]">¿Activo?</span>
              <input type="checkbox" name="activo" checked={p.activo} class="w-5 h-5 rounded" />
            </label>
          </div>
        </div>

        <div class="md:col-span-2 bg-white p-8 rounded-[40px] shadow-2xl space-y-6">
          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Nombre Comercial</label>
            <input type="text" name="nombre" value={p.nombre} required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-bold" />
          </div>

          <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Descripción</label>
            <textarea name="descripcion" rows="4" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none text-sm">{p.descripcion}</textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Teléfono</label>
                <input type="text" name="telefono" value={p.telefono} class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none" />
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">WhatsApp</label>
                <input type="text" name="whatsapp" value={p.whatsapp} class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Categoría</label>
                <select name="categoria" class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-bold">
                  {categoriasDB.map(c => <option value={c.slug} selected={c.slug === p.categoria_slug}>{c.nombre}</option>)}
                </select>
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Precio Desde</label>
                <input type="number" name="precio" value={p.precio_desde} class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-black text-[#AD946D]" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Departamento</label>
              <select id="depto-select" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none">
                <option value="">Seleccionar...</option>
                {departamentosDB.map(d => (
                  <option value={d.id} data-nombre={d.nombre} selected={d.nombre === p.departamento}>{d.nombre}</option>
                ))}
              </select>
              <input type="hidden" name="departamento_nombre" id="depto-nombre" value={p.departamento} />
            </div>
            <div>
              <label class="block text-[10px] font-black uppercase text-gray-400 mb-2">Municipio</label>
              <select name="municipio" id="muni-select" required class="w-full px-5 py-3 rounded-xl bg-gray-50 border-none font-medium">
                <option value={p.municipio}>{p.municipio}</option>
              </select>
            </div>
          </div>

          <button type="submit" class="w-full bg-[#243447] text-white py-5 rounded-2xl font-black uppercase text-[11px] shadow-xl hover:bg-[#AD946D] transition-colors">
            Guardar Cambios 🚀
          </button>
          
          {error && <div class="bg-red-50 p-4 rounded-xl text-center text-red-500 font-bold uppercase text-[10px]">{mensaje}</div>}
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ municipiosDB }}>
    const deptoSelect = document.getElementById('depto-select');
    const muniSelect = document.getElementById('muni-select');
    const deptoNombreInput = document.getElementById('depto-nombre');

    deptoSelect.addEventListener('change', () => {
      const deptoId = deptoSelect.value;
      const selectedOption = deptoSelect.options[deptoSelect.selectedIndex];
      deptoNombreInput.value = selectedOption.getAttribute('data-nombre');

      const filtrados = municipiosDB.filter(m => m.departamento_id == deptoId);
      muniSelect.innerHTML = filtrados.length 
        ? filtrados.map(m => `<option value="${m.nombre}">${m.nombre}</option>`).join('')
        : '<option value="">Municipio...</option>';
    });
  </script>
</Layout>