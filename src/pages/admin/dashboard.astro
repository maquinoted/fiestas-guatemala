---
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

// 1. Total de Leads (Clicks en WhatsApp/Llamada)
const { rows: statsLeads } = await sql`
  SELECT COUNT(*) as total FROM eventos_proveedores 
  WHERE tipo_evento IN ('click_whatsapp', 'click_llamada')
`;

// 2. Ranking de los Top 5 Mariachis más populares
const { rows: topProveedores } = await sql`
  SELECT p.nombre, p.municipio, COUNT(e.id) as total_contactos
  FROM proveedores p
  JOIN eventos_proveedores e ON p.id = e.proveedor_id
  WHERE e.tipo_evento IN ('click_whatsapp', 'click_llamada')
  GROUP BY p.id, p.nombre, p.municipio
  ORDER BY total_contactos DESC
  LIMIT 5
`;

// 3. Actividad Reciente
const { rows: actividad } = await sql`
  SELECT p.nombre, e.tipo_evento, e.fecha 
  FROM eventos_proveedores e
  JOIN proveedores p ON e.proveedor_id = p.id
  ORDER BY e.fecha DESC
  LIMIT 10
`;
---

<Layout title="Dashboard Administrativo | Fiestas Guatemala">
  <div class="bg-[#F5F3E7] min-h-screen p-8 font-sans">
    <div class="max-w-6xl mx-auto">
      
      <header class="flex justify-between items-center mb-10">
        <div>
          <h1 class="text-4xl font-black text-[#243447]">Hola, Claudia 👋</h1>
          <p class="text-gray-500">Aquí está el pulso de las fiestas en Guatemala hoy.</p>
        </div>
        <div class="bg-white px-6 py-3 rounded-2xl shadow-sm border border-gray-100">
          <span class="text-[10px] font-bold text-gray-400 uppercase block">Total Leads Hoy</span>
          <span class="text-2xl font-black text-[#AD946D]">{statsLeads[0].total}</span>
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2 space-y-8">
          <section class="bg-white rounded-[40px] p-10 shadow-xl border border-white">
            <h2 class="text-2xl font-bold text-[#243447] mb-8 flex items-center gap-3">
              🏆 Los Más Buscados
            </h2>
            <div class="space-y-6">
              {topProveedores.map((item, index) => (
                <div class="flex items-center justify-between border-b border-gray-50 pb-4 last:border-0">
                  <div class="flex items-center gap-4">
                    <span class="text-2xl font-black text-gray-200">#{index + 1}</span>
                    <div>
                      <p class="font-bold text-[#243447]">{item.nombre}</p>
                      <p class="text-xs text-gray-400 font-medium italic">{item.municipio}</p>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="text-xl font-black text-[#AD946D]">{item.total_contactos}</p>
                    <p class="text-[9px] text-gray-400 font-bold uppercase tracking-tighter">Contactos Reales</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        </div>

        <div class="space-y-8">
          <section class="bg-[#243447] rounded-[40px] p-8 text-white shadow-2xl">
            <h2 class="text-lg font-bold mb-6 flex items-center gap-2">
              <span class="w-2 h-2 bg-green-400 rounded-full animate-ping"></span>
              En Vivo
            </h2>
            <div class="space-y-4">
              {actividad.map(log => (
                <div class="text-sm border-l-2 border-[#AD946D]/30 pl-4 py-1">
                  <p class="font-bold">{log.nombre}</p>
                  <p class="text-[10px] text-gray-400 opacity-80">
                    {log.tipo_evento === 'vista_perfil' ? '👀 Vieron perfil' : '📲 Click WhatsApp'}
                  </p>
                </div>
              ))}
            </div>
          </section>

          <div class="bg-white rounded-[40px] p-8 border-2 border-dashed border-gray-200 flex flex-col items-center justify-center text-center">
             <p class="text-gray-400 text-sm font-medium mb-4 italic">"Los datos son el alma de la fiesta."</p>
             <button class="bg-[#AD946D] text-white px-6 py-3 rounded-full font-bold text-[10px] uppercase tracking-widest">Descargar Reporte PDF</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>