---
import Layout from '../layouts/Layout.astro';

// Datos para las 9 cards según tu requerimiento
const categorias = [
  { nombre: 'Fincas para Bodas', img: '/images/fincas.jpg', icon: '🏡' },
  { nombre: 'Salones de Eventos', img: '/images/salones.jpg', icon: '🏛️' },
  { nombre: 'Catering / Banquetes', img: '/images/catering.jpg', icon: '🍽️' },
  { nombre: 'Juegos Infantiles', img: '/images/juegos.jpg', icon: '🎈' },
  { nombre: 'Decoradores', img: '/images/decoradores.jpg', icon: '🎨' },
  { nombre: 'Organizadores de Eventos', img: '/images/organizadores.jpg', icon: '📋' },
  { nombre: 'Mariachis', img: '/images/mariachis.jpg', icon: '🎸' },
  { nombre: 'Fotógrafos', img: '/images/fotografos.jpg', icon: '📷' },
  { nombre: 'Pasteles', img: '/images/pasteles.jpg', icon: '🎂' },
];
---

<Layout title="Fiestas Guatemala | Todo para tu evento">
  <div class="bg-[#F5F3E7] min-h-screen font-sans text-[#243447]">
    
    <section class="pt-12 pb-16 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <div class="mb-8">
            <img src="/logo-color.png" alt="Fiestas Guatemala" class="h-20 mx-auto py-4" />
            <p class="text-sm font-medium text-gray-500 italic">Aquí tú eres el alma de la fiesta</p>
        </div>

        <div class="bg-[#243447] p-2 rounded-full shadow-2xl flex flex-col md:flex-row items-center gap-2">
          <input type="text" placeholder="¿Qué buscas? (Categoría)" class="flex-1 bg-transparent px-6 py-3 text-white outline-none placeholder:text-gray-400" />
          <div class="hidden md:block w-[1px] h-8 bg-gray-600"></div>
          <select class="bg-transparent px-6 py-3 text-white outline-none cursor-pointer">
            <option class="text-black">Guatemala (Departamento)</option>
          </select>
          <button class="bg-[#AD946D] hover:bg-[#C5A97D] text-white font-bold px-8 py-3 rounded-full transition-all">
            Buscar Proveedores Verificados
          </button>
        </div>
      </div>
    </section>

    <main class="max-w-7xl mx-auto px-6 pb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {categorias.map((cat, i) => (
          <div class="bg-white rounded-[32px] overflow-hidden shadow-sm hover:shadow-md transition-all border border-gray-100 group">
            <div class="relative h-48 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute top-4 right-4 bg-[#AD946D] w-10 h-10 rounded-full flex items-center justify-center text-white font-bold shadow-lg">
                {i + 1}
              </div>
            </div>
            <div class="p-6 flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-[#F5F3E7] rounded-2xl flex items-center justify-center text-2xl shadow-inner">
                  {cat.icon}
                </div>
                <div>
                  <h3 class="font-black text-lg leading-tight">{cat.nombre}</h3>
                  <div class="flex text-[#AD946D] text-xs mt-1">
                    ★★★★★ <span class="text-gray-400 ml-2 font-bold">4.0</span>
                  </div>
                </div>
              </div>
              <p class="text-[10px] font-black uppercase tracking-tighter bg-gray-100 px-2 py-1 rounded-md text-gray-400">Verificado</p>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-20 pb-10 px-8">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
        <div class="space-y-6">
          <img src="/logo-blanco.png" alt="Logo" class="h-16" />
          <p class="text-sm text-gray-400 leading-relaxed">Expertos en hacer de tu evento un momento inolvidable. El directorio más confiable de Guatemala.</p>
          <div class="flex gap-4 text-xl">
            <span>f</span> <span>i</span> <span>t</span> <span>w</span>
          </div>
        </div>
        
        <div>
          <h4 class="font-black mb-6 uppercase tracking-widest text-[#AD946D] text-xs">Categorías</h4>
          <ul class="space-y-3 text-sm text-gray-300">
            <li>Mariachis</li>
            <li>Fotógrafos</li>
            <li>Pasteles</li>
            <li>Juegos Infantiles</li>
            <li>Ver todas</li>
          </ul>
        </div>

        <div>
          <h4 class="font-black mb-6 uppercase tracking-widest text-[#AD946D] text-xs">Servicios</h4>
          <ul class="space-y-3 text-sm text-gray-300">
            <li>Sobre Nosotros</li>
            <li>Contáctanos</li>
            <li>Privacidad</li>
            <li>SOS / Emergencias</li>
          </ul>
        </div>

        <div>
          <h4 class="font-black mb-6 uppercase tracking-widest text-[#AD946D] text-xs">Zonas</h4>
          <ul class="space-y-3 text-sm text-gray-300">
            <li>Guatemala</li>
            <li>Antigua Guatemala</li>
            <li>Quetzaltenango</li>
            <li>Ver todas</li>
          </ul>
        </div>
      </div>
      <div class="max-w-7xl mx-auto mt-20 pt-8 border-t border-gray-700 text-center text-xs text-gray-500">
        © 2026 Fiestas Guatemala. Todos los derechos reservados.
      </div>
    </footer>
  </div>
</Layout>