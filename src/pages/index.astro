---
import Layout from '../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

let categorias = [];
try {
  const { rows } = await sql`SELECT * FROM categorias ORDER BY orden ASC`;
  categorias = rows;
} catch (e) {
  console.error(e);
}

// Datos para el carrusel superior (fiel a la imagen)
const carrusel = [
  { img: "https://images.unsplash.com/photo-1519167758481-83f550bb49b3", title: "Eventos" },
  { img: "https://images.unsplash.com/photo-1530103043960-ef38714abb15", title: "Pasteles" },
  { img: "https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3", title: "Mariachis" },
  { img: "https://images.unsplash.com/photo-1464366400600-7168b8af9bc3", title: "Globos" },
  { img: "https://images.unsplash.com/photo-1511795409834-ef04bbd61622", title: "Piñatas" }
];
---

<Layout title="FiestasGuatemala.com | Aquí tú eres el alma de la fiesta">
  <main class="bg-[#F3F1E7] min-h-screen font-sans text-[#1e293b]">
    
    <header class="pt-8 pb-4 px-6">
      <div class="max-w-7xl mx-auto flex justify-between items-center text-[13px] font-medium text-gray-600">
        <div class="flex gap-6">
          <a href="#" class="flex items-center gap-1">Categorías <span class="text-[9px]">▼</span></a>
          <a href="#">Departamentos</a>
        </div>
        
        <div class="flex flex-col items-center">
          <div class="flex flex-col items-center mb-1">
             <span class="text-4xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-blue-500 via-purple-500 to-pink-500">FG</span>
             <h1 class="text-xl font-serif font-bold text-[#1e293b] mt-1">FiestasGuatemala.com</h1>
             <p class="text-[10px] text-gray-500 italic">Aquí tú eres el alma de la fiesta</p>
          </div>
        </div>

        <div class="flex gap-6">
          <a href="#" class="flex items-center gap-1">Favoritos ♡</a>
          <a href="#">Login / Registrarse</a>
        </div>
      </div>
    </header>

    <div class="max-w-7xl mx-auto px-4">
      
      <section class="flex gap-3 overflow-x-auto py-6 no-scrollbar">
        {carrusel.map((item) => (
          <div class="min-w-[210px] h-[280px] rounded-[30px] overflow-hidden shadow-lg border-4 border-white">
            <img src={item.img} class="w-full h-full object-cover" alt={item.title} />
          </div>
        ))}
      </section>

      <section class="mt-4 mb-10">
        <div class="bg-[#243447] rounded-full p-1.5 flex flex-col md:flex-row items-center shadow-2xl max-w-5xl mx-auto border border-gray-600">
          <div class="flex-1 flex items-center px-8 py-3 border-r border-gray-600 w-full group">
            <span class="text-gray-400 mr-3">🔍</span>
            <input 
              type="text" 
              id="mainSearch"
              placeholder="¿Qué buscas? (Categoría)" 
              class="bg-transparent text-white w-full outline-none placeholder:text-gray-400 text-sm"
            >
          </div>
          <div class="flex-1 flex items-center px-8 py-3 w-full group">
            <span class="text-gray-400 mr-3 text-lg">📍</span>
            <input 
              type="text" 
              placeholder="Guatemala (Departamento)" 
              class="bg-transparent text-white w-full outline-none placeholder:text-gray-400 text-sm"
            >
          </div>
          <button 
            id="btnBuscar"
            class="bg-[#AD946D] text-white px-8 py-4 rounded-full font-bold hover:bg-[#967F5C] transition-all text-xs tracking-widest uppercase m-1"
          >
            Buscar Proveedores Verificados
          </button>
        </div>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-8 pb-20">
        {categorias.map((cat, index) => (
          <a href={`/${cat.slug}`} class="group bg-white rounded-[25px] overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100">
            <div class="h-44 relative overflow-hidden">
              <img 
                src={`https://images.unsplash.com/photo-1519167758481-83f550bb49b3?auto=format&fit=crop&q=80&w=500&sig=${index}`} 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            </div>
            
            <div class="p-5 flex items-center gap-4">
              <div class="w-10 h-10 flex items-center justify-center opacity-70 group-hover:opacity-100 transition-opacity">
                 <span class="text-2xl">{cat.icono || '✨'}</span>
              </div>
              <h3 class="font-bold text-gray-800 text-lg tracking-tight">
                {index + 1}. {cat.nombre}
              </h3>
            </div>
          </a>
        ))}
      </section>
    </div>

    <footer class="bg-[#EAE7D9] py-12 border-t border-gray-300 text-center text-[11px] text-gray-600 tracking-wide">
      <div class="max-w-4xl mx-auto px-6">
        <p class="mb-1 leading-relaxed">Dirección: Boulevard Los Proceres 24-69 zona 10, Edificio Zona Pradera, torre 2 oficina 1108</p>
        <p class="mb-1 font-bold text-gray-800 text-sm">PBX 23022299</p>
        <p class="mb-8 underline">asitencia@fiestasguatemala.com</p>
        
        <button class="bg-[#AD946D] bg-opacity-10 text-[#8E7957] border border-[#AD946D]/30 px-8 py-3 rounded-full font-bold inline-flex items-center gap-2 hover:bg-[#AD946D]/20 transition-colors">
          ¿Necesitas ayuda urgente? <span class="bg-[#AD946D] text-white rounded-full w-5 h-5 flex items-center justify-center text-[9px] shadow-sm">SOS</span>
        </button>
      </div>
    </footer>
  </main>
</Layout>

<script>
  // Lógica de búsqueda mejorada
  const btn = document.getElementById('btnBuscar');
  const input = document.getElementById('mainSearch') as HTMLInputElement;

  btn?.addEventListener('click', () => {
    const val = input.value.toLowerCase().trim();
    if (!val) return;
    
    // Diccionario de redirección inteligente
    if (val.includes('mariachi') || val.includes('banda')) window.location.href = '/mariachis';
    else if (val.includes('finca') || val.includes('jardin')) window.location.href = '/fincas';
    else if (val.includes('salon')) window.location.href = '/salones';
    else if (val.includes('comida') || val.includes('catering')) window.location.href = '/catering';
    else if (val.includes('payaso')) window.location.href = '/payasos';
    else if (val.includes('pastel')) window.location.href = '/pasteles';
    else alert('Categoría no encontrada. Prueba con "Mariachis" o "Fincas"');
  });

  input?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') btn?.click();
  });
</script>

<style>
  /* Para que el carrusel se deslice suave pero sin barra visible */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  
  /* Fuente elegante */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap');
  
  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  h1 {
    font-family: 'Playfair Display', serif;
  }
</style>