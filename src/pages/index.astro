---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// 1. Array de categorías
const categorias = [
  { nombre: 'Salones de fiestas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏛️', slug: 'salones-de-festas' },
  { nombre: 'Jardines para eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🌿', slug: 'jardines-para-eventos' },
  { nombre: 'Alquifiestas', img: 'https://images.unsplash.com/photo-1478147427282-58a87a120781?q=80&w=800', icon: '🪑', slug: 'alquifiestas' },
  { nombre: 'Organizadores de fiestas', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋', slug: 'organizadores-de-fiestas' },
  { nombre: 'Mariachis', img: 'https://images.unsplash.com/photo-1593003426291-562a0a380926?q=80&w=800', icon: '🎸', slug: 'mariachis' },
  { nombre: 'Inflables', img: 'https://images.unsplash.com/photo-1574675623044-64478833959c?q=80&w=800', icon: '🎈', slug: 'inflables' },
  { nombre: 'Decoración', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨', slug: 'decoracion' },
];

const categoriasData = categorias.map(c => ({
  termino: c.nombre.toLowerCase(),
  slug: c.slug
}));
---

<Layout title="fiestasGuatemala.com | Directorio de Eventos y Proveedores Verificados">
  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    
    <Header />

    <header class="mt-6 md:mt-10 pb-12 px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <form id="search-form" class="bg-[#243447] rounded-[30px] md:rounded-full p-2 shadow-2xl flex flex-col md:flex-row items-stretch md:items-center border border-white/5 gap-2 md:gap-0">
          
          <div class="flex-[1.4] flex items-center px-6 py-2 md:py-0 md:border-r border-white/10">
            <span class="text-white/40 text-lg mr-2">🔍</span>
            <input type="text" name="q" required placeholder="¿Qué buscas? (Ej: Mariachis)" class="bg-transparent w-full text-white text-base outline-none placeholder:text-white/40 py-3 font-light" />
          </div>
          
          <div class="flex-1 flex items-center px-6 py-2 md:py-0">
            <span class="text-white/40 text-lg mr-2">📍</span>
            <input type="text" name="location" placeholder="Toda Guatemala" class="bg-transparent w-full text-white text-base outline-none placeholder:text-white/40 py-3 font-light" />
          </div>
          
          <button type="submit" class="bg-[#a68a56] text-white px-8 py-4 md:py-5 rounded-[22px] md:rounded-full text-[11px] md:text-[12px] font-black uppercase tracking-widest hover:bg-[#c5ab78] transition-all whitespace-nowrap active:scale-95 shadow-xl">
            Buscar Proveedores
          </button>
        </form>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 pb-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {categorias.slice(0, 6).map((cat) => (
          <div class="group bg-white rounded-[28px] overflow-hidden shadow-sm border border-gray-100 hover:shadow-2xl transition-all duration-500 cursor-pointer" onclick={`window.location.href='/${cat.slug}'`}>
            <div class="h-44 overflow-hidden relative">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
              <div class="absolute bottom-3 right-3 bg-white/95 backdrop-blur px-3 py-1.5 rounded-full shadow-sm border border-gray-100 flex items-center gap-1.5">
                <span class="text-[#a68a56] text-[10px]">★</span>
                <span class="text-[8px] font-black uppercase tracking-widest text-[#243447]">Verificados</span>
              </div>
            </div>
            
            <div class="py-6 px-6 flex items-center justify-center gap-3">
              <span class="text-2xl opacity-80">{cat.icon}</span>
              <h3 class="font-serif font-light text-[#243447] text-xl leading-tight tracking-tight group-hover:text-[#a68a56] transition-colors">
                {cat.nombre}
              </h3>
            </div>
          </div>
        ))}
      </div>
    </main>

    <section class="max-w-4xl mx-auto px-8 pb-24 text-center">
      <div class="border-t border-[#8b7355]/10 pt-16">
        <h1 class="text-2xl md:text-3xl font-serif mb-4 tracking-tight text-[#243447]">Directorio de Eventos y Fiestas <span class="text-[#a68a56]">en Guatemala</span></h1>
        <p class="text-[13px] md:text-sm text-[#8b7355]/80 leading-relaxed max-w-2xl mx-auto italic font-light">
          "Aquí Tú Eres el Alma de la Fiesta". Cotiza con proveedores verificados al instante para bodas, cumpleaños y eventos corporativos en todo el país.
        </p>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<script is:inline define:vars={{ categoriasData }}>
  const form = document.getElementById('search-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const query = formData.get('q').toString().toLowerCase().trim();
      const coincidencia = categoriasData.find(c => query.includes(c.termino) || c.termino.includes(query));
      window.location.href = coincidencia ? `/${coincidencia.slug}` : `/search?q=${encodeURIComponent(query)}`;
    });
  }
</script>