---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡', slug: 'fincas-para-bodas' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️', slug: 'salones-de-eventos' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️', slug: 'catering-banquetes' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈', slug: 'juegos-infantiles' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨', slug: 'decoradores' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋', slug: 'organizadores-de-eventos' },
];
---

<Layout title="Fiestas Guatemala | Directorio Premium">
  <div class="bg-[#fcfaf4] min-h-screen font-sans text-[#243447]">
    
    <nav class="max-w-7xl mx-auto px-10 py-6 flex justify-between items-center text-[11px] font-bold uppercase tracking-[0.2em] text-[#8b7355]">
      <div class="flex gap-10 items-center flex-1">
        <a href="#" class="hover:text-[#a68a56]">Categorías ▾</a>
        <a href="#" class="hover:text-[#a68a56]">Departamentos</a>
      </div>
      <div class="flex flex-col items-center flex-1">
        <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-20 w-auto mb-2" />
        <h2 class="text-2xl font-serif font-light text-[#243447] tracking-tight lowercase">FiestasGuatemala<span class="text-[#a68a56]">.com</span></h2>
        <p class="text-[8px] font-medium text-gray-400 uppercase tracking-[0.5em] mt-1">Aquí tú eres el alma de la fiesta</p>
      </div>
      <div class="flex gap-10 items-center flex-1 justify-end">
        <a href="#" class="hover:text-[#a68a56]">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-6 py-2.5 rounded-full hover:bg-black transition-all">Login / Registrarse</a>
      </div>
    </nav>

    <header class="pt-4 pb-16 px-6">
      <div class="max-w-4xl mx-auto bg-[#243447] rounded-full p-1.5 shadow-[0_25px_60px_-15px_rgba(36,52,71,0.4)] flex items-center border border-white/5">
        <div class="flex-[1.4] flex items-center px-8 border-r border-white/10">
          <span class="text-white/40 text-lg">🔍</span>
          <input type="text" placeholder="¿Qué buscas? (Categoría)" class="bg-transparent w-full text-white text-sm outline-none placeholder:text-white/30 py-4 px-4 font-light" />
        </div>
        <div class="flex-1 flex items-center px-8">
          <span class="text-white/40 text-lg">📍</span>
          <input type="text" placeholder="Guatemala (Departamento)" class="bg-transparent w-full text-white text-sm outline-none placeholder:text-white/30 py-4 px-4 font-light" />
        </div>
        <button class="bg-[#a68a56] text-white px-10 py-4 rounded-full text-[10px] font-black uppercase tracking-widest hover:bg-[#c5ab78] transition-all whitespace-nowrap active:scale-95 shadow-lg">
          Buscar Proveedores Verificados
        </button>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-10 pb-32">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {categorias.map((cat, i) => (
          <div class="group bg-white rounded-[40px] overflow-hidden shadow-[0_15px_40px_-15px_rgba(0,0,0,0.1)] border border-gray-100/50 hover:shadow-[0_25px_60px_-10px_rgba(166,138,86,0.2)] hover:-translate-y-2 transition-all duration-500 cursor-pointer">
            <div class="h-56 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-[1.2s] ease-out" />
            </div>
            
            <div class="p-8 flex items-start gap-5">
              <div class="w-14 h-14 bg-[#fcfaf4] rounded-2xl flex items-center justify-center text-3xl border border-gray-100 group-hover:bg-white transition-colors duration-500">
                {cat.icon}
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-serif font-light text-[#243447] leading-tight">
                  <span class="text-[#a68a56] font-sans font-bold text-sm mr-1">{i + 1}.</span> {cat.nombre}
                </h3>
                <div class="flex items-center mt-2">
                  <span class="text-[#a68a56] text-sm">★★★★★</span>
                  <span class="text-[10px] font-bold text-gray-300 ml-1 uppercase tracking-tighter">4.0</span>
                </div>
                <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-[#a68a56]/60 mt-2">Sello de Verificado</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-24 pb-12 px-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-16">
        <div class="col-span-1 space-y-6">
          <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-10 brightness-0 invert opacity-80" />
          <p class="text-gray-400 text-xs leading-relaxed font-light">
            Boulevard Los Proceres 24-69 zona 10,<br/>
            Edificio Zona Pradera, torre 2, oficina 1108
            <span class="block mt-4 font-bold text-[#a68a56] text-sm tracking-widest">PBX: 2302-2201</span>
          </p>
        </div>
        <div>
          <h4 class="text-[#a68a56] uppercase text-[10px] font-black tracking-[0.3em] mb-8">Categorías</h4>
          <ul class="text-gray-400 text-[11px] space-y-4 font-light tracking-wide">
            <li class="hover:text-white cursor-pointer transition-colors">Mariachis</li>
            <li class="hover:text-white cursor-pointer transition-colors">Salones de Eventos</li>
            <li class="hover:text-white cursor-pointer transition-colors">Catering / Banquetes</li>
          </ul>
        </div>
        <div>
          <h4 class="text-[#a68a56] uppercase text-[10px] font-black tracking-[0.3em] mb-8">Servicios</h4>
          <ul class="text-gray-400 text-[11px] space-y-4 font-light tracking-wide">
            <li class="hover:text-white cursor-pointer transition-colors">Sobre Nosotros</li>
            <li class="hover:text-white cursor-pointer transition-colors">Términos y Privacidad</li>
            <li class="text-red-400/70 font-bold hover:text-red-400 cursor-pointer">SOS / Emergencias</li>
          </ul>
        </div>
        <div class="flex flex-col md:items-end">
           <div class="flex gap-5 mb-8">
             <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#a68a56] hover:border-[#a68a56] transition-all cursor-pointer">f</div>
             <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#a68a56] hover:border-[#a68a56] transition-all cursor-pointer">i</div>
           </div>
           <p class="text-[9px] text-gray-500 uppercase tracking-widest font-bold">© 2026 FiestasGuatemala.com</p>
        </div>
      </div>
    </footer>
  </div>
</Layout>