---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋' },
  { nombre: 'Mariachis', img: 'https://images.unsplash.com/photo-1593003426291-562a0a380926?q=80&w=800', icon: '🎸' },
  { nombre: 'Fotógrafos', img: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800', icon: '📷' },
  { nombre: 'Pasteles', img: 'https://images.unsplash.com/photo-1535141192574-5d4897c12636?q=80&w=800', icon: '🎂' },
];
---

<Layout title="Fiestas Guatemala">
  <div class="bg-[#fcfaf4] min-h-screen font-sans text-[#243447]">
    
    <nav class="max-w-7xl mx-auto px-10 py-4 flex justify-between items-center text-[14px] text-[#5d4d37] font-semibold border-b border-gray-100">
      <div class="flex gap-8 items-center flex-1">
        <a href="#" class="hover:text-[#a68a56]">Categorías ▾</a>
        <a href="#" class="hover:text-[#a68a56]">Departamentos</a>
      </div>
      
      <div class="flex justify-center px-4">
        <img 
          src="/Logo-Fiestas-Guatemala.jpg" 
          alt="Fiestas Guatemala" 
          class="h-20 w-auto object-contain" 
        />
      </div>

      <div class="flex gap-8 items-center flex-1 justify-end">
        <a href="#" class="hover:text-[#a68a56]">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-6 py-2.5 rounded-full text-xs font-bold hover:bg-[#324a63] transition-colors">Login / Registrarse</a>
      </div>
    </nav>

    <header class="pt-10 pb-16 px-6 text-center">
        <h1 class="text-4xl md:text-5xl font-serif text-[#243447] mb-2 tracking-tight">
          FiestasGuatemala<span class="text-[#a68a56]">.com</span>
        </h1>
        
        <p class="text-[12px] font-medium text-[#7a7a7a] uppercase tracking-[0.2em] mb-10">
          Aquí tú eres el alma de la fiesta
        </p>

        <div class="max-w-4xl mx-auto bg-[#243447] p-2 rounded-full shadow-2xl flex flex-col md:flex-row items-center">
          <div class="flex-[1.2] flex items-center px-6 w-full border-b md:border-b-0 md:border-r border-white/10">
            <span class="text-white/60 mr-3 text-lg">🔍</span>
            <input type="text" placeholder="¿Qué buscas? (Ej: Mariachis)" class="w-full bg-transparent py-4 text-white outline-none placeholder:text-white/40 text-sm font-light" />
          </div>
          <div class="flex-1 flex items-center px-6 w-full">
            <span class="text-white/60 mr-3 text-lg">📍</span>
            <select class="w-full bg-transparent py-4 text-white outline-none cursor-pointer text-sm font-light">
              <option class="text-black">Guatemala (Departamento)</option>
            </select>
          </div>
          <button class="w-full md:w-auto bg-[#a68a56] hover:bg-[#c5ab78] text-white font-bold px-10 py-4 rounded-full transition-all text-xs uppercase tracking-widest m-1 shadow-lg active:scale-95">
            Buscar Ahora
          </button>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-10 pb-40">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {categorias.map((cat) => (
          <div class="bg-white rounded-[40px] overflow-hidden shadow-[0_10px_40px_rgba(0,0,0,0.03)] border border-gray-100/50 hover:shadow-xl transition-shadow flex flex-col">
            <div class="relative h-64">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover" />
            </div>
            <div class="p-8">
              <div class="flex items-center gap-6">
                <div class="w-14 h-14 bg-[#fcfaf4] rounded-[20px] flex items-center justify-center text-3xl shadow-inner">
                  {cat.icon}
                </div>
                <h3 class="font-bold text-xl tracking-tight text-[#243447]">{cat.nombre}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-24 pb-12 px-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-16">
        <div class="space-y-8">
          <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-14 brightness-0 invert" />
          <p class="text-gray-400 text-sm leading-relaxed">Expertos en hacer de tu evento un momento inolvidable. El directorio más confiable de Guatemala.</p>
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-bold hover:bg-[#a68a56] transition-colors cursor-pointer text-lg">f</div>
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-bold hover:bg-[#a68a56] transition-colors cursor-pointer text-lg">i</div>
          </div>
        </div>
        
        <div>
          <h4 class="font-bold mb-8 text-[#a68a56] text-[11px] uppercase tracking-[0.2em]">Explorar</h4>
          <ul class="space-y-4 text-[13px] text-gray-400 font-medium">
            <li class="hover:text-white cursor-pointer">Todas las Categorías</li>
            <li class="hover:text-white cursor-pointer">Departamentos</li>
            <li class="hover:text-white cursor-pointer">Proveedores Verificados</li>
          </ul>
        </div>

        <div>
          <h4 class="font-bold mb-8 text-[#a68a56] text-[11px] uppercase tracking-[0.2em]">Empresa</h4>
          <ul class="space-y-4 text-[13px] text-gray-400 font-medium">
            <li class="hover:text-white cursor-pointer">Sobre Nosotros</li>
            <li class="hover:text-white cursor-pointer">Contacto</li>
            <li class="hover:text-white cursor-pointer text-red-400/80">SOS / Emergencias</li>
          </ul>
        </div>

        <div>
          <h4 class="font-bold mb-8 text-[#a68a56] text-[11px] uppercase tracking-[0.2em]">Legal</h4>
          <ul class="space-y-4 text-[13px] text-gray-400 font-medium">
            <li class="hover:text-white cursor-pointer">Privacidad</li>
            <li class="hover:text-white cursor-pointer">Términos</li>
          </ul>
        </div>
      </div>
      <div class="max-w-7xl mx-auto mt-24 pt-8 border-t border-white/5 text-center">
        <p class="text-[10px] text-gray-500 uppercase tracking-widest font-bold">© 2026 Fiestas Guatemala. Todos los derechos reservados.</p>
      </div>
    </footer>
  </div>
</Layout>