---
import Layout from '../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

let categorias = [];
try {
  const { rows } = await sql`SELECT * FROM categorias ORDER BY orden ASC`;
  categorias = rows;
} catch (e) {
  console.error(e);
}

// Imágenes para el carrusel superior (basadas en la imagen)
const carrusel = [
  "https://images.unsplash.com/photo-1519167758481-83f550bb49b3",
  "https://images.unsplash.com/photo-1530103043960-ef38714abb15",
  "https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3",
  "https://images.unsplash.com/photo-1464366400600-7168b8af9bc3",
  "https://images.unsplash.com/photo-1511795409834-ef04bbd61622"
];
---

<Layout title="FiestasGuatemala.com | Aquí tú eres el alma de la fiesta">
  <header class="bg-[#FCFAF3] py-4 px-6 border-b border-gray-100">
    <div class="max-w-7xl mx-auto flex flex-wrap justify-between items-center gap-4">
      <div class="flex gap-6 text-sm font-medium text-gray-700">
        <a href="#" class="hover:text-gray-900 flex items-center gap-1">Categorías <span class="text-[10px]">▼</span></a>
        <a href="#" class="hover:text-gray-900">Departamentos</a>
      </div>
      
      <div class="text-center">
        <h1 class="text-2xl font-serif font-bold text-[#1e293b]">FiestasGuatemala.com</h1>
        <p class="text-xs text-gray-500 italic">Aquí tú eres el alma de la fiesta</p>
      </div>

      <div class="flex gap-6 text-sm font-medium text-gray-700">
        <a href="#" class="flex items-center gap-1">Favoritos ♡</a>
        <a href="#">Login / Registrarse</a>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 pb-20">
    
    <section class="flex gap-4 overflow-x-auto py-8 no-scrollbar">
      {carrusel.map((img) => (
        <div class="min-w-[200px] h-64 rounded-2xl overflow-hidden shadow-md">
          <img src={img} class="w-full h-full object-cover" alt="Evento" />
        </div>
      ))}
    </section>

    <section class="mb-12">
      <div class="bg-[#1e293b] rounded-full p-2 flex flex-col md:flex-row items-center shadow-xl max-w-5xl mx-auto">
        <div class="flex-1 flex items-center px-6 py-3 border-r border-slate-700 w-full">
          <span class="mr-3">🔍</span>
          <input 
            type="text" 
            id="mainSearch"
            placeholder="¿Qué buscas? (Categoría)" 
            class="bg-transparent text-white w-full outline-none placeholder:text-slate-400"
          >
        </div>
        <div class="flex-1 flex items-center px-6 py-3 w-full md:border-r border-slate-700">
          <span class="mr-3">📍</span>
          <input 
            type="text" 
            placeholder="Guatemala (Departamento)" 
            class="bg-transparent text-white w-full outline-none placeholder:text-slate-400"
          >
        </div>
        <button 
          id="btnBuscar"
          class="bg-[#a38a5e] text-white px-8 py-4 rounded-full font-bold hover:bg-[#8e7852] transition-colors whitespace-nowrap text-sm m-1"
        >
          BUSCAR PROVEEDORES VERIFICADOS
        </button>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {categorias.map((cat, index) => (
        <a href={`/${cat.slug}`} class="group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all border border-gray-100">
          <div class="h-48 overflow-hidden">
            <img 
              src={`https://images.unsplash.com/photo-1519167758481-83f550bb49b3?auto=format&fit=crop&q=80&w=400&index=${index}`} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
              alt={cat.nombre} 
            />
          </div>
          <div class="bg-white p-4 flex items-center gap-3">
            <div class="w-8 h-8 flex items-center justify-center grayscale group-hover:grayscale-0 transition-all">
               <span class="text-xl">{cat.icono}</span>
            </div>
            <h3 class="font-bold text-gray-800 text-lg">
              {index + 1}. {cat.nombre}
            </h3>
          </div>
        </a>
      ))}
    </section>
  </main>

  <footer class="bg-[#FCFAF3] py-10 border-t border-gray-200 text-center text-xs text-gray-600">
    <div class="max-w-4xl mx-auto px-4">
      <p class="mb-2">Dirección: Boulevard Los Proceres 24-69 zona 10, Edificio Zona Pradera, torre 2 oficina 1108</p>
      <p class="mb-2 font-bold">PBX 23022299</p>
      <p class="mb-6">asitencia@fiestasguatemala.com</p>
      
      <button class="bg-[#a38a5e] bg-opacity-20 text-[#8e7852] px-6 py-3 rounded-full font-bold inline-flex items-center gap-2">
        ¿Necesitas ayuda urgente? <span class="bg-[#a38a5e] text-white rounded-full w-5 h-5 flex items-center justify-center text-[10px]">SOS</span>
      </button>
    </div>
  </footer>
</Layout>

<script>
  const btn = document.getElementById('btnBuscar');
  const input = document.getElementById('mainSearch') as HTMLInputElement;

  function normalizar(texto) {
    return texto.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
  }

  btn?.addEventListener('click', () => {
    const val = normalizar(input.value);
    
    if (val.includes('mariachi')) window.location.href = '/mariachis';
    else if (val.includes('finca')) window.location.href = '/fincas';
    else if (val.includes('salon')) window.location.href = '/salones';
    else if (val.includes('catering') || val.includes('banquete')) window.location.href = '/catering';
    else if (val.includes('payaso')) window.location.href = '/payasos';
    else alert('Busca una categoría como "Mariachis" o "Fincas"');
  });

  input?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') btn?.click();
  });
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>