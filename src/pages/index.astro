---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡', slug: 'fincas-para-bodas' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️', slug: 'salones-de-eventos' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️', slug: 'catering-banquetes' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈', slug: 'juegos-infantiles' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨', slug: 'decoradores' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋', slug: 'organizadores-de-eventos' },
];
---

<Layout title="Fiestas Guatemala | Directorio Premium">
  <div class="bg-[#fcfaf4] min-h-screen font-sans text-[#243447]">
    
    <nav class="max-w-7xl mx-auto px-10 py-2 flex justify-between items-center text-[12px] font-bold uppercase tracking-widest text-[#8b7355]">
      <div class="flex gap-8 items-center flex-1">
        <a href="#" class="hover:text-[#a68a56] transition-colors">Categorías ▾</a>
        <a href="#" class="hover:text-[#a68a56] transition-colors">Departamentos</a>
      </div>
      
      <div class="flex flex-col items-center flex-1">
        <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-16 w-auto" />
        <h2 class="text-xl font-serif font-light text-[#243447] tracking-tight -mt-1">FiestasGuatemala<span class="text-[#a68a56]">.com</span></h2>
        <p class="text-[7px] font-bold text-gray-400 uppercase tracking-[0.5em] -mt-1">Aquí tú eres el alma de la fiesta</p>
      </div>

      <div class="flex gap-8 items-center flex-1 justify-end">
        <a href="#" class="hover:text-[#a68a56] transition-colors">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-5 py-2 rounded-full text-[10px] tracking-widest hover:bg-black transition-all">Login / Registro</a>
      </div>
    </nav>

    <header class="pt-2 pb-8 px-6">
      <div class="max-w-4xl mx-auto bg-[#243447] rounded-full p-1 shadow-[0_20px_50px_-10px_rgba(36,52,71,0.4)] flex items-center border border-white/5">
        <div class="flex-[1.4] flex items-center px-6 border-r border-white/10">
          <span class="text-white text-base">🔍</span>
          <input type="text" placeholder="¿Qué buscas? (Categoría)" class="bg-transparent w-full text-white text-sm outline-none placeholder:text-white/40 py-3 px-4 font-light" />
        </div>
        <div class="flex-1 flex items-center px-6">
          <span class="text-white text-base">📍</span>
          <input type="text" placeholder="Guatemala (Departamento)" class="bg-transparent w-full text-white text-sm outline-none placeholder:text-white/40 py-3 px-4 font-light" />
        </div>
        <button class="bg-[#a68a56] text-white px-8 py-3 rounded-full text-[9px] font-black uppercase tracking-widest hover:bg-[#c5ab78] transition-all active:scale-95 shadow-lg">
          Buscar Proveedores Verificados
        </button>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-10 pb-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {categorias.map((cat, i) => (
          <div class="group bg-white rounded-[35px] overflow-hidden shadow-[0_10px_30px_-15px_rgba(0,0,0,0.1)] border border-gray-100 hover:shadow-[0_20px_50px_-10px_rgba(166,138,86,0.2)] transition-all duration-500 cursor-pointer">
            <div class="h-44 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            </div>
            
            <div class="p-6 flex items-center gap-4">
              <div class="w-12 h-12 bg-[#fcfaf4] rounded-xl flex items-center justify-center text-2xl border border-gray-50">
                {cat.icon}
              </div>
              <div class="flex-1">
                <h3 class="text-lg font-serif font-light text-[#243447] leading-tight">
                  <span class="text-[#a68a56] font-sans font-bold text-xs mr-1">{i + 1}.</span> {cat.nombre}
                </h3>
                <div class="flex items-center mt-1">
                  <span class="text-[#a68a56] text-xs">★★★★★</span>
                  <span class="text-[9px] font-bold text-gray-300 ml-1 uppercase">4.0</span>
                </div>
                <p class="text-[8px] font-bold uppercase tracking-widest text-gray-400 mt-1">Sello de Verificado</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-16 pb-10 px-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
        <div class="col-span-1 space-y-4 text-gray-400 text-[11px] font-light">
          <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-8 brightness-0 invert opacity-70" />
          <p>Boulevard Los Proceres 24-69 zona 10,<br/>Edificio Zona Pradera</p>
          <p class="font-bold text-[#a68a56]">PBX: 2302-2201</p>
        </div>
        <div>
          <h4 class="text-[#a68a56] uppercase text-[9px] font-black tracking-widest mb-6">Categorías</h4>
          <ul class="text-gray-400 text-[11px] space-y-3 font-light">
            <li>Mariachis</li>
            <li>Salones</li>
            <li>Fincas</li>
          </ul>
        </div>
        <div>
          <h4 class="text-[#a68a56] uppercase text-[9px] font-black tracking-widest mb-6">Soporte</h4>
          <ul class="text-gray-400 text-[11px] space-y-3 font-light">
            <li>Nosotros</li>
            <li>Términos</li>
            <li class="text-red-400/60 font-bold">SOS Emergencias</li>
          </ul>
        </div>
        <div class="flex flex-col md:items-end justify-center">
           <div class="flex gap-4 mb-4">
             <div class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#a68a56] transition-all">f</div>
             <div class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#a68a56] transition-all">i</div>
           </div>
           <p class="text-[8px] text-gray-500 uppercase tracking-widest font-bold">© 2026 FiestasGuatemala.com</p>
        </div>
      </div>
    </footer>
  </div>
</Layout>