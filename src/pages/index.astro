---
import Layout from '../layouts/Layout.astro';

// 1. Array completo de 7 categorías
const categorias = [
  { nombre: 'Salones de fiestas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏛️', slug: 'salones-de-fiestas' },
  { nombre: 'Jardines para eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🌿', slug: 'jardines-para-eventos' },
  { nombre: 'Alquifiestas', img: 'https://images.unsplash.com/photo-1478147427282-58a87a120781?q=80&w=800', icon: '🪑', slug: 'alquifiestas' },
  { nombre: 'Organizadores de fiestas', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋', slug: 'organizadores-de-fiestas' },
  { nombre: 'Mariachis', img: 'https://images.unsplash.com/photo-1593003426291-562a0a380926?q=80&w=800', icon: '🎸', slug: 'mariachis' },
  { nombre: 'Inflables', img: 'https://images.unsplash.com/photo-1574675623044-64478833959c?q=80&w=800', icon: '🎈', slug: 'inflables' },
  { nombre: 'Decoración', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨', slug: 'decoracion' },
];

const categoriasData = categorias.map(c => ({
  termino: c.nombre.toLowerCase(),
  slug: c.slug
}));
---

<Layout title="fiestasGuatemala.com | Directorio de Eventos y Proveedores Verificados">
  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    
    <nav class="max-w-6xl mx-auto px-4 py-1.5 flex justify-between items-center text-[12px] font-bold uppercase tracking-[0.15em] text-[#141510]">
      <div class="flex gap-8 items-center flex-1">
        <a href="#" class="hover:text-[#a68a56] transition-colors">Categorías ▾</a>
        <a href="#" class="hover:text-[#a68a56] transition-colors">Departamentos</a>
      </div>
      
      <div class="flex flex-col items-center flex-1">
        <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-14 w-auto" />
        <h2 class="text-[22px] font-serif font-light text-[#243447] tracking-tight -mt-1 leading-none normal-case" style="text-transform: none;">fiestasGuatemala<span class="text-[#a68a56]">.com</span></h2>
        <p class="text-[11px] font-sans font-bold text-[#8b7355] mt-0.5 tracking-tight">Aquí Tú Eres el Alma de la Fiesta</p>
      </div>

      <div class="flex gap-8 items-center flex-1 justify-end">
        <a href="#" class="hover:text-[#a68a56] transition-colors">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-5 py-1.5 rounded-full text-[9px] tracking-widest">Login / Registro</a>
      </div>
    </nav>

    <header class="pt-2 pb-5 px-4">
      <form id="search-form" class="max-w-4xl mx-auto bg-[#243447] rounded-full p-1 shadow-[0_15px_40px_-10px_rgba(36,52,71,0.4)] flex items-center border border-white/5">
        <div class="flex-[1.4] flex items-center px-6 border-r border-white/10">
          <input type="text" name="q" required placeholder="¿Qué buscas? (Categoría)" class="bg-transparent w-full text-white text-base outline-none placeholder:text-white/60 py-2.5 px-2 font-light" />
          <span class="text-white text-lg ml-1">🔍</span>
        </div>
        
        <div class="flex-1 flex items-center px-6">
          <span class="text-white text-lg mr-2">📍</span>
          <input type="text" name="location" placeholder="Guatemala" class="bg-transparent w-full text-white text-base outline-none placeholder:text-white/60 py-2.5 px-2 font-light" />
        </div>
        
        <button type="submit" class="bg-[#a68a56] text-white px-8 py-3 rounded-full text-[11px] font-black uppercase tracking-widest hover:bg-[#c5ab78] transition-all whitespace-nowrap active:scale-95 shadow-xl">
          Buscar Proveedores
        </button>
      </form>
    </header>

    <main class="max-w-6xl mx-auto px-6 pb-10">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {categorias.slice(0, 6).map((cat) => (
          <div class="group bg-white rounded-[28px] overflow-hidden shadow-[0_12px_35px_rgba(0,0,0,0.1)] border border-gray-100/50 hover:shadow-2xl transition-all duration-500 cursor-pointer" onclick={`window.location.href='/${cat.slug}'`}>
            <div class="h-36 lg:h-40 overflow-hidden relative">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
              <div class="absolute bottom-3 right-3 bg-white/90 backdrop-blur px-2.5 py-1 rounded-full shadow-sm border border-gray-100 flex items-center gap-1">
                <span class="text-[#a68a56] text-[8px]">★</span>
                <span class="text-[7px] font-black uppercase tracking-widest text-[#243447]">Proveedores Verificados</span>
              </div>
            </div>
            
            <div class="py-4 px-6 flex items-center justify-center gap-3">
              <span class="text-xl brightness-50 sepia-[1] hue-rotate-[10deg] saturate-[1.5]" style="color: #8b7355;">{cat.icon}</span>
              <h3 class="font-sans font-normal text-[#141510] text-lg leading-tight tracking-tight group-hover:text-[#a68a56] transition-colors">
                {cat.nombre}
              </h3>
            </div>
          </div>
        ))}
      </div>
    </main>

    <section class="max-w-4xl mx-auto px-6 pb-16 text-center text-[#8b7355]/80 font-light">
      <div class="border-t border-[#8b7355]/10 pt-8">
        <h1 class="text-base font-serif mb-2 tracking-tight">Directorio de Eventos y Fiestas en Guatemala</h1>
        <p class="text-[11px] leading-relaxed max-w-2xl mx-auto mb-4 italic">
          Aquí Tú Eres el Alma de la Fiesta. Cotiza con proveedores verificados al instante.
        </p>
      </div>
    </section>

    <footer class="bg-[#243447] text-white pt-12 pb-8 px-10 text-[10px]">
      <div class="max-w-4xl mx-auto grid grid-cols-4 gap-8 font-light text-center md:text-left">
        <div class="col-span-1 space-y-2 opacity-60 text-left">
          <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-6 brightness-0 invert mx-auto md:mx-0" />
          <p>Boulevard Los Proceres 24-69 zona 10</p>
          <p class="font-bold text-[#a68a56]">2302-2201</p>
        </div>
        <div>
          <h4 class="text-[#a68a56] uppercase text-[7px] font-black tracking-widest mb-3">Explorar</h4>
          <ul class="space-y-1 opacity-50"><li>Mariachis</li><li>Salones</li></ul>
        </div>
        <div>
          <h4 class="text-[#a68a56] uppercase text-[7px] font-black tracking-widest mb-3">Soporte</h4>
          <ul class="space-y-1 opacity-50"><li>Nosotros</li><li class="text-red-400">SOS</li></ul>
        </div>
        <div class="flex flex-col items-center md:items-end gap-2">
           <div class="flex gap-2">
             <div class="w-6 h-6 rounded-full border border-white/10 flex items-center justify-center">f</div>
             <div class="w-6 h-6 rounded-full border border-white/10 flex items-center justify-center">i</div>
           </div>
           <p class="text-[7px] opacity-30 font-bold uppercase">© 2026 fiestasGuatemala.com</p>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script is:inline define:vars={{ categoriasData }}>
  const form = document.getElementById('search-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const query = formData.get('q').toString().toLowerCase().trim();
      const coincidencia = categoriasData.find(c => query.includes(c.termino) || c.termino.includes(query));
      window.location.href = coincidencia ? `/${coincidencia.slug}` : `/search?q=${encodeURIComponent(query)}`;
    });
  }
</script>