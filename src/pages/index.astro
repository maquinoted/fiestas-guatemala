---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋' },
  { nombre: 'Mariachis', img: 'https://images.unsplash.com/photo-1593003426291-562a0a380926?q=80&w=800', icon: '🎸' },
  { nombre: 'Fotógrafos', img: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800', icon: '📷' },
  { nombre: 'Pasteles', img: 'https://images.unsplash.com/photo-1535141192574-5d4897c12636?q=80&w=800', icon: '🎂' },
];
---

<Layout title="Fiestas Guatemala">
  <div class="bg-[#fcfaf4] min-h-screen font-sans text-[#243447]">
    
    <a href="https://wa.me/50223022201" target="_blank" class="fixed bottom-8 right-8 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.588-5.946 0-6.556 5.332-11.888 11.888-11.888 3.176 0 6.164 1.236 8.41 3.483 2.247 2.247 3.483 5.235 3.483 8.41 0 6.556-5.332 11.888-11.888 11.888-2.003 0-3.96-.504-5.698-1.465l-6.104 1.68zm6.54-3.419c1.551.921 3.253 1.408 4.991 1.408 5.393 0 9.782-4.389 9.782-9.782 0-2.612-1.017-5.067-2.863-6.913-1.847-1.847-4.302-2.864-6.913-2.864-5.392 0-9.781 4.389-9.781 9.782 0 1.83.513 3.613 1.482 5.187l-1.008 3.684 3.771-.976-.464-.228z"/></svg>
    </a>

    <nav class="max-w-7xl mx-auto px-10 py-2 flex justify-between items-center text-[13px] text-[#5d4d37] font-medium border-b border-gray-100">
      <div class="flex gap-8 items-center flex-1">
        <a href="#" class="hover:text-[#a68a56]">Categorías ▾</a>
        <a href="#" class="hover:text-[#a68a56]">Departamentos</a>
      </div>
      
      <div class="flex flex-col items-center">
        <img src="/Logo-Fiestas-Guatemala.jpg" alt="Fiestas Guatemala" class="h-16 w-auto object-contain" />
      </div>

      <div class="flex gap-8 items-center flex-1 justify-end">
        <a href="#" class="hover:text-[#a68a56]">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-5 py-2 rounded-full text-xs font-bold">Login</a>
      </div>
    </nav>

    <header class="pt-6 pb-12 px-6 text-center">
        <h1 class="text-4xl font-serif font-light text-[#243447] mb-1">
          FiestasGuatemala<span class="text-[#a68a56]">.com</span>
        </h1>
        
        <p class="text-[10px] font-medium text-[#8b8b8b] uppercase tracking-[0.2em] mb-8">
          Aquí tú eres el alma de la fiesta
        </p>

        <form class="max-w-4xl mx-auto bg-[#243447] p-2 rounded-full shadow-2xl flex flex-col md:flex-row items-center border border-white/10">
          <div class="flex-[1.2] flex items-center px-6 w-full border-r border-white/10">
            <span class="text-white/40 mr-3">🔍</span>
            <input type="text" name="q" placeholder="¿Qué buscas? (Ej: Mariachis)" class="w-full bg-transparent py-4 text-white outline-none placeholder:text-white/40 text-sm font-light" />
          </div>
          <div class="flex-1 flex items-center px-6 w-full">
            <span class="text-white/40 mr-3">📍</span>
            <select name="location" class="w-full bg-transparent py-4 text-white outline-none cursor-pointer text-sm font-light">
              <option value="guatemala">Guatemala (Departamento)</option>
            </select>
          </div>
          <button type="submit" class="bg-[#a68a56] hover:bg-[#c5ab78] text-white font-bold px-10 py-4 rounded-full transition-all text-xs uppercase tracking-widest m-1">
            Buscar Ahora
          </button>
        </form>
    </header>

    <main class="max-w-7xl mx-auto px-10 pb-40">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {categorias.map((cat) => (
          <div class="bg-white rounded-[40px] overflow-hidden shadow-sm border border-gray-100 flex flex-col group">
            <div class="relative h-60">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-[#fcfaf4] rounded-2xl flex items-center justify-center text-2xl border border-gray-50">
                  {cat.icon}
                </div>
                <h3 class="font-light text-lg text-[#5d4d37] tracking-tight">{cat.nombre}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-20 pb-12 px-10 text-[13px]">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-16">
        <div class="space-y-6">
          <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-10 brightness-0 invert" />
          <div class="text-gray-400 leading-relaxed font-light">
            <p>Boulevard Los Proceres 24-69 zona 10,</p>
            <p>Edificio Zona Pradera, torre 2, oficina 1108</p>
            <p class="mt-4 font-bold text-[#a68a56]">PBX: 2302-2201</p>
          </div>
        </div>
        
        <div>
          <h4 class="font-bold mb-6 text-[#a68a56] text-[11px] uppercase tracking-widest">Explorar</h4>
          <ul class="space-y-3 text-gray-400 font-light">
            <li>Todas las Categorías</li>
            <li>Directorio de Departamentos</li>
            <li>Proveedores Verificados</li>
          </ul>
        </div>

        <div class="flex flex-col items-start md:items-end">
          <h4 class="font-bold mb-6 text-[#a68a56] text-[11px] uppercase tracking-widest">Redes</h4>
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-bold hover:bg-[#a68a56] transition-colors cursor-pointer text-lg">f</div>
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-bold hover:bg-[#a68a56] transition-colors cursor-pointer text-lg">i</div>
          </div>
        </div>
      </div>
      <div class="max-w-7xl mx-auto mt-20 pt-8 border-t border-white/5 text-center text-gray-500 text-[10px]">
        © 2026 Fiestas Guatemala. Todos los derechos reservados.
      </div>
    </footer>
  </div>
</Layout>