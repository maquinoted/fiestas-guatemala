---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋' },
  { nombre: 'Mariachis', img: 'https://images.unsplash.com/photo-1593003426291-562a0a380926?q=80&w=800', icon: '🎸' },
  { nombre: 'Fotógrafos', img: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800', icon: '📷' },
  { nombre: 'Pasteles', img: 'https://images.unsplash.com/photo-1535141192574-5d4897c12636?q=80&w=800', icon: '🎂' },
];
---

<Layout title="Fiestas Guatemala">
  <div class="bg-[#F5F3E7] min-h-screen font-sans text-[#243447] selection:bg-[#a68a56] selection:text-white">
    
    <nav class="max-w-7xl mx-auto px-8 py-6 flex justify-between items-center text-[12px] font-black uppercase tracking-widest border-b border-gray-200/40">
      <div class="flex gap-10">
        <a href="#" class="hover:text-[#a68a56] transition-all">Categorías <span class="text-[8px] ml-1">▼</span></a>
        <a href="#" class="hover:text-[#a68a56] transition-all">Departamentos</a>
      </div>
      <div class="flex gap-10 items-center">
        <a href="#" class="hover:text-[#a68a56] transition-all">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-8 py-3 rounded-full hover:scale-105 transition-all shadow-lg active:scale-95">Login / Registrarse</a>
      </div>
    </nav>

    <header class="pt-16 pb-20 px-6 text-center">
        <div class="mb-14">
            <img 
              src="/Logo-Fiestas-Guatemala.jpg" 
              alt="Fiestas Guatemala" 
              class="h-28 mx-auto object-contain drop-shadow-sm" 
            />
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.5em] mt-4">Aquí tú eres el alma de la fiesta</p>
        </div>

        <div class="max-w-4xl mx-auto bg-[#243447] p-1.5 rounded-full shadow-[0_25px_60px_-15px_rgba(0,0,0,0.3)] flex flex-col md:flex-row items-center border border-white/10">
          <div class="flex-[1.2] flex items-center px-8">
            <span class="opacity-40 text-white mr-3">🔍</span>
            <input type="text" placeholder="¿Qué buscas? (Categoría)" class="w-full bg-transparent py-4 text-white outline-none placeholder:text-gray-400 text-sm font-bold" />
          </div>
          <div class="hidden md:block w-[1px] h-8 bg-white/10"></div>
          <div class="flex-1 flex items-center px-8">
            <span class="opacity-40 text-white mr-3">📍</span>
            <select class="w-full bg-transparent py-4 text-white outline-none cursor-pointer text-sm font-bold appearance-none">
              <option>Guatemala (Departamento)</option>
            </select>
          </div>
          <button class="bg-[#a68a56] hover:bg-[#c5ab78] text-white font-black px-12 py-4 rounded-full transition-all text-xs uppercase tracking-widest m-1 shadow-xl active:scale-95">
            Buscar Proveedores
          </button>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-8 pb-40">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {categorias.map((cat, i) => (
          <div class="bg-white rounded-[40px] overflow-hidden shadow-[0_15px_35px_rgba(0,0,0,0.04)] hover:shadow-[0_30px_60px_rgba(0,0,0,0.1)] transition-all duration-500 group border border-gray-100/50">
            <div class="relative h-64 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
              <div class="absolute top-6 right-6 bg-[#a68a56] w-10 h-10 rounded-full flex items-center justify-center text-white font-black text-xs shadow-xl border-2 border-white/30">
                {i + 1}
              </div>
            </div>
            
            <div class="p-10">
              <div class="flex items-center gap-6">
                <div class="w-16 h-16 bg-[#F5F3E7] rounded-[24px] flex items-center justify-center text-3xl shadow-inner border border-black/5">
                  {cat.icon}
                </div>
                <div class="flex-1">
                  <h3 class="font-black text-xl tracking-tight leading-none text-[#243447] mb-2">{cat.nombre}</h3>
                  <div class="flex items-center gap-2">
                    <span class="text-[#a68a56] text-xs">★★★★★</span>
                    <span class="text-gray-300 text-[11px] font-black uppercase">4.0</span>
                  </div>
                </div>
              </div>
              <div class="mt-8 pt-6 border-t border-gray-50 flex items-center">
                <div class="flex items-center gap-2">
                    <div class="w-1.5 h-1.5 bg-green-500 rounded-full shadow-[0_0_10px_rgba(34,197,94,0.5)]"></div>
                    <span class="text-[9px] font-black uppercase tracking-[0.2em] text-gray-400">Sello de Verificado</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-32 pb-16 px-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-20">
        <div class="space-y-10">
          <img src="https://fiestasguatemala.com/wp-content/uploads/2023/06/Logo-Fiestas-Guatemala.png" alt="Logo" class="h-16 brightness-0 invert opacity-100" />
          <p class="text-gray-400 text-sm leading-relaxed font-medium">Expertos en hacer de tu evento un momento inolvidable. El directorio más confiable de Guatemala.</p>
          <div class="flex gap-5">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[#a68a56] transition-all cursor-pointer font-bold">f</div>
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[#a68a56] transition-all cursor-pointer font-bold">i</div>
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[#a68a56] transition-all cursor-pointer font-bold">t</div>
          </div>
        </div>
        
        <div>
          <h4 class="font-black mb-10 text-[#a68a56] text-[10px] uppercase tracking-[0.3em]">Categorías</h4>
          <ul class="space-y-5 text-[13px] text-gray-400 font-bold">
            <li class="hover:text-white cursor-pointer transition-colors">Mariachis</li>
            <li class="hover:text-white cursor-pointer transition-colors">Fotógrafos</li>
            <li class="hover:text-white cursor-pointer transition-colors">Pasteles</li>
            <li class="hover:text-white cursor-pointer font-black text-white underline decoration-[#a68a56] underline-offset-8">Ver todas</li>
          </ul>
        </div>

        <div>
          <h4 class="font-black mb-10 text-[#a68a56] text-[10px] uppercase tracking-[0.3em]">Servicios</h4>
          <ul class="space-y-5 text-[13px] text-gray-400 font-bold">
            <li class="hover:text-white cursor-pointer transition-colors">Sobre Nosotros</li>
            <li class="hover:text-white cursor-pointer transition-colors text-red-400/80 uppercase text-[11px]">SOS / Emergencias</li>
          </ul>
        </div>

        <div>
          <h4 class="font-black mb-10 text-[#a68a56] text-[10px] uppercase tracking-[0.3em]">Zonas</h4>
          <ul class="space-y-5 text-[13px] text-gray-400 font-bold">
            <li class="hover:text-white cursor-pointer transition-colors font-black text-white underline decoration-[#a68a56] underline-offset-8">Ver todas</li>
          </ul>
        </div>
      </div>
      <div class="max-w-7xl mx-auto mt-32 pt-10 border-t border-white/5 text-center">
        <p class="text-[9px] text-gray-500 uppercase tracking-[0.4em] font-black">© 2026 Fiestas Guatemala. Todos los derechos reservados.</p>
      </div>
    </footer>
  </div>
</Layout>