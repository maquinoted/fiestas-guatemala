---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋' },
  { nombre: 'Mariachis', img: 'https://images.unsplash.com/photo-1593003426291-562a0a380926?q=80&w=800', icon: '🎸' },
  { nombre: 'Fotógrafos', img: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800', icon: '📷' },
  { nombre: 'Pasteles', img: 'https://images.unsplash.com/photo-1535141192574-5d4897c12636?q=80&w=800', icon: '🎂' },
];
---

<Layout title="Fiestas Guatemala">
  <div class="bg-[#fcfaf4] min-h-screen font-light text-[#243447]">
    
    <nav class="max-w-7xl mx-auto px-10 py-4 flex justify-between items-center text-[13px] text-[#8b7355] font-light">
      <div class="flex gap-8 items-center flex-1">
        <a href="#" class="hover:text-[#a68a56] transition-colors">Categorías ▾</a>
        <a href="#" class="hover:text-[#a68a56] transition-colors">Departamentos</a>
      </div>
      
      <div class="flex flex-col items-center px-10">
        <img 
          src="/logo-fiestas-guatemala.jpg" 
          alt="Fiestas Guatemala" 
          class="h-16 object-contain" 
        />
      </div>

      <div class="flex gap-8 items-center flex-1 justify-end">
        <a href="#" class="hover:text-[#a68a56] transition-colors">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-6 py-2 rounded-full text-xs font-medium">Login / Registrarse</a>
      </div>
    </nav>

    <header class="pt-4 pb-16 px-6 text-center">
        <div class="mb-10">
            <p class="text-[11px] font-medium text-[#8b8b8b] uppercase tracking-[0.4em] mb-8">Aquí tú eres el alma de la fiesta</p>

            <div class="max-w-4xl mx-auto bg-[#243447] p-1.5 rounded-full shadow-xl flex flex-col md:flex-row items-center border border-white/10">
              <div class="flex-[1.2] flex items-center px-8 w-full border-r border-white/10">
                <span class="text-white/40 mr-3">🔍</span>
                <input type="text" placeholder="¿Qué buscas?" class="w-full bg-transparent py-4 text-white outline-none placeholder:text-white/40 text-sm font-light" />
              </div>
              <div class="flex-1 flex items-center px-8 w-full">
                <span class="text-white/40 mr-3">📍</span>
                <select class="w-full bg-transparent py-4 text-white outline-none cursor-pointer text-sm font-light appearance-none">
                  <option>Guatemala (Departamento)</option>
                </select>
              </div>
              <button class="bg-[#a68a56] text-white font-medium px-10 py-4 rounded-full transition-all text-xs uppercase m-1 whitespace-nowrap">
                Buscar Proveedores
              </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-10 pb-40">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {categorias.map((cat) => (
          <div class="bg-white rounded-[35px] overflow-hidden shadow-[0_10px_30px_rgba(0,0,0,0.03)] border border-gray-100/50 flex flex-col">
            <div class="relative h-60 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover" />
            </div>
            
            <div class="p-6">
              <div class="flex items-center gap-5">
                <div class="w-12 h-12 bg-[#fcfaf4] rounded-[15px] flex items-center justify-center text-2xl border border-black/5">
                  {cat.icon}
                </div>
                <div class="flex-1">
                  <h3 class="font-medium text-lg tracking-tight text-[#243447]">{cat.nombre}</h3>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-20 pb-10 px-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-16">
        <div class="space-y-6">
          <img src="/logo-fiestas-guatemala.jpg" alt="Logo" class="h-12 brightness-0 invert" />
          <p class="text-gray-400 text-[13px] leading-relaxed">Expertos en hacer de tu evento un momento inolvidable.</p>
        </div>
        
        <div>
          <h4 class="font-bold mb-6 text-[#a68a56] text-[11px] uppercase tracking-widest">Categorías</h4>
          <ul class="space-y-3 text-[13px] text-gray-400">
            <li>Mariachis</li>
            <li class="text-white underline decoration-[#a68a56] underline-offset-4 cursor-pointer">Ver todas</li>
          </ul>
        </div>
        </div>
    </footer>
  </div>
</Layout>