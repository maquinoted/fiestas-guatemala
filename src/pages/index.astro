---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋' },
  { nombre: 'Mariachis', img: 'https://images.unsplash.com/photo-1593003426291-562a0a380926?q=80&w=800', icon: '🎸' },
  { nombre: 'Fotógrafos', img: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800', icon: '📷' },
  { nombre: 'Pasteles', img: 'https://images.unsplash.com/photo-1535141192574-5d4897c12636?q=80&w=800', icon: '🎂' },
];
---

<Layout title="Fiestas Guatemala">
  <div class="bg-[#F5F3E7] min-h-screen font-sans text-[#243447]">
    
    <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center text-[13px] font-bold border-b border-gray-200/50">
      <div class="flex gap-8 items-center">
        <a href="#" class="hover:text-[#a68a56] transition-colors flex items-center gap-1">Categorías <span class="text-[10px]">▼</span></a>
        <a href="#" class="hover:text-[#a68a56] transition-colors">Departamentos</a>
      </div>
      
      <div class="flex gap-8 items-center">
        <a href="#" class="hover:text-[#a68a56] transition-colors flex items-center gap-1">Favoritos <span class="text-lg">♡</span></a>
        <a href="#" class="bg-[#243447] text-white px-6 py-2.5 rounded-full hover:bg-[#a68a56] transition-all shadow-md">Login / Registrarse</a>
      </div>
    </nav>

    <header class="pt-12 pb-16 px-6 text-center">
        <div class="py-12">
            <img 
              src="https://fiestasguatemala.com/wp-content/uploads/2023/06/Logo-Fiestas-Guatemala.png" 
              alt="Fiestas Guatemala" 
              class="h-24 mx-auto object-contain mb-4" 
            />
            <p class="text-[11px] font-bold text-gray-400 uppercase tracking-[0.4em]">Aquí tú eres el alma de la fiesta</p>
        </div>

        <div class="max-w-4xl mx-auto bg-[#243447] p-1.5 rounded-full shadow-[0_20px_50px_rgba(0,0,0,0.15)] flex flex-col md:flex-row items-center border border-white/5">
          <div class="flex-1 flex items-center px-6 w-full">
            <input type="text" placeholder="¿Qué buscas? (Categoría)" class="w-full bg-transparent py-4 text-white outline-none placeholder:text-gray-400 text-sm font-medium" />
          </div>
          <div class="hidden md:block w-[1px] h-8 bg-white/10 mx-2"></div>
          <div class="flex-1 flex items-center px-6 w-full">
            <select class="w-full bg-transparent py-4 text-white outline-none cursor-pointer text-sm font-medium appearance-none">
              <option>Guatemala (Departamento)</option>
            </select>
          </div>
          <button class="bg-[#a68a56] hover:bg-[#8e7545] text-white font-black px-10 py-4 rounded-full transition-all text-sm m-1 whitespace-nowrap shadow-lg">
            Buscar Proveedores Verificados
          </button>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pb-32">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {categorias.map((cat, i) => (
          <div class="bg-white rounded-[35px] overflow-hidden shadow-[0_10px_30px_rgba(0,0,0,0.05)] hover:shadow-[0_25px_50px_rgba(0,0,0,0.12)] transition-all duration-500 flex flex-col group">
            <div class="relative h-60 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
              <div class="absolute top-5 right-5 bg-[#a68a56] w-9 h-9 rounded-full flex items-center justify-center text-white font-bold text-sm shadow-lg border-2 border-white/20">
                {i + 1}
              </div>
            </div>
            
            <div class="p-8">
              <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#F5F3E7] rounded-[22px] flex items-center justify-center text-3xl shadow-inner">
                  {cat.icon}
                </div>
                <div class="flex-1">
                  <h3 class="font-black text-xl leading-tight text-[#243447]">{cat.nombre}</h3>
                  <div class="flex items-center gap-2 mt-1">
                    <span class="text-[#a68a56] text-sm">★★★★★</span>
                    <span class="text-gray-400 text-sm font-bold">4.0</span>
                  </div>
                </div>
              </div>
              <div class="mt-6 pt-5 border-t border-gray-100 flex justify-between items-center">
                <div class="flex items-center gap-1">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                    <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">Verificado</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#1a2b3c] text-white pt-24 pb-12 px-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-16">
        <div class="space-y-8">
          <img src="https://fiestasguatemala.com/wp-content/uploads/2023/06/Logo-Fiestas-Guatemala.png" alt="Logo" class="h-14 brightness-0 invert opacity-90" />
          <p class="text-gray-400 text-sm leading-relaxed">Expertos en hacer de tu evento un momento inolvidable. El directorio más confiable de Guatemala.</p>
          <div class="flex gap-6 text-xl text-gray-400">
            <span class="hover:text-white cursor-pointer transition-colors">f</span>
            <span class="hover:text-white cursor-pointer transition-colors">i</span>
            <span class="hover:text-white cursor-pointer transition-colors">l</span>
            <span class="hover:text-white cursor-pointer transition-colors">w</span>
          </div>
        </div>
        
        <div>
          <h4 class="font-black mb-8 text-[#a68a56] text-xs uppercase tracking-[0.2em]">Categorías</h4>
          <ul class="space-y-4 text-sm text-gray-400 font-medium">
            <li class="hover:text-white transition-colors cursor-pointer">Mariachis</li>
            <li class="hover:text-white transition-colors cursor-pointer">Fotógrafos</li>
            <li class="hover:text-white transition-colors cursor-pointer">Pasteles</li>
            <li class="hover:text-white transition-colors cursor-pointer">Juegos Infantiles</li>
            <li class="hover:text-white transition-colors font-bold text-white underline decoration-[#a68a56] underline-offset-8">Ver todas</li>
          </ul>
        </div>

        <div>
          <h4 class="font-black mb-8 text-[#a68a56] text-xs uppercase tracking-[0.2em]">Servicios</h4>
          <ul class="space-y-4 text-sm text-gray-400 font-medium">
            <li class="hover:text-white transition-colors cursor-pointer">Sobre Nosotros</li>
            <li class="hover:text-white transition-colors cursor-pointer">Contáctanos</li>
            <li class="hover:text-white transition-colors cursor-pointer text-red-400/80 font-bold">SOS / Emergencias</li>
          </ul>
        </div>

        <div>
          <h4 class="font-black mb-8 text-[#a68a56] text-xs uppercase tracking-[0.2em]">Zonas</h4>
          <ul class="space-y-4 text-sm text-gray-400 font-medium">
            <li class="hover:text-white transition-colors cursor-pointer">Guatemala</li>
            <li class="hover:text-white transition-colors cursor-pointer">Antigua Guatemala</li>
            <li class="hover:text-white transition-colors font-bold text-white underline decoration-[#a68a56] underline-offset-8">Ver todas</li>
          </ul>
        </div>
      </div>
      
      <div class="max-w-7xl mx-auto mt-24 pt-8 border-t border-gray-800 text-center">
        <p class="text-[10px] text-gray-500 uppercase tracking-widest font-bold">© 2026 Fiestas Guatemala. Todos los derechos reservados.</p>
      </div>
    </footer>
  </div>
</Layout>