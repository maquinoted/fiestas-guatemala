---
import Layout from '../layouts/Layout.astro';

// ... tus constantes de categorías se quedan igual
---

<Layout title="Fiestas Guatemala">
  <div class="bg-[#f2f3ed] min-h-screen font-sans text-[#243447] selection:bg-[#a68a56] selection:text-white">
    
    <nav class="max-w-7xl mx-auto px-10 py-6 flex justify-between items-center text-[12px] font-black uppercase tracking-[0.2em] border-b border-gray-200/50">
      <div class="flex gap-10">
        <a href="#" class="hover:text-[#a68a56] transition-all flex items-center gap-1.5">Categorías <span class="text-[9px]">▼</span></a>
        <a href="#" class="hover:text-[#a68a56] transition-all">Departamentos</a>
      </div>
      
      <div class="flex gap-10 items-center">
        <a href="#" class="hover:text-[#a68a56] transition-all flex items-center gap-1.5 font-medium normal-case tracking-normal">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-7 py-3 rounded-full hover:bg-[#1a2b3c] transition-all shadow-md active:scale-95">Login / Registrarse</a>
      </div>
    </nav>

    <header class="pt-16 pb-20 px-6 text-center">
        <div class="py-12">
            <img src="/Logo-Fiestas-Guatemala.png" alt="Fiestas Guatemala" class="h-28 mx-auto object-contain mb-5" />
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.5em]">Aquí tú eres el alma de la fiesta</p>
        </div>

        <div class="max-w-4xl mx-auto bg-[#e8e4d9] p-2 rounded-full shadow-[0_30px_70px_rgba(0,0,0,0.1)] flex flex-col md:flex-row items-center border border-white/5">
          <div class="flex-[1.2] flex items-center px-8 w-full border-r border-gray-200/50">
            <span class="text-gray-400 mr-3">🔍</span>
            <input type="text" placeholder="¿Qué buscas? (Categoría)" class="w-full bg-transparent py-4 text-[#243447] outline-none placeholder:text-gray-500 text-sm font-medium" />
          </div>
          <div class="flex-1 flex items-center px-8 w-full">
            <span class="text-gray-400 mr-3">📍</span>
            <select class="w-full bg-transparent py-4 text-[#243447] outline-none cursor-pointer text-sm font-medium appearance-none">
              <option>Guatemala (Departamento)</option>
            </select>
          </div>
          <button class="bg-[#a68a56] hover:bg-[#c5ab78] text-white font-black px-12 py-4 rounded-full transition-all text-xs uppercase tracking-widest m-1 shadow-lg active:scale-95">
            Buscar Proveedores
          </button>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-10 pb-40">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-14">
        {categorias.map((cat, i) => (
          <div class="bg-white rounded-[45px] overflow-hidden shadow-[0_15px_35px_rgba(0,0,0,0.03)] hover:shadow-[0_30px_60px_rgba(0,0,0,0.1)] transition-all duration-500 flex flex-col group border border-gray-100/50">
            <div class="relative h-64 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute top-6 right-6 bg-[#a68a56] w-10 h-10 rounded-full flex items-center justify-center text-white font-black text-xs shadow-xl border-2 border-white/20">
                {i + 1}
              </div>
            </div>
            
            <div class="p-10">
              <div class="flex items-center gap-6">
                <div class="w-16 h-16 bg-[#f2f3ed] rounded-[24px] flex items-center justify-center text-4xl shadow-inner border border-black/5">
                  {cat.icon}
                </div>
                <div class="flex-1">
                  <h3 class="font-black text-xl tracking-tight leading-none text-[#243447] mb-2.5">{cat.nombre}</h3>
                  <div class="flex items-center gap-2">
                    <span class="text-[#a68a56] text-xs">★★★★★</span>
                    <span class="text-gray-300 text-[11px] font-black uppercase">4.0</span>
                  </div>
                </div>
              </div>
              <div class="mt-9 pt-6 border-t border-gray-100 flex items-center">
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_rgba(34,197,94,0.6)]"></span>
                    <span class="text-[9px] font-black uppercase tracking-[0.2em] text-gray-400">Verificado</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#3d4a5c] text-white pt-24 pb-12 px-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-16">
        <div class="space-y-10">
          <img src="/Logo-Fiestas-Guatemala.png" alt="Logo" class="h-16 brightness-0 invert opacity-100" />
          <p class="text-gray-300 text-sm leading-relaxed font-medium">Expertos en hacer de tu evento un momento inolvidable. El directorio más confiable de Guatemala.</p>
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[#a68a56] transition-all cursor-pointer font-bold text-lg">f</div>
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[#a68a56] transition-all cursor-pointer font-bold text-lg">i</div>
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[#a68a56] transition-all cursor-pointer font-bold text-lg">t</div>
          </div>
        </div>
        
        <div>
          <h4 class="font-black mb-10 text-[#a68a56] text-[10px] uppercase tracking-[0.3em]">Categorías</h4>
          <ul class="space-y-5 text-[13px] text-gray-300 font-bold">
            <li class="hover:text-white cursor-pointer transition-colors">Mariachis</li>
            <li class="hover:text-white cursor-pointer transition-colors">Fotógrafos</li>
            <li class="hover:text-white cursor-pointer transition-colors">Pasteles</li>
            <li class="hover:text-white cursor-pointer transition-colors">Juegos Infantiles</li>
            <li class="hover:text-white cursor-pointer font-black text-white underline decoration-[#a68a56] underline-offset-8">Ver todas</li>
          </ul>
        </div>

        <div>
          <h4 class="font-black mb-10 text-[#a68a56] text-[10px] uppercase tracking-[0.3em]">Servicios</h4>
          <ul class="space-y-5 text-[13px] text-gray-300 font-bold">
            <li class="hover:text-white cursor-pointer transition-colors">Sobre Nosotros</li>
            <li class="hover:text-white cursor-pointer transition-colors">Contáctanos</li>
            <li class="hover:text-white cursor-pointer transition-colors">Términos de Servicio</li>
            <li class="hover:text-white cursor-pointer font-black text-red-400 uppercase text-[11px]">SOS / Emergencias</li>
          </ul>
        </div>

        <div>
          <h4 class="font-black mb-10 text-[#a68a56] text-[10px] uppercase tracking-[0.3em]">Zonas</h4>
          <ul class="space-y-5 text-[13px] text-gray-300 font-bold">
            <li class="hover:text-white cursor-pointer transition-colors">Guatemala</li>
            <li class="hover:text-white cursor-pointer transition-colors">Antigua Guatemala</li>
            <li class="hover:text-white cursor-pointer transition-colors underline decoration-[#a68a56] underline-offset-8">Ver todas</li>
          </ul>
        </div>
      </div>
      
      <div class="max-w-7xl mx-auto mt-24 pt-8 border-t border-white/5 text-center">
        <p class="text-[9px] text-gray-500 uppercase tracking-[0.4em] font-black">© 2026 Fiestas Guatemala. Todos los derechos reservados.</p>
      </div>
    </footer>
  </div>
</Layout>