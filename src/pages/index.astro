---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋' },
  { nombre: 'Mariachis', img: 'https://images.unsplash.com/photo-1593003426291-562a0a380926?q=80&w=800', icon: '🎸' },
  { nombre: 'Fotógrafos', img: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800', icon: '📷' },
  { nombre: 'Pasteles', img: 'https://images.unsplash.com/photo-1535141192574-5d4897c12636?q=80&w=800', icon: '🎂' },
];
---

<Layout title="Fiestas Guatemala">
  <div class="bg-[#f2f3ed] min-h-screen font-sans text-[#243447]">
    
    <nav class="max-w-7xl mx-auto px-10 py-6 flex justify-between items-center text-[12px] font-black uppercase tracking-[0.2em] border-b border-gray-200/50">
      <div class="flex gap-10">
        <a href="#" class="hover:text-[#a68a56]">Categorías ▼</a>
        <a href="#" class="hover:text-[#a68a56]">Departamentos</a>
      </div>
      <div class="flex gap-10 items-center">
        <a href="#" class="hover:text-[#a68a56] lowercase font-medium tracking-normal">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-7 py-2.5 rounded-full shadow-lg">Login / Registrarse</a>
      </div>
    </nav>

    <header class="pt-16 pb-20 px-6 text-center">
      <div class="py-12">
        <img 
          src="/Logo-Fiestas-Guatemala.png" 
          alt="Fiestas Guatemala" 
          class="h-28 mx-auto object-contain mb-5"
          onerror="this.src='https://fiestasguatemala.com/wp-content/uploads/2023/06/Logo-Fiestas-Guatemala.png'"
        />
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.5em]">Aquí tú eres el alma de la fiesta</p>
      </div>

      <div class="max-w-4xl mx-auto bg-[#e8e4d9] p-2 rounded-full shadow-[0_30px_70px_rgba(0,0,0,0.1)] flex flex-col md:flex-row items-center">
        <div class="flex-[1.2] flex items-center px-8 w-full border-r border-gray-300/30">
          <span class="mr-3">🔍</span>
          <input type="text" placeholder="¿Qué buscas?" class="w-full bg-transparent py-4 outline-none text-sm font-medium" />
        </div>
        <div class="flex-1 flex items-center px-8 w-full">
          <span class="mr-3">📍</span>
          <select class="w-full bg-transparent py-4 outline-none text-sm font-medium appearance-none">
            <option>Guatemala (Departamento)</option>
          </select>
        </div>
        <button class="bg-[#a68a56] text-white font-black px-12 py-4 rounded-full text-xs uppercase tracking-widest m-1">
          Buscar
        </button>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-10 pb-40">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-14">
        {categorias.map((cat, i) => (
          <div class="bg-white rounded-[45px] overflow-hidden shadow-[0_15px_35px_rgba(0,0,0,0.03)] flex flex-col border border-gray-100">
            <div class="relative h-64 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover" />
              <div class="absolute top-6 right-6 bg-[#a68a56] w-10 h-10 rounded-full flex items-center justify-center text-white font-black text-xs border-2 border-white/20">
                {i + 1}
              </div>
            </div>
            <div class="p-10">
              <div class="flex items-center gap-6">
                <div class="w-16 h-16 bg-[#f2f3ed] rounded-[24px] flex items-center justify-center text-4xl shadow-inner">
                  {cat.icon}
                </div>
                <div class="flex-1">
                  <h3 class="font-black text-xl text-[#243447] mb-2">{cat.nombre}</h3>
                  <div class="flex items-center gap-2">
                    <span class="text-[#a68a56] text-xs">★★★★★</span>
                    <span class="text-gray-300 text-[11px] font-black">4.0</span>
                  </div>
                </div>
              </div>
              <div class="mt-9 pt-6 border-t border-gray-100 flex items-center gap-2">
                <span class="w-2 h-2 bg-green-500 rounded-full shadow-lg"></span>
                <span class="text-[9px] font-black uppercase tracking-widest text-gray-400">Verificado</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#3d4a5c] text-white pt-24 pb-12 px-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-16">
        <div class="space-y-8">
          <img src="https://fiestasguatemala.com/wp-content/uploads/2023/06/Logo-Fiestas-Guatemala.png" class="h-16 brightness-0 invert" />
          <p class="text-gray-300 text-sm leading-relaxed">Expertos en hacer de tu evento un momento inolvidable.</p>
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center font-bold">f</div>
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center font-bold">i</div>
          </div>
        </div>
        <div>
          <h4 class="font-black mb-8 text-[#a68a56] text-[10px] uppercase tracking-widest">Categorías</h4>
          <ul class="space-y-4 text-sm text-gray-300 font-bold">
            <li>Mariachis</li>
            <li>Fotógrafos</li>
            <li class="text-white underline decoration-[#a68a56] underline-offset-8">Ver todas</li>
          </ul>
        </div>
        <div>
          <h4 class="font-black mb-8 text-[#a68a56] text-[10px] uppercase tracking-widest">Servicios</h4>
          <ul class="space-y-4 text-sm text-gray-300 font-bold">
            <li>Sobre Nosotros</li>
            <li class="text-red-400">SOS / Emergencias</li>
          </ul>
        </div>
        <div>
          <h4 class="font-black mb-8 text-[#a68a56] text-[10px] uppercase tracking-widest">Zonas</h4>
          <ul class="space-y-4 text-sm text-gray-300 font-bold">
            <li>Guatemala</li>
            <li class="text-white underline decoration-[#a68a56] underline-offset-8">Ver todas</li>
          </ul>
        </div>
      </div>
    </footer>
  </div>
</Layout>