---
import Layout from '../layouts/Layout.astro';

const categorias = [
  { nombre: 'Fincas para Bodas', img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', icon: '🏡', slug: 'fincas-para-bodas' },
  { nombre: 'Salones de Eventos', img: 'https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800', icon: '🏛️', slug: 'salones-de-eventos' },
  { nombre: 'Catering / Banquetes', img: 'https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=800', icon: '🍽️', slug: 'catering-banquetes' },
  { nombre: 'Juegos Infantiles', img: 'https://images.unsplash.com/photo-1533411133346-656891104e46?q=80&w=800', icon: '🎈', slug: 'juegos-infantiles' },
  { nombre: 'Decoradores', img: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=800', icon: '🎨', slug: 'decoradores' },
  { nombre: 'Organizadores de Eventos', img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', icon: '📋', slug: 'organizadores-de-eventos' },
];
---

<Layout title="Fiestas Guatemala | Directorio Premium">
  <div class="bg-[#fcfaf4] min-h-screen font-sans text-[#243447]">
    
    <nav class="max-w-4xl mx-auto px-4 py-2 flex justify-between items-center text-[11px] font-bold uppercase tracking-widest text-[#8b7355]">
      <div class="flex gap-6 items-center flex-1">
        <a href="#" class="hover:text-[#a68a56]">Categorías ▾</a>
        <a href="#" class="hover:text-[#a68a56]">Departamentos</a>
      </div>
      
      <div class="flex flex-col items-center flex-1">
        <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-14 w-auto" />
        <h2 class="text-xl font-serif font-light text-[#243447] tracking-tight -mt-1 leading-none">FiestasGuatemala<span class="text-[#a68a56]">.com</span></h2>
        <p class="text-[7px] font-sans font-black text-gray-400 uppercase tracking-[0.4em] mt-1">Aquí tú eres el alma de la fiesta</p>
      </div>

      <div class="flex gap-6 items-center flex-1 justify-end">
        <a href="#" class="hover:text-[#a68a56]">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-4 py-1.5 rounded-full text-[9px] tracking-widest">Login / Registro</a>
      </div>
    </nav>

    <header class="pt-1 pb-6 px-4">
      <div class="max-w-4xl mx-auto bg-[#243447] rounded-full p-1 shadow-[0_15px_40px_-10px_rgba(36,52,71,0.4)] flex items-center border border-white/5">
        <div class="flex-[1.4] flex items-center px-6 border-r border-white/10">
          <span class="text-white text-base">🔍</span>
          <input type="text" placeholder="¿Qué buscas? (Categoría)" class="bg-transparent w-full text-white text-sm outline-none placeholder:text-white/30 py-2.5 px-3 font-light" />
        </div>
        <div class="flex-1 flex items-center px-6">
          <span class="text-white text-base">📍</span>
          <input type="text" placeholder="Guatemala" class="bg-transparent w-full text-white text-sm outline-none placeholder:text-white/30 py-2.5 px-3 font-light" />
        </div>
        <button class="bg-[#a68a56] text-white px-6 py-2.5 rounded-full text-[9px] font-black uppercase tracking-widest hover:bg-[#c5ab78] transition-all">
          Buscar Proveedores
        </button>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 pb-12">
      <div class="grid grid-cols-3 gap-6">
        {categorias.map((cat, i) => (
          <div class="group bg-white rounded-[30px] overflow-hidden shadow-[0_8px_25px_-10px_rgba(0,0,0,0.1)] border border-gray-100/50 hover:shadow-xl transition-all duration-500 cursor-pointer">
            <div class="h-40 overflow-hidden">
              <img src={cat.img} alt={cat.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            
            <div class="p-5 flex items-center gap-4">
              <div class="w-10 h-10 bg-[#fcfaf4] rounded-xl flex items-center justify-center text-xl border border-gray-50 flex-shrink-0">
                {cat.icon}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-serif font-light text-[#243447] leading-tight truncate">
                  <span class="text-[#a68a56] font-sans font-bold text-[10px] mr-1">{i + 1}.</span> {cat.nombre}
                </h3>
                <p class="text-[8px] font-bold uppercase tracking-[0.2em] text-[#a68a56]/70 mt-1">Sello de Verificado</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-12 pb-8 px-10 text-[11px]">
      <div class="max-w-4xl mx-auto grid grid-cols-4 gap-8">
        <div class="col-span-1 space-y-3 opacity-60 font-light">
          <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-6 brightness-0 invert" />
          <p>Boulevard Los Proceres 24-69 zona 10</p>
          <p class="font-bold text-[#a68a56]">2302-2201</p>
        </div>
        <div>
          <h4 class="text-[#a68a56] uppercase text-[8px] font-black tracking-widest mb-4">Categorías</h4>
          <ul class="space-y-2 opacity-50">
            <li>Mariachis</li>
            <li>Salones</li>
          </ul>
        </div>
        <div>
          <h4 class="text-[#a68a56] uppercase text-[8px] font-black tracking-widest mb-4">Soporte</h4>
          <ul class="space-y-2 opacity-50">
            <li>Sobre Nosotros</li>
            <li class="text-red-400">SOS</li>
          </ul>
        </div>
        <div class="flex flex-col items-end gap-3">
           <div class="flex gap-3">
             <div class="w-7 h-7 rounded-full border border-white/10 flex items-center justify-center">f</div>
             <div class="w-7 h-7 rounded-full border border-white/10 flex items-center justify-center">i</div>
           </div>
           <p class="text-[8px] opacity-30 font-bold uppercase tracking-tighter">© 2026 FiestasGuatemala.com</p>
        </div>
      </div>
    </footer>
  </div>
</Layout>