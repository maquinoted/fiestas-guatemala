---
import Layout from '../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

// 1. Traemos las categorías reales de tu base de datos Neon
// Usamos un TRY/CATCH por si la conexión falla, que el sitio no se caiga
let categorias = [];
try {
  const { rows } = await sql`SELECT * FROM categorias ORDER BY orden ASC`;
  categorias = rows;
} catch (e) {
  console.error("Error al conectar con la base de datos:", e);
}

// Imagenes de respaldo (mientras agregamos el campo imagen a la DB)
const imagenesRespaldo = {
  fincas: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3',
  salones: 'https://images.unsplash.com/photo-1519741497674-611481863552',
  catering: 'https://images.unsplash.com/photo-1555244162-803834f70033',
  mariachis: 'https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3'
};
---

<Layout title="FiestasGuatemala.com | El alma de la fiesta">
	<main class="max-w-7xl mx-auto px-4">
		
		<section class="py-16">
			<div class="max-w-4xl mx-auto">
				<div class="bg-[#1e293b] rounded-full p-2 flex flex-col md:flex-row items-center shadow-2xl border border-slate-700">
					<div class="flex-1 flex items-center px-6 py-3 border-r border-slate-700 w-full">
						<span class="mr-3 text-slate-400">🔍</span>
						<input type="text" placeholder="¿Qué buscas? (Categoría)" class="bg-transparent text-white w-full outline-none placeholder:text-slate-500">
					</div>
					<div class="flex-1 flex items-center px-6 py-3 w-full">
						<span class="mr-3 text-slate-400">📍</span>
						<input type="text" placeholder="Guatemala (Departamento)" class="bg-transparent text-white w-full outline-none placeholder:text-slate-500">
					</div>
					<button class="bg-[#a38a5e] text-white px-10 py-4 rounded-full font-bold hover:bg-[#8e7852] transition-colors whitespace-nowrap uppercase tracking-tighter text-sm">
						Buscar Proveedores
					</button>
				</div>
			</div>
		</section>

		<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 pb-20">
			{categorias.length > 0 ? (
				categorias.map((cat) => (
					<a href={`/categoria/${cat.slug}`} class="group">
						<div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
							<div class="aspect-[4/3] overflow-hidden bg-slate-100">
								<img 
									src={imagenesRespaldo[cat.slug] || 'https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3'} 
									alt={cat.nombre} 
									class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
								/>
							</div>
							<div class="p-4 flex items-center gap-3">
								<span class="text-2xl opacity-60 group-hover:opacity-100">{cat.icono}</span>
								<h3 class="font-bold text-slate-800 group-hover:text-blue-900 transition-colors uppercase tracking-tight text-sm">
									{cat.nombre}
								</h3>
							</div>
						</div>
					</a>
				))
			) : (
				<div class="col-span-full text-center py-20 text-slate-400">
					Cargando categorías...
				</div>
			)}
		</section>

	</main>
</Layout>