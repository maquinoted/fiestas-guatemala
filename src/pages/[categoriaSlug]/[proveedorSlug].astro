---
// src/pages/[categoriaSlug]/[proveedorSlug].astro
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

// 1. CONSULTA A LA BASE DE DATOS
const { rows } = await sql`
  SELECT *, NOW() as db_time FROM proveedores WHERE slug = ${proveedorSlug} AND activo = true LIMIT 1
`;
const p = rows[0];

if (!p) return Astro.redirect('/404');

// 2. UTILIDADES Y FRESHNESS
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const categoriaLimpia = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const categoriaCapitalizada = capitalize(categoriaLimpia);
const nombreMunicipio = p.municipio || p.departamento;

const fecha = new Date();
const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
const fechaActualizacion = `${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;

// 3. SEO (H1 debe ser igual al Title)
const tituloSEO = `${p.nombre} en ${nombreMunicipio} | Cotización y Precios | FiestasGuatemala.com`;
const descriptionSEO = `Contrata a ${p.nombre} en ${nombreMunicipio}. Especialista en ${categoriaLimpia}. Precios actualizados a ${fechaActualizacion}. ¡Contacta directo por WhatsApp!`;

// 4. URL Y FOTO DE DB (Específica para Mariachis)
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;

// Lógica de imagen: Prioridad a la DB, si es mariachi usa la que ya tenemos
const fotoFinal = p.imagen_url || (categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : '/placeholder.jpg');

// 5. SCHEMAS
const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": p.nombre,
  "image": fotoFinal,
  "telephone": `+502${p.telefono}`,
  "priceRange": `Q${p.precio_desde}+`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": p.municipio,
    "addressRegion": p.departamento,
    "addressCountry": "GT"
  }
};

const whatsappLink = `https://wa.me/502${p.telefono}?text=${encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com...`)}`;
---

<Layout title={tituloSEO} description={descriptionSEO}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:image" content={fotoFinal} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />

    <main class="max-w-5xl mx-auto pt-8 pb-20 px-6">
      
      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-serif text-[#243447] leading-tight mb-4">
          {p.nombre} <span class="text-[#a68a56]">en {nombreMunicipio}</span>
        </h1>

        <div class="flex items-center gap-2 text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold mb-4">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Actualizado: {fechaActualizacion}
        </div>

        <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#8b7355] font-bold border-b border-[#8b7355]/10 pb-6">
          <a href="/" class="hover:text-[#243447] no-underline">Inicio</a>
          <span class="opacity-30">/</span>
          <a href={`/${categoriaSlug}`} class="hover:text-[#243447] no-underline">{categoriaCapitalizada}</a>
          <span class="opacity-30">/</span>
          <span class="text-[#a68a56] font-black">{p.nombre}</span>
        </nav>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <div class="lg:col-span-5">
          <div class="rounded-[30px] overflow-hidden shadow-2xl border-4 border-white aspect-square lg:aspect-auto lg:h-[450px]">
            <img src={fotoFinal} class="w-full h-full object-cover" alt={p.nombre} />
          </div>
        </div>

        <div class="lg:col-span-7 space-y-6">
          <div class="bg-white p-8 rounded-[35px] shadow-sm border border-white">
            <div class="inline-flex items-center gap-2 bg-[#243447] text-white text-[9px] font-black px-4 py-2 rounded-full uppercase tracking-widest mb-6">
              ★ Proveedor Verificado
            </div>

            <div class="flex justify-between items-end mb-8">
              <div>
                <p class="text-[10px] uppercase tracking-widest text-[#8b7355] font-bold mb-1">Precio Base</p>
                <p class="text-4xl font-serif text-[#a68a56]">Q{p.precio_desde}</p>
              </div>
              <div class="text-right text-[10px] text-gray-400 font-bold uppercase tracking-widest leading-tight">
                📍 {p.municipio}<br/>{p.departamento}
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <a href={whatsappLink} class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-4 rounded-2xl font-bold text-[11px] uppercase tracking-widest hover:scale-105 transition-all no-underline">
                <span class="text-xl">💬</span> WhatsApp
              </a>
              <a href={`tel:+502${p.telefono}`} class="bg-[#243447] text-white flex items-center justify-center gap-3 py-4 rounded-2xl font-bold text-[11px] uppercase tracking-widest hover:bg-black transition-all no-underline">
                <span class="text-xl">📞</span> Llamar
              </a>
            </div>
          </div>

          <div class="bg-[#fcfaf3] p-8 rounded-[35px] border-l-8 border-[#a68a56]">
             <p class="text-[#243447]/80 leading-relaxed italic font-light">
               "{p.description || p.descripcion}"
             </p>
          </div>
        </div>
      </div>

      <div class="mt-16 border-t border-[#8b7355]/10 pt-10 text-center">
        <a href={`/${categoriaSlug}`} class="text-[#8b7355] font-black uppercase text-[10px] tracking-[0.2em] no-underline hover:text-[#243447] transition-colors">
          ← Ver más {categoriaCapitalizada} en Guatemala
        </a>
      </div>

    </main>
    <Footer />
  </div>
</Layout>