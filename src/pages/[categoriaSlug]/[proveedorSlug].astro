---
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { proveedorSlug } = Astro.params;

const { rows } = await sql`
  SELECT * FROM proveedores WHERE slug = ${proveedorSlug} LIMIT 1
`;
const p = rows[0];

// Función para limpiar el número de teléfono y crear el link de WhatsApp
// Asumimos que el teléfono viene como '55551234'
const mensajeWA = encodeURIComponent(`Hola ${p?.nombre}, vi tu perfil en FiestasGuatemala.com y me gustaría solicitar una cotización. 👋`);
const whatsappLink = `https://wa.me/502${p?.telefono}?text=${mensajeWA}`;
---

<Layout title={p ? `${p.nombre} | Fiestas Guatemala` : 'Proveedor'}>
  {p ? (
    <main class="max-w-4xl mx-auto px-4 py-12">
      <div class="bg-white rounded-[40px] overflow-hidden shadow-2xl border border-slate-100">
        <img src={p.imagen_url} class="w-full h-96 object-cover" />
        
        <div class="p-10">
          <div class="flex justify-between items-start mb-6">
            <div>
              <span class="bg-[#fef3c7] text-[#d97706] px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-2 inline-block">
                {p.categoria_slug} Premium
              </span>
              <h1 class="text-5xl font-black text-slate-800">{p.nombre}</h1>
            </div>
            <div class="text-right">
              <p class="text-sm text-slate-400 uppercase font-bold">Desde</p>
              <p class="text-4xl font-black text-[#d97706]">Q{p.precio_desde}</p>
            </div>
          </div>

          <p class="text-xl text-slate-600 leading-relaxed mb-10">
            {p.descripcion}
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <a href={whatsappLink} target="_blank" class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-5 rounded-2xl font-bold text-xl hover:bg-[#20ba5a] transition-all transform hover:scale-[1.02] shadow-lg shadow-green-200">
              <span>💬</span> Contactar por WhatsApp
            </a>
            
            <a href={`tel:+502${p.telefono}`} class="bg-[#1e293b] text-white flex items-center justify-center gap-3 py-5 rounded-2xl font-bold text-xl hover:bg-slate-800 transition-all">
              <span>📞</span> Llamar al {p.telefono}
            </a>
          </div>
        </div>
      </div>
    </main>
  ) : (
    <div class="text-center py-20">
      <h1 class="text-2xl font-bold text-slate-400">Proveedor no encontrado</h1>
      <a href="/" class="text-[#a38a5e] underline mt-4 block">Volver al inicio</a>
    </div>
  )}
</Layout>