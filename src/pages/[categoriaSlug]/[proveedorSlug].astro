---
// MARCA_DE_EXITO: VERSION_FINAL_825PM
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} AND p.activo = true LIMIT 1
  `;
  p = rows[0];
  if (p) {
    const { rows: vRows } = await sql`SELECT nombre, slug, imagen_url, precio_desde FROM proveedores WHERE categoria_slug = ${categoriaSlug} AND municipio = ${p.municipio} AND slug != ${p.slug} AND activo = true LIMIT 3`;
    vecinos = vRows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

const dbEmoji = p.categoria_emoji || '✨';
const nombreMunicipio = p.municipio || p.departamento;

// 🔥 Título: Emoji después del nombre
const tituloSEO = `${p.nombre} ${dbEmoji} en ${nombreMunicipio} | Q${p.precio_desde}`;

// 🔥 4 SCHEMAS RECONSTRUIDOS
const schemaMarkup = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": p.nombre,
    "image": p.imagen_url,
    "telephone": p.telefono,
    "priceRange": `Q${p.precio_desde}+`,
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142" },
    "address": { "@type": "PostalAddress", "addressLocality": p.municipio, "addressRegion": p.departamento, "addressCountry": "GT" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": `¿Cuánto cobra ${p.nombre}?`,
      "acceptedAnswer": { "@type": "Answer", "text": `En ${p.municipio}, los servicios de ${p.nombre} inician desde Q${p.precio_desde}.` }
    }]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://fiestasguatemala.com" },
      { "@type": "ListItem", "position": 2, "name": p.categoria_nombre, "item": `https://fiestasguatemala.com/${categoriaSlug}` },
      { "@type": "ListItem", "position": 3, "name": p.nombre, "item": `https://fiestasguatemala.com/${categoriaSlug}/${p.slug}` }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Fiestas Guatemala",
    "url": "https://fiestasguatemala.com"
  }
];

const whatsappLink = `https://wa.me/502${p.whatsapp || p.telefono}?text=Hola...`;
---

<Layout title={tituloSEO} description={`Perfil verificado de ${p.nombre} en ${p.municipio}.`}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-5xl mx-auto pt-4 pb-20 px-4">
      
      <header class="mb-4 border-b pb-3">
        <h1 class="text-xl md:text-2xl font-serif font-bold truncate">
          {p.nombre} en {p.municipio}, {p.departamento}
        </h1>
        <nav class="flex items-center gap-2 text-[9px] uppercase font-bold text-[#8b7355] my-1">
          <a href="/">Inicio</a> <span>/</span>
          <a href={`/${categoriaSlug}`}>{p.categoria_nombre}</a> <span>/</span>
          <span class="text-[#a68a56]">{p.nombre}</span>
        </nav>
        <div class="text-[8px] uppercase font-black opacity-40">Actualizado Marzo 2026</div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
        
        <div class="md:col-span-4 lg:col-span-3">
          <div class="rounded-3xl overflow-hidden shadow-lg border-4 border-white aspect-square md:aspect-auto md:h-64">
            <img src={p.imagen_url} class="w-full h-full object-cover" alt={p.nombre} fetchpriority="high" />
          </div>
          <div class="mt-3 flex flex-col gap-2">
            <a href={whatsappLink} class="bg-[#25D366] text-white text-center py-2.5 rounded-xl font-bold text-[10px] uppercase shadow-md">WhatsApp Directo 💬</a>
            <a href={`tel:+502${p.telefono}`} class="bg-[#243447] text-white text-center py-2.5 rounded-xl font-bold text-[10px] uppercase shadow-md">Llamar Ahora 📞</a>
          </div>
        </div>

        <div class="md:col-span-8 lg:col-span-9">
          <div class="bg-white p-6 rounded-[35px] shadow-sm border border-white">
            <p class="text-[10px] font-black uppercase text-[#243447] mb-3 flex items-center gap-1">📍 {p.municipio}, {p.departamento}</p>
            
            <div class="bg-[#243447] text-white text-[8px] font-black px-3 py-1.5 rounded-full inline-block mb-4 uppercase tracking-widest">
              ★ Perfil Verificado
            </div>

            <p class="text-lg md:text-xl italic font-serif text-gray-700 leading-relaxed">
              "{p.descripcion}"
            </p>

            <div class="mt-6 pt-5 border-t flex justify-between items-end">
              <div>
                <p class="text-[9px] font-black text-gray-400 uppercase">Precio desde</p>
                <p class="text-4xl md:text-5xl font-serif text-[#a68a56] font-bold">Q{p.precio_desde}</p>
              </div>
              <div class="text-2xl opacity-40">{dbEmoji}</div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>