---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

// 1. DATOS DE DB
const { rows } = await sql`
  SELECT *, NOW() as db_time FROM proveedores WHERE slug = ${proveedorSlug} AND activo = true LIMIT 1
`;
const p = rows[0];

if (!p) return Astro.redirect('/404');

// 2. UTILIDADES
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const categoriaLimpia = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const categoriaCapitalizada = capitalize(categoriaLimpia);
const nombreMunicipio = p.municipio || p.departamento;

const fecha = new Date();
const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
const fechaActualizacion = `${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;

// 3. SEO Y META DESCRIPTION (ALTO CTR + EMOJI)
const emoji = categoriaSlug === 'mariachis' ? '🎺' : '✨';
const tituloSEO = `${p.nombre} en ${nombreMunicipio} | Cotiza Hoy | FiestasGuatemala.com`;
const descriptionSEO = `${emoji} ¡Contrata a los mejores! ${p.nombre} en ${nombreMunicipio}. Especialistas en ${categoriaLimpia} con precios desde Q${p.precio_desde}. ¡Reserva ahora tu fecha para este ${fecha.getFullYear()}! ✅ Verificados y Recomendados.`;

// 4. IMAGEN DE LA DB (FALLBACK ESPECÍFICO)
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
// Aquí forzamos la lectura de la imagen_url de la base de datos
const fotoFinal = p.imagen_url || (categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : '/placeholder.jpg');

// 5. SCHEMAS (LOS 3 ELEMENTOS: PRODUCT/RATING, FAQ Y BREADCRUMB)
const schemaMarkup = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": p.nombre,
    "image": fotoFinal,
    "description": descriptionSEO,
    "brand": { "@type": "Brand", "name": "FiestasGuatemala.com" },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "85"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `¿Cómo contratar a ${p.nombre}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Puedes contactarlos directamente a través del botón de WhatsApp o llamada telefónica para solicitar tu cotización sin compromiso.`
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteBase },
      { "@type": "ListItem", "position": 2, "name": categoriaCapitalizada, "item": `${siteBase}/${categoriaSlug}` },
      { "@type": "ListItem", "position": 3, "name": p.nombre, "item": canonicalURL }
    ]
  }
];

const whatsappLink = `https://wa.me/502${p.telefono}?text=${encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com y me gustaría cotizar sus servicios...`)}`;
---

<Layout title={tituloSEO} description={descriptionSEO}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:image" content={fotoFinal} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />

    <main class="max-w-5xl mx-auto pt-6 pb-20 px-6">
      
      <header class="mb-6">
        <h1 class="text-3xl md:text-5xl font-serif text-[#243447] leading-none mb-3">
          {p.nombre} <span class="text-[#a68a56]">en {nombreMunicipio}</span>
        </h1>

        <div class="flex items-center justify-between border-b border-[#8b7355]/10 pb-4">
          <div class="flex items-center gap-2 text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            Perfil Actualizado: {fechaActualizacion}
          </div>
          <nav class="hidden md:flex items-center gap-2 text-[10px] uppercase tracking-[0.1em] text-[#8b7355] font-bold">
            <a href="/" class="no-underline">Inicio</a> / 
            <a href={`/${categoriaSlug}`} class="no-underline">{categoriaCapitalizada}</a>
          </nav>
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        
        <div class="lg:col-span-4">
          <div class="rounded-[30px] overflow-hidden shadow-xl border-4 border-white h-[300px] lg:h-[350px]">
            <img src={fotoFinal} class="w-full h-full object-cover" alt={p.nombre} />
          </div>
        </div>

        <div class="lg:col-span-8 space-y-4">
          <div class="bg-white p-6 md:p-8 rounded-[35px] shadow-sm border border-white">
            <div class="flex flex-wrap justify-between items-start gap-4 mb-6">
              <div>
                <div class="inline-flex items-center gap-2 bg-[#243447] text-white text-[8px] font-black px-3 py-1.5 rounded-full uppercase tracking-tighter mb-3">
                  ★ Proveedor Verificado
                </div>
                <p class="text-[9px] uppercase tracking-widest text-[#8b7355] font-black mb-1">Inversión desde</p>
                <p class="text-4xl font-serif text-[#a68a56] leading-none">Q{p.precio_desde}</p>
              </div>
              <div class="text-right">
                <span class="text-xs">📍</span>
                <p class="text-[10px] font-black uppercase text-[#243447]">{p.municipio}</p>
                <p class="text-[9px] text-[#8b7355] uppercase font-bold tracking-widest">{p.departamento}, GT</p>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <a href={whatsappLink} class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-4 rounded-2xl font-black text-[11px] uppercase tracking-widest hover:scale-[1.02] active:scale-95 transition-all no-underline shadow-lg shadow-green-100">
                <span class="text-xl">💬</span> Contactar WhatsApp
              </a>
              <a href={`tel:+502${p.telefono}`} class="bg-[#243447] text-white flex items-center justify-center gap-3 py-4 rounded-2xl font-black text-[11px] uppercase tracking-widest hover:bg-black active:scale-95 transition-all no-underline shadow-lg">
                <span class="text-xl">📞</span> Llamar Ahora
              </a>
            </div>
          </div>

          <div class="bg-[#fcfaf3] p-6 md:p-8 rounded-[35px] border-l-[6px] border-[#a68a56]">
             <h3 class="text-[10px] uppercase font-black tracking-[0.2em] text-[#8b7355] mb-3">Sobre el servicio:</h3>
             <p class="text-[15px] md:text-[17px] text-[#243447] leading-relaxed italic font-light">
               "{p.descripcion || `Especialistas con amplia trayectoria en ${categoriaLimpia}, comprometidos con la excelencia y la puntualidad para que tu evento en ${nombreMunicipio} sea inolvidable.`}"
             </p>
          </div>
        </div>
      </div>

      <div class="mt-10 text-center">
        <a href={`/${p.categoria_slug}`} class="text-[#8b7355] font-black uppercase text-[10px] tracking-[0.2em] no-underline hover:text-[#243447] transition-all group">
          ← Ver más {categoriaCapitalizada} en Guatemala
        </a>
      </div>

    </main>
    <Footer />
  </div>
</Layout>