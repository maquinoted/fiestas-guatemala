---
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { proveedorSlug } = Astro.params;

const { rows } = await sql`
  SELECT * FROM proveedores WHERE slug = ${proveedorSlug} LIMIT 1
`;
const p = rows[0];

// Link de WhatsApp con mensaje personalizado
const mensajeWA = encodeURIComponent(`Hola ${p?.nombre}, vi tu perfil en FiestasGuatemala.com y me gustaría solicitar una cotización para un evento en ${p?.departamento}. 👋`);
const whatsappLink = `https://wa.me/502${p?.telefono}?text=${mensajeWA}`;
---

<Layout title={p ? `${p.nombre} | Fiestas Guatemala` : 'Proveedor'}>
  {p ? (
    <main class="bg-[#F5F3E7] min-h-screen py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <a href={`/${p.categoria_slug}`} class="inline-flex items-center gap-2 text-[#243447] font-bold mb-8 hover:opacity-70 transition-opacity uppercase text-xs tracking-widest">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
          Volver a {p.categoria_slug}
        </a>

        <div class="bg-white rounded-[45px] overflow-hidden shadow-2xl border border-white">
          <div class="h-[400px] relative">
            <img src={p.imagen_url} class="w-full h-full object-cover" alt={p.nombre} />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            
            <div class="absolute bottom-8 left-10 flex items-center gap-2 bg-[#AD946D] text-white px-5 py-2 rounded-full font-bold text-sm shadow-lg">
              <span>📍</span> {p.departamento}
            </div>
          </div>
          
          <div class="p-10 md:p-14">
            <div class="flex flex-col md:flex-row justify-between items-start gap-6 mb-10">
              <div>
                <span class="text-[#AD946D] text-xs font-black uppercase tracking-[0.2em] mb-3 block">Proveedor Verificado</span>
                <h1 class="text-5xl font-black text-[#243447] tracking-tight">{p.nombre}</h1>
              </div>
              <div class="bg-[#F5F3E7] p-6 rounded-[30px] text-center min-w-[180px]">
                <p class="text-[10px] text-gray-400 font-bold uppercase mb-1">Precio sugerido</p>
                <p class="text-3xl font-black text-[#AD946D]">Q{p.precio_desde}</p>
              </div>
            </div>

            <div class="prose prose-slate max-w-none mb-12">
              <p class="text-xl text-gray-600 leading-relaxed font-medium">
                {p.descripcion}
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <a href={whatsappLink} target="_blank" class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-5 rounded-[20px] font-bold text-lg hover:scale-[1.02] transition-all shadow-xl shadow-green-100">
                <span class="text-2xl">💬</span> WhatsApp Directo
              </a>
              
              <a href={`tel:+502${p.telefono}`} class="bg-[#243447] text-white flex items-center justify-center gap-3 py-5 rounded-[20px] font-bold text-lg hover:bg-black transition-all shadow-xl shadow-slate-200">
                <span class="text-2xl">📞</span> Llamar al {p.telefono}
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
  ) : (
    <div class="min-h-screen flex items-center justify-center bg-[#F5F3E7]">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-gray-400">Proveedor no encontrado</h1>
        <a href="/" class="text-[#AD946D] font-bold underline mt-4 block">Volver al inicio</a>
      </div>
    </div>
  )}
</Layout>