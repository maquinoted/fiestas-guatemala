---
// Todo el bloque Astro (Selects, Canonical, Schemas, WhatsAppLink) se mantiene EXACTAMENTE IGUAL.
// Solo modificamos el HTML del main.
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} AND p.activo = true LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const { rows: vRows } = await sql`
      SELECT nombre, slug, imagen_url, precio_desde FROM proveedores WHERE categoria_slug = ${categoriaSlug} AND municipio = ${p.municipio} AND slug != ${p.slug} AND activo = true LIMIT 3
    `;
    vecinos = vRows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const dbEmoji = p.categoria_emoji || '✨';
const h1Texto = `${p.nombre} en ${p.municipio}, ${p.departamento}`;
const ogDescription = `✅ Perfil Oficial Verificado: Contrata a ${p.nombre} en ${p.municipio}. Servicios de ${p.categoria_nombre} desde Q${p.precio_desde}. ¡Reserva hoy mismo!`;

const schemaMarkup = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "name": p.nombre, "image": p.imagen_url, "telephone": p.telefono, "priceRange": `Q${p.precio_desde}+`, "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142" }, "address": { "@type": "PostalAddress", "addressLocality": p.municipio, "addressRegion": p.departamento, "addressCountry": "GT" } },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{ "@type": "Question", "name": `¿Cuánto cobra ${p.nombre}?`, "acceptedAnswer": { "@type": "Answer", "text": `En ${p.municipio}, los servicios de ${p.nombre} inician desde Q${p.precio_desde}.` } }] },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteBase }, { "@type": "ListItem", "position": 2, "name": p.categoria_nombre, "item": `${siteBase}/${categoriaSlug}` }, { "@type": "ListItem", "position": 3, "name": p.nombre, "item": canonicalURL }] },
  { "@context": "https://schema.org", "@type": "WebSite", "name": "Fiestas Guatemala", "url": siteBase },
  { "@context": "https://schema.org", "@type": "Organization", "name": "Fiestas Guatemala", "logo": `${siteBase}/logo.png`, "url": siteBase }
];
---

<Layout title={`${h1Texto} ${dbEmoji}`} description={ogDescription}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#F8F7F4] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-6xl mx-auto pt-8 pb-20 px-6">
      
      <header class="mb-12 border-b border-[#AD946D]/20 pb-10">
        <h1 class="text-4xl md:text-7xl font-serif italic text-[#243447] tracking-tighterLEADING-none mb-6">
          {p.nombre}
        </h1>
        
        <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#AD946D] font-black">
          <a href="/" class="hover:text-[#243447]">Inicio</a> 
          <span class="opacity-30">/</span> 
          <a href={`/${categoriaSlug}`} class="hover:text-[#243447]">{p.categoria_nombre}</a> 
          <span class="opacity-30">/</span> 
          <span class="text-[#243447] font-black">{p.nombre}</span>
        </nav>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-stretch bg-white rounded-[60px] shadow-[0_35px_100px_-15px_rgba(36,52,71,0.08)] p-4 border border-gray-100 mb-20">
        
        <div class="md:col-span-5 relative group">
          <div class="absolute -inset-1 bg-[#AD946D]/10 rounded-[50px] blur-2xl group-hover:bg-[#AD946D]/20 transition-all duration-1000"></div>
          <img 
            src={p.imagen_url} 
            class="relative w-full h-full object-cover rounded-[50px] shadow-2xl aspect-[4/5] md:aspect-auto md:h-full border border-gray-100" 
            alt={p.nombre} 
            fetchpriority="high"
          />
          <div class="absolute top-8 left-8 bg-[#AD946D]/80 backdrop-blur-sm text-white px-4 py-2 rounded-full font-black text-[9px] uppercase tracking-[0.2em]">
             {p.categoria_nombre}
          </div>
        </div>

        <div class="md:col-span-7 space-y-12 p-6 md:p-12 flex flex-col justify-center">
          
          <div class="space-y-3">
             <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-full border border-[#AD946D]/50 flex items-center justify-center text-[#AD946D] font-black text-2xl">★</div>
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-[#AD946D]">Perfil Verificado<br/>Oficialmente</p>
             </div>
          </div>

          <div class="relative">
            <span class="text-7xl font-serif text-[#AD946D]/20 absolute -top-10 -left-6">“</span>
            <p class="text-2xl md:text-4xl font-serif leading-snug text-[#243447] italic border-l-4 border-[#AD946D]/30 pl-8 relative z-10">
              {p.descripcion || `Brindando excelencia en cada detalle para tus eventos en ${p.municipio}.`}
            </p>
          </div>

          <div class="pt-8 border-t border-gray-100 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
            <div>
               <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-2">Presupuesto inicial desde</p>
               <p class="text-5xl md:text-7xl font-serif text-[#243447] tracking-tighter leading-none">Q{p.precio_desde}</p>
            </div>
            
            <div class="border-t md:border-t-0 md:border-l border-gray-100 pt-6 md:pt-0 md:pl-8 space-y-2">
               <p class="text-[10px] font-black uppercase tracking-widest text-[#AD946D]">Ubicación</p>
               <p class="text-lg font-serif italic text-gray-600 leading-tight">📍 {p.municipio},<br/>{p.departamento}</p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-gray-100 mt-auto">
            <a href={`https://wa.me/502${p.whatsapp || p.telefono}?text=Hola...`} id="btn-wa" class="bg-[#25D366] text-white py-6 rounded-2xl text-center font-black text-[11px] uppercase tracking-widest shadow-xl hover:translate-y-[-2px] transition-all">
              WhatsApp Directo
            </a>
            <a href={`tel:+502${p.telefono}`} id="btn-call" class="border-2 border-[#243447] text-[#243447] py-6 rounded-2xl text-center font-black text-[11px] uppercase tracking-widest hover:bg-[#243447] hover:text-white transition-all">
              Llamar Ahora
              📞
            </a>
          </div>

        </div>
      </div>

    </main>
    <Footer />
  </div>
</Layout>

<script define:vars={{ pId: p.id }}>
  const track = (tipo) => {
    fetch('/api/click', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ proveedorId: pId, tipo }), keepalive: true }).catch(() => {});
  };
  document.getElementById('btn-wa')?.addEventListener('click', () => track('whatsapp'));
  document.getElementById('btn-call')?.addEventListener('click', () => track('llamada'));
  track('vista');
</script>