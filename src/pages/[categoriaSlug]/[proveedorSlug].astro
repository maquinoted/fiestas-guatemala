---
// Lógica de base de datos, Schemas y SEO intactos.
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} AND p.activo = true LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const { rows: vRows } = await sql`
      SELECT nombre, slug, imagen_url, precio_desde FROM proveedores 
      WHERE categoria_slug = ${categoriaSlug} AND municipio = ${p.municipio} 
      AND slug != ${p.slug} AND activo = true LIMIT 3
    `;
    vecinos = vRows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const dbEmoji = p.categoria_emoji || '✨';
const h1Texto = `${p.nombre} en ${p.municipio}, ${p.departamento}`;
const ogDescription = `✅ Perfil Verificado: Contrata a ${p.nombre} en ${p.municipio}. Servicios de ${p.categoria_nombre} desde Q${p.precio_desde}. ¡Reserva hoy mismo!`;

const schemaMarkup = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "name": p.nombre, "image": p.imagen_url, "telephone": p.telefono, "priceRange": `Q${p.precio_desde}+`, "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142" }, "address": { "@type": "PostalAddress", "addressLocality": p.municipio, "addressRegion": p.departamento, "addressCountry": "GT" } },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{ "@type": "Question", "name": `¿Cuánto cobra ${p.nombre}?`, "acceptedAnswer": { "@type": "Answer", "text": `En ${p.municipio}, los servicios de ${p.nombre} inician desde Q${p.precio_desde}.` } }] },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteBase }, { "@type": "ListItem", "position": 2, "name": p.categoria_nombre, "item": `${siteBase}/${categoriaSlug}` }, { "@type": "ListItem", "position": 3, "name": p.nombre, "item": canonicalURL }] },
  { "@context": "https://schema.org", "@type": "WebSite", "name": "Fiestas Guatemala", "url": siteBase },
  { "@context": "https://schema.org", "@type": "Organization", "name": "Fiestas Guatemala", "logo": `${siteBase}/logo.png`, "url": siteBase }
];
---

<Layout title={`${h1Texto} ${dbEmoji}`} description={ogDescription}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#F8F7F4] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-5xl mx-auto pt-8 pb-20 px-4 md:px-6">
      
      <header class="mb-10">
        <h1 class="text-2xl md:text-4xl font-serif italic text-[#243447] tracking-tight leading-tight">
          {h1Texto}
        </h1>
        <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#AD946D] font-black mt-2">
          <a href="/" class="hover:text-[#243447]">Inicio</a> <span>/</span> 
          <a href={`/${categoriaSlug}`}>{p.categoria_nombre}</a> <span>/</span> 
          <span class="text-[#243447]">{p.nombre}</span>
        </nav>
      </header>

      <div class="bg-white rounded-[50px] shadow-[0_30px_90px_-20px_rgba(0,0,0,0.1)] overflow-hidden border border-white">
        <div class="grid grid-cols-1 md:grid-cols-2">
          
          <div class="relative aspect-square md:aspect-auto">
            <img src={p.imagen_url} class="w-full h-full object-cover" alt={p.nombre} fetchpriority="high" />
            <div class="absolute top-6 left-6 bg-white/95 backdrop-blur-sm px-4 py-2 rounded-full shadow-lg">
              <p class="text-[9px] font-black uppercase tracking-widest text-[#243447]">★ Perfil Verificado</p>
            </div>
          </div>

          <div class="p-10 md:p-14 flex flex-col justify-center">
            <div class="mb-8">
              <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#AD946D] mb-4">
                📍 {p.municipio}, {p.departamento}
              </p>
              <p class="text-2xl md:text-3xl font-serif italic leading-relaxed text-[#243447]">
                "{p.descripcion}"
              </p>
            </div>
            
            <div class="pt-8 border-t border-gray-100 mb-10">
              <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-2">Precio inicial</p>
              <div class="flex items-baseline gap-2">
                <p class="text-5xl md:text-6xl font-serif font-bold text-[#243447]">Q{p.precio_desde}</p>
                <span class="text-2xl opacity-20">{dbEmoji}</span>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-3">
              <a href={`https://wa.me/502${p.whatsapp || p.telefono}?text=Hola...`} id="btn-wa" class="bg-[#25D366] text-white py-5 rounded-2xl text-center font-black text-[11px] uppercase tracking-widest shadow-xl hover:translate-y-[-1px] transition-all">
                WhatsApp Directo
              </a>
              <a href={`tel:+502${p.telefono}`} id="btn-call" class="bg-[#243447] text-white py-5 rounded-2xl text-center font-black text-[11px] uppercase tracking-widest hover:bg-[#1a2633] transition-all">
                Llamar Ahora
              </a>
            </div>
          </div>

        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script define:vars={{ pId: p.id }}>
  const track = (tipo) => {
    fetch('/api/click', { 
      method: 'POST', 
      headers: { 'Content-Type': 'application/json' }, 
      body: JSON.stringify({ proveedorId: pId, tipo }), 
      keepalive: true 
    }).catch(() => {});
  };
  document.getElementById('btn-wa')?.addEventListener('click', () => track('whatsapp'));
  document.getElementById('btn-call')?.addEventListener('click', () => track('llamada'));
  track('vista');
</script>