---
// 1. SSR ABSOLUTO
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

// 2. CONSULTA A LA BASE DE DATOS
const { rows } = await sql`
  SELECT *, NOW() as db_time FROM proveedores WHERE slug = ${proveedorSlug} AND activo = true LIMIT 1
`;
const p = rows[0];

if (!p) return Astro.redirect('/404');

// 3. UTILIDADES Y FECHA (Factor Freshness)
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const categoriaLimpia = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const categoriaCapitalizada = capitalize(categoriaLimpia);
const nombreMunicipio = p.municipio || p.departamento;

const fecha = new Date();
const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
const fechaActualizacion = `${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;

// 4. SEO LOCAL DINÁMICO (Jerarquía H1 = Title)
const tituloSEO = `${p.nombre} en ${nombreMunicipio} | Cotización y Precios | FiestasGuatemala.com`;
const descriptionSEO = `¿Necesitas contratar a ${p.nombre} en ${nombreMunicipio}? Especialista en ${categoriaLimpia} para eventos. Consulta precios actualizados a ${fechaActualizacion}, mira sus fotos reales y solicita tu cotización directa vía WhatsApp. ¡Proveedor Verificado!`;

// 5. URLS Y MULTIMEDIA
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
// Prioridad a la imagen de la base de datos
const fotoFinal = p.imagen_url || (categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : '/placeholder.jpg');

// 6. SCHEMAS (LocalBusiness para máximo impacto en Google)
const schemaMarkup = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": p.nombre,
      "image": fotoFinal,
      "description": descriptionSEO,
      "url": canonicalURL,
      "telephone": `+502${p.telefono}`,
      "priceRange": `Q${p.precio_desde}+`,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": p.municipio,
        "addressRegion": p.departamento,
        "addressCountry": "GT"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "24"
      }
    }
  ]
};

// Preparación de links de contacto
const ubicacionTexto = p.municipio ? `${p.municipio}, ${p.departamento}` : p.departamento;
const mensajeWA = encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com y me gustaría solicitar información para un evento en ${ubicacionTexto}.`);
const whatsappLink = `https://wa.me/502${p.telefono}?text=${mensajeWA}`;
---

<Layout title={tituloSEO} description={descriptionSEO}>
  <link rel="icon" type="image/png" href="https://fiestasguatemala.com/favicon.png" slot="head" />
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:title" content={tituloSEO} slot="head" />
  <meta property="og:description" content={descriptionSEO} slot="head" />
  <meta property="og:image" content={fotoFinal} slot="head" />
  <meta property="og:url" content={canonicalURL} slot="head" />
  <meta property="og:type" content="profile" slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />

    <main class="max-w-4xl mx-auto pt-10 pb-20 px-6">
      
      <header class="mb-10">
        <h1 class="text-4xl md:text-5xl font-serif text-[#243447] tracking-tight leading-[1.1] mb-4">
          {p.nombre} <span class="text-[#a68a56]">en {nombreMunicipio}</span>
        </h1>

        <div class="flex items-center gap-2 text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Perfil Actualizado: {fechaActualizacion}
        </div>

        <nav class="flex flex-wrap items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#8b7355] font-bold border-b border-[#8b7355]/10 pb-6">
          <a href="/" class="hover:text-[#243447] no-underline">Inicio</a>
          <span class="opacity-30">/</span>
          <a href={`/${categoriaSlug}`} class="hover:text-[#243447] no-underline">{categoriaCapitalizada}</a>
          <span class="opacity-30">/</span>
          <span class="text-[#a68a56] font-black">{p.nombre}</span>
        </nav>
      </header>

      <div class="bg-white rounded-[40px] overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.07)] border border-white">
        <div class="h-[400px] md:h-[550px] relative">
          <img src={fotoFinal} class="w-full h-full object-cover" alt={`${p.nombre} - ${categoriaCapitalizada} en ${nombreMunicipio}`} loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8 flex items-center gap-2 bg-[#a68a56] text-white px-6 py-3 rounded-full font-bold text-[10px] uppercase tracking-widest shadow-xl">
            <span>📍</span> {ubicacionTexto}
          </div>
        </div>
        
        <div class="p-8 md:p-14">
          <div class="flex flex-col md:flex-row justify-between items-start gap-8 mb-12">
            <div class="flex-1">
              <div class="inline-flex items-center gap-2 bg-[#243447] text-white text-[9px] font-black px-4 py-2 rounded-full uppercase tracking-[0.2em] border border-[#a68a56]/40 mb-5 shadow-lg">
                <span class="text-[#a68a56] text-xs">★</span>
                Proveedor Verificado
              </div>
              <h2 class="text-2xl font-serif text-[#243447]">{p.nombre}</h2>
              <p class="text-[#8b7355] font-bold mt-2 text-[11px] uppercase tracking-[0.15em]">Especialista en {categoriaCapitalizada}</p>
            </div>
            
            <div class="bg-[#f0efec] p-8 rounded-[35px] text-center min-w-[200px] border border-[#243447]/5">
              <p class="text-[9px] text-[#8b7355] font-black uppercase mb-1 tracking-widest opacity-70">Cotiza desde</p>
              <p class="text-4xl font-serif text-[#a68a56]">Q{p.precio_desde}</p>
            </div>
          </div>

          <div class="prose prose-slate max-w-none mb-14">
            <h3 class="text-sm uppercase tracking-widest text-[#243447] font-black mb-4">Sobre este servicio</h3>
            <p class="text-[18px] text-[#243447]/80 leading-relaxed font-light italic bg-[#fcfaf3] p-8 rounded-[30px] border-l-4 border-[#a68a56]">
              "{p.descripcion}"
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <a href={whatsappLink} id="btnWhatsApp" data-id={p.id} target="_blank" class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-6 rounded-[25px] font-bold text-[11px] uppercase tracking-[0.15em] hover:scale-[1.02] transition-all no-underline shadow-xl shadow-green-100">
              <span class="text-2xl">💬</span> WhatsApp Directo
            </a>
            <a href={`tel:+502${p.telefono}`} id="btnCall" data-id={p.id} class="bg-[#243447] text-white flex items-center justify-center gap-3 py-6 rounded-[25px] font-bold text-[11px] uppercase tracking-[0.15em] hover:bg-black transition-all no-underline shadow-xl shadow-slate-200">
              <span class="text-2xl">📞</span> Llamar ahora
            </a>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href={`/${p.categoria_slug}`} class="inline-flex items-center gap-3 text-[#8b7355] font-black uppercase text-[10px] tracking-[0.2em] no-underline hover:text-[#243447] transition-all group">
          <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"></path>
          </svg>
          Ver más {categoriaCapitalizada} en Guatemala
        </a>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  // Script de analítica (igual al anterior, solo verificado)
  const track = (id: string, tipo: string, exit = false) => {
    const url = '/api/click';
    const payload = JSON.stringify({ proveedorId: id, tipo });
    if (exit && navigator.sendBeacon) {
      const blob = new Blob([payload], { type: 'application/json' });
      navigator.sendBeacon(url, blob);
    } else {
      fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload }).catch(() => {});
    }
  };

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest('a');
    if (!link || !link.dataset.id) return;
    const id = link.dataset.id;
    if (link.id === 'btnWhatsApp') track(id, 'click_whatsapp', true);
    if (link.id === 'btnCall') track(id, 'click_llamada', true);
  });

  window.addEventListener('load', () => {
    const el = document.querySelector('[data-id]') as HTMLElement;
    const id = el?.dataset.id;
    if (id) track(id, 'vista_perfil');
  });
</script>