---
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { proveedorSlug } = Astro.params;

const { rows } = await sql`
  SELECT * FROM proveedores WHERE slug = ${proveedorSlug} LIMIT 1
`;
const p = rows[0];

// Link de WhatsApp con mensaje personalizado (Limpio de caracteres extraños)
const ubicacionTexto = p?.municipio ? `${p.municipio}, ${p.departamento}` : p?.departamento;
const mensajeWA = encodeURIComponent(`Hola ${p?.nombre}, vi tu perfil en FiestasGuatemala.com y me gustaría solicitar una cotización para un evento en ${ubicacionTexto}. Gracias.`);
const whatsappLink = `https://wa.me/502${p?.telefono}?text=${mensajeWA}`;
---

<Layout title={p ? `${p.nombre} | Fiestas Guatemala` : 'Proveedor'}>
  {p ? (
    <main class="bg-[#F5F3E7] min-h-screen py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <a href={`/${p.categoria_slug}`} class="inline-flex items-center gap-2 text-[#243447] font-bold mb-8 hover:opacity-70 transition-opacity uppercase text-xs tracking-widest">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
          Volver a {p.categoria_slug}
        </a>

        <div class="bg-white rounded-[45px] overflow-hidden shadow-2xl border border-white">
          <div class="h-[400px] relative">
            <img src={p.imagen_url} class="w-full h-full object-cover" alt={p.nombre} />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            
            <div class="absolute bottom-8 left-10 flex items-center gap-2 bg-[#AD946D] text-white px-6 py-2.5 rounded-full font-bold text-sm shadow-xl border border-white/20">
              <span class="text-lg">📍</span> {p.municipio ? `${p.municipio}, ` : ''}{p.departamento}
            </div>
          </div>
          
          <div class="p-10 md:p-14">
            <div class="flex flex-col md:flex-row justify-between items-start gap-6 mb-10">
              <div>
                <div class="flex items-center gap-2 mb-3">
                   {/* ETIQUETA UNIFICADA: VERIFICADO */}
                   <div class="inline-flex items-center gap-2 bg-[#243447] text-white text-[10px] font-black px-4 py-2 rounded-full uppercase tracking-[0.2em] border border-[#AD946D]/50 shadow-lg">
                    <svg class="w-3.5 h-3.5 text-[#AD946D]" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    Verificado
                  </div>
                </div>
                <h1 class="text-5xl font-black text-[#243447] tracking-tight">{p.nombre}</h1>
                <p class="text-gray-400 font-medium mt-2 flex items-center gap-1 italic text-sm">
                  Atendiendo en toda el área de {p.municipio || p.departamento}
                </p>
              </div>
              <div class="bg-[#F5F3E7] p-6 rounded-[30px] text-center min-w-[180px] border border-[#243447]/5">
                <p class="text-[10px] text-gray-400 font-bold uppercase mb-1">Precio sugerido</p>
                <p class="text-3xl font-black text-[#AD946D]">Q{p.precio_desde}</p>
              </div>
            </div>

            <div class="prose prose-slate max-w-none mb-12">
              <p class="text-xl text-gray-600 leading-relaxed font-medium">
                {p.descripcion}
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <a 
                href={whatsappLink} 
                id="btnWhatsApp"
                data-id={p.id}
                target="_blank" 
                class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-5 rounded-[20px] font-bold text-lg hover:scale-[1.02] transition-all shadow-xl shadow-green-100/50"
              >
                <span class="text-2xl">💬</span> WhatsApp Directo
              </a>
              
              <a 
                href={`tel:+502${p.telefono}`} 
                id="btnCall"
                data-id={p.id}
                class="bg-[#243447] text-white flex items-center justify-center gap-3 py-5 rounded-[20px] font-bold text-lg hover:bg-black transition-all shadow-xl shadow-slate-200"
              >
                <span class="text-2xl">📞</span> Llamar al {p.telefono}
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
  ) : (
    <div class="min-h-screen flex items-center justify-center bg-[#F5F3E7]">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-gray-400 font-serif">Proveedor no encontrado</h1>
        <a href="/" class="text-[#AD946D] font-bold underline mt-4 block uppercase text-xs tracking-widest">Volver al inicio</a>
      </div>
    </div>
  )}
</Layout>

<script>
  const trackClick = async (proveedorId: string, tipo: string) => {
    try {
      await fetch('/api/click', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ proveedorId, tipo })
      });
    } catch (e) {
      console.error("Error tracking click", e);
    }
  };

  const btnWA = document.getElementById('btnWhatsApp');
  const btnCall = document.getElementById('btnCall');
  const proveedorId = btnWA?.getAttribute('data-id');

  if (proveedorId) {
    trackClick(proveedorId, 'vista_perfil');
  }

  btnWA?.addEventListener('click', () => {
    if (proveedorId) trackClick(proveedorId, 'click_whatsapp');
  });

  btnCall?.addEventListener('click', () => {
    if (proveedorId) trackClick(proveedorId, 'click_llamada');
  });
</script>