---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} AND p.activo = true LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const { rows: vRows } = await sql`
      SELECT nombre, slug, imagen_url, precio_desde 
      FROM proveedores 
      WHERE categoria_slug = ${categoriaSlug} 
      AND municipio = ${p.municipio} 
      AND slug != ${p.slug} 
      AND activo = true 
      ORDER BY es_premium DESC LIMIT 3
    `;
    vecinos = vRows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

// 🔥 CONFIGURACIÓN SEO TÉCNICA
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const dbEmoji = p.categoria_emoji || '✨';
const nombreMunicipio = p.municipio || p.departamento;

// H1 solicitado: "Mariachi dos en Guatemala, Guatemala"
const h1Texto = `${p.nombre} en ${p.municipio}, ${p.departamento}`;
const tituloSEO = `${h1Texto} ${dbEmoji} | Q${p.precio_desde}`;

const schemaMarkup = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": p.nombre,
    "image": p.imagen_url,
    "telephone": p.telefono,
    "url": canonicalURL,
    "priceRange": `Q${p.precio_desde}+`,
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142" },
    "address": { "@type": "PostalAddress", "addressLocality": p.municipio, "addressRegion": p.departamento, "addressCountry": "GT" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": `¿Cuánto cobra ${p.nombre}?`,
      "acceptedAnswer": { "@type": "Answer", "text": `En ${p.municipio}, los servicios de ${p.nombre} inician desde Q${p.precio_desde}.` }
    }]
  }
];

const whatsappLink = `https://wa.me/502${p.whatsapp || p.telefono}?text=${encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com...`)}`;
---

<Layout title={tituloSEO} description={`Contrata a ${p.nombre} en ${p.municipio}. Perfil verificado.`}>
  
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:url" content={canonicalURL} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#F8F7F4] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-6xl mx-auto pt-6 pb-12 px-6">
      
      <header class="mb-6">
        <h1 class="text-3xl md:text-6xl font-serif italic text-[#243447] tracking-tighter mb-2 leading-tight">
          {h1Texto}
        </h1>
        
        <nav class="flex items-center gap-2 text-[9px] uppercase tracking-[0.2em] text-[#AD946D] font-black">
          <a href="/">Inicio</a> <span class="opacity-30">/</span> 
          <a href={`/${categoriaSlug}`}>{p.categoria_nombre}</a> <span class="opacity-30">/</span> 
          <span class="text-[#243447]">{p.nombre}</span>
        </nav>

        <div class="text-[8px] uppercase tracking-[0.3em] text-gray-400 font-medium mt-1">
          Actualizado: Marzo 2026
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
        
        <div class="md:col-span-5">
          <div class="relative rounded-[30px] overflow-hidden shadow-2xl bg-white p-1.5 border border-gray-100">
            <img src={p.imagen_url} class="w-full aspect-[4/4] object-cover rounded-[24px]" alt={p.nombre} fetchpriority="high" />
          </div>
        </div>

        <div class="md:col-span-7 space-y-6">
          
          <div class="space-y-2">
            <div class="flex items-center gap-2 bg-[#243447] text-white px-3 py-1 rounded-full w-fit">
              <span class="text-[#AD946D] text-[10px]">★</span>
              <span class="text-[8px] font-black uppercase tracking-widest">Perfil Verificado</span>
            </div>
            <p class="text-xl md:text-3xl font-serif leading-tight text-[#243447] italic">
              "{p.descripcion || `Excelencia en ${p.categoria_nombre} para tus eventos en ${p.municipio}.`}"
            </p>
          </div>

          <div class="flex items-end gap-4">
             <div>
               <p class="text-[9px] font-black uppercase tracking-widest text-gray-400 mb-1">Inversión desde</p>
               <p class="text-5xl md:text-6xl font-serif text-[#243447] leading-none">Q{p.precio_desde}</p>
             </div>
             <div class="text-2xl pb-1">{dbEmoji}</div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a href={whatsappLink} class="flex-1 bg-[#25D366] text-white py-4 rounded-xl text-center font-black text-[11px] uppercase tracking-widest shadow-lg hover:scale-[1.02] transition-all">
              WhatsApp Directo
            </a>
            <a href={`tel:+502${p.telefono}`} class="flex-1 border-2 border-[#243447] text-[#243447] py-4 rounded-xl text-center font-black text-[11px] uppercase tracking-widest hover:bg-[#243447] hover:text-white transition-all">
              Llamar Ahora
            </a>
          </div>
        </div>
      </div>

      {vecinos.length > 0 && (
        <section class="mt-12 pt-8 border-t border-gray-100">
          <h2 class="text-xl font-serif italic text-[#243447] mb-6">Otros recomendados en {p.municipio}</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {vecinos.map(v => (
              <a href={`/${categoriaSlug}/${v.slug}`} class="group no-underline block bg-white p-2 rounded-3xl shadow-sm border border-gray-50">
                <div class="aspect-video rounded-2xl overflow-hidden mb-2">
                  <img src={v.imagen_url || '/placeholder.jpg'} class="w-full h-full object-cover" alt={v.nombre} loading="lazy" />
                </div>
                <h4 class="font-serif text-[#243447] text-sm px-1">{v.nombre}</h4>
              </a>
            ))}
          </div>
        </section>
      )}

    </main>
    <Footer />
  </div>
</Layout>