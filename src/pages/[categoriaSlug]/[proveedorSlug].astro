---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} AND p.activo = true LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const { rows: vRows } = await sql`
      SELECT nombre, slug, imagen_url, precio_desde FROM proveedores 
      WHERE categoria_slug = ${categoriaSlug} AND municipio = ${p.municipio} 
      AND slug != ${p.slug} AND activo = true LIMIT 3
    `;
    vecinos = vRows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const dbEmoji = p.categoria_emoji || '✨';
// H1 exacto: Nombre en Municipio, Departamento
const h1Texto = `${p.nombre} en ${p.municipio}, ${p.departamento}`;

const schemaMarkup = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": p.nombre,
    "image": p.imagen_url,
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142" }
  }
];

const whatsappLink = `https://wa.me/502${p.whatsapp || p.telefono}?text=Hola...`;
---

<Layout title={`${h1Texto} ${dbEmoji}`} description={`Contrata a ${p.nombre}.`}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#F8F7F4] min-h-screen font-sans text-[#243447]">
    <Header />
    <main class="max-w-6xl mx-auto pt-6 pb-12 px-6">
      <header class="mb-6">
        <h1 class="text-3xl md:text-5xl font-serif italic font-bold truncate">{h1Texto}</h1>
        <nav class="text-[9px] uppercase font-black text-[#AD946D] my-2">
          <a href="/">Inicio</a> / <a href={`/${categoriaSlug}`}>{p.categoria_nombre}</a> / {p.nombre}
        </nav>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
        <div class="md:col-span-5">
          <img src={p.imagen_url} class="w-full aspect-square object-cover rounded-[30px] shadow-2xl border-4 border-white" alt={p.nombre} />
        </div>
        <div class="md:col-span-7 space-y-6">
          <div class="bg-[#243447] text-white text-[8px] font-black px-3 py-1 rounded-full inline-block uppercase">★ Perfil Verificado</div>
          <p class="text-2xl md:text-3xl font-serif italic">"{p.descripcion}"</p>
          <p class="text-5xl font-serif text-[#243447] font-bold">Q{p.precio_desde}</p>
          
          <div class="flex flex-col sm:flex-row gap-3">
            <a href={whatsappLink} id="track-whatsapp" class="flex-1 bg-[#25D366] text-white py-4 rounded-xl text-center font-black text-[11px] uppercase shadow-lg">WhatsApp Directo</a>
            <a href={`tel:+502${p.telefono}`} id="track-llamada" class="flex-1 border-2 border-[#243447] text-[#243447] py-4 rounded-xl text-center font-black text-[11px] uppercase">Llamar Ahora</a>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script define:vars={{ pId: p.id }}>
  // FUNCIÓN DE RASTREO CORREGIDA
  const track = (tipo) => {
    console.log("Tracking:", tipo);
    fetch('/api/click', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ proveedorId: pId, tipo }),
      keepalive: true
    }).catch(err => console.error("Error tracking:", err));
  };

  document.getElementById('track-whatsapp')?.addEventListener('click', () => track('whatsapp'));
  document.getElementById('track-llamada')?.addEventListener('click', () => track('llamada'));
  track('vista');
</script>