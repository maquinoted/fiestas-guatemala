---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} AND p.activo = true LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const { rows: vRows } = await sql`
      SELECT nombre, slug, imagen_url, precio_desde FROM proveedores 
      WHERE categoria_slug = ${categoriaSlug} AND municipio = ${p.municipio} 
      AND slug != ${p.slug} AND activo = true LIMIT 3
    `;
    vecinos = vRows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const dbEmoji = p.categoria_emoji || '✨';
const h1Texto = `${p.nombre} en ${p.municipio}, ${p.departamento}`;
const ogDescription = `✅ Perfil Verificado: Contrata a ${p.nombre} en ${p.municipio}. Servicios de ${p.categoria_nombre} desde Q${p.precio_desde}. ¡Reserva hoy mismo!`;

// 🔥 MANTENIENDO TUS 5 SCHEMAS INTACTOS
const schemaMarkup = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "name": p.nombre, "image": p.imagen_url, "telephone": p.telefono, "priceRange": `Q${p.precio_desde}+`, "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142" }, "address": { "@type": "PostalAddress", "addressLocality": p.municipio, "addressRegion": p.departamento, "addressCountry": "GT" } },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{ "@type": "Question", "name": `¿Cuánto cobra ${p.nombre}?`, "acceptedAnswer": { "@type": "Answer", "text": `En ${p.municipio}, los servicios de ${p.nombre} inician desde Q${p.precio_desde}.` } }] },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteBase }, { "@type": "ListItem", "position": 2, "name": p.categoria_nombre, "item": `${siteBase}/${categoriaSlug}` }, { "@type": "ListItem", "position": 3, "name": p.nombre, "item": canonicalURL }] },
  { "@context": "https://schema.org", "@type": "WebSite", "name": "Fiestas Guatemala", "url": siteBase },
  { "@context": "https://schema.org", "@type": "Organization", "name": "Fiestas Guatemala", "logo": `${siteBase}/logo.png`, "url": siteBase }
];
---

<Layout title={`${h1Texto} ${dbEmoji}`} description={ogDescription}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#F8F7F4] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-5xl mx-auto pt-8 pb-20 px-4 md:px-6">
      
      <header class="mb-10">
        <h1 class="text-4xl md:text-6xl font-serif italic text-[#243447] tracking-tighter leading-none mb-3">
          {h1Texto}
        </h1>
        <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#AD946D] font-black">
          <a href="/">Inicio</a> <span>/</span> 
          <a href={`/${categoriaSlug}`}>{p.categoria_nombre}</a> <span>/</span> 
          <span class="text-[#243447]">{p.nombre}</span>
        </nav>
        <div class="text-[8px] uppercase tracking-[0.3em] opacity-30 font-bold mt-2">
          Actualizado: Marzo 2026
        </div>
      </header>

      <div class="bg-white rounded-[50px] shadow-2xl overflow-hidden border border-white relative">
        
        <div class="grid grid-cols-1 md:grid-cols-2">
          
          <div class="relative h-[400px] md:h-auto overflow-hidden">
            <img 
              src={p.imagen_url} 
              class="w-full h-full object-cover" 
              alt={p.nombre}
              fetchpriority="high"
            />
            <div class="absolute top-6 left-6 bg-white/95 backdrop-blur-sm px-4 py-2 rounded-full shadow-xl flex items-center gap-2">
              <span class="text-[#AD946D] text-xs">★</span>
              <span class="text-[10px] font-black uppercase tracking-widest text-[#243447]">Verificado</span>
            </div>
          </div>

          <div class="p-8 md:p-12 flex flex-col justify-center space-y-8">
            <div class="space-y-4">
              <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#AD946D]">📍 {p.municipio}, {p.departamento}</p>
              <p class="text-2xl md:text-3xl font-serif italic leading-tight text-[#243447]">
                "{p.descripcion}"
              </p>
            </div>

            <div class="pt-6 border-t border-gray-50">
              <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Inversión desde</p>
              <div class="flex items-baseline gap-2">
                <p class="text-5xl md:text-6xl font-serif text-[#243447] font-bold tracking-tighter">Q{p.precio_desde}</p>
                <span class="text-2xl opacity-20">{dbEmoji}</span>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-3 pt-4">
              <a href={`https://wa.me/502${p.whatsapp || p.telefono}?text=Hola...`} id="btn-wa" class="bg-[#25D366] text-white py-5 rounded-2xl text-center font-black text-xs uppercase tracking-widest shadow-xl hover:scale-[1.02] transition-all">
                WhatsApp Directo
              </a>
              <a href={`tel:+502${p.telefono}`} id="btn-call" class="bg-[#243447] text-white py-5 rounded-2xl text-center font-black text-xs uppercase tracking-widest hover:bg-[#1a2633] transition-all">
                Llamar Ahora
              </a>
            </div>
          </div>
        </div>
      </div>

      {vecinos.length > 0 && (
        <section class="mt-20">
          <h2 class="text-2xl font-serif italic text-[#243447] mb-10 opacity-80 text-center md:text-left">Otros recomendados en {p.municipio}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
            {vecinos.map(v => (
              <a href={`/${categoriaSlug}/${v.slug}`} class="group">
                <div class="bg-white p-3 rounded-[40px] shadow-lg border border-white transition-all group-hover:shadow-2xl group-hover:-translate-y-1">
                  <div class="aspect-square rounded-[30px] overflow-hidden mb-4">
                    <img src={v.imagen_url || '/placeholder.jpg'} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt={v.nombre} loading="lazy" />
                  </div>
                  <div class="px-2 pb-2">
                    <h4 class="font-serif text-xl text-[#243447]">{v.nombre}</h4>
                    <p class="text-[10px] text-[#AD946D] font-black uppercase tracking-widest mt-1">Desde Q{v.precio_desde}</p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

    </main>
    <Footer />
  </div>
</Layout>

<script define:vars={{ pId: p.id }}>
  const track = (tipo) => {
    fetch('/api/click', { 
      method: 'POST', 
      headers: { 'Content-Type': 'application/json' }, 
      body: JSON.stringify({ proveedorId: pId, tipo }), 
      keepalive: true 
    }).catch(() => {});
  };
  document.getElementById('btn-wa')?.addEventListener('click', () => track('whatsapp'));
  document.getElementById('btn-call')?.addEventListener('click', () => track('llamada'));
  track('vista');
</script>