---
// 1. SSR ABSOLUTO
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { proveedorSlug } = Astro.params;

// 2. Consulta a la base de datos
const { rows } = await sql`
  SELECT *, NOW() as db_time FROM proveedores WHERE slug = ${proveedorSlug} LIMIT 1
`;
const p = rows[0];

if (!p) return Astro.redirect('/404');

// 3. SEO LOCAL DINÁMICO
const nombreMunicipio = p.municipio || p.departamento;
const tituloSEO = `${p.nombre} en ${nombreMunicipio} | Cotización y Precios | Fiestas Guatemala`;
const descripcionSEO = `Contrata a ${p.nombre} en ${nombreMunicipio}. Especialistas en ${p.categoria_slug}. Precios desde Q${p.precio_desde}. ¡Proveedor Verificado!`;

const ubicacionTexto = p.municipio ? `${p.municipio}, ${p.departamento}` : p.departamento;
const mensajeWA = encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com y me gustaría solicitar información para un evento en ${ubicacionTexto}.`);
const whatsappLink = `https://wa.me/502${p.telefono}?text=${mensajeWA}`;
---

<Layout title={tituloSEO} description={descripcionSEO}>
  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    
    <Header />

    <main class="max-w-4xl mx-auto mt-4 pb-20 px-6">
      
      <nav class="mb-10">
        <a href={`/${p.categoria_slug}`} class="inline-flex items-center gap-2 text-[#8b7355] font-bold hover:text-[#243447] transition-colors uppercase text-[10px] tracking-[0.2em] no-underline group">
          <svg class="w-3 h-3 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"></path>
          </svg>
          Volver a {p.categoria_slug.replace(/-/g, ' ')}
        </a>
      </nav>

      <div class="bg-white rounded-[35px] overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.07)] border border-white">
        <div class="h-[400px] md:h-[500px] relative">
          <img src={p.imagen_url} class="w-full h-full object-cover" alt={`${p.nombre} en ${nombreMunicipio}`} loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8 flex items-center gap-2 bg-[#a68a56] text-white px-5 py-2.5 rounded-full font-bold text-[10px] uppercase tracking-widest shadow-xl">
            <span>📍</span> {p.municipio ? `${p.municipio}, ` : ''}{p.departamento}
          </div>
        </div>
        
        <div class="p-8 md:p-14">
          <div class="flex flex-col md:flex-row justify-between items-start gap-8 mb-12">
            <div class="flex-1">
              <div class="inline-flex items-center gap-2 bg-[#243447] text-white text-[9px] font-black px-4 py-2 rounded-full uppercase tracking-[0.2em] border border-[#a68a56]/40 mb-5 shadow-lg">
                <span class="text-[#a68a56] text-xs">★</span>
                Proveedor Verificado
              </div>
              <h1 class="text-4xl md:text-5xl font-serif text-[#243447] tracking-tight leading-[1.1]">{p.nombre}</h1>
              <p class="text-[#8b7355] font-bold mt-3 text-[11px] uppercase tracking-[0.15em]">Servicio profesional en {nombreMunicipio}</p>
            </div>
            
            <div class="bg-[#f0efec] p-7 rounded-[30px] text-center min-w-[180px] border border-[#243447]/5">
              <p class="text-[9px] text-[#8b7355] font-black uppercase mb-1 tracking-widest opacity-70">Cotiza desde</p>
              <p class="text-3xl font-serif text-[#a68a56]">Q{p.precio_desde}</p>
            </div>
          </div>

          <div class="prose prose-slate max-w-none mb-14">
            <p class="text-[17px] text-[#243447]/80 leading-relaxed font-light italic">
              "{p.descripcion}"
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <a href={whatsappLink} id="btnWhatsApp" data-id={p.id} target="_blank" class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-5 rounded-[22px] font-bold text-[11px] uppercase tracking-[0.15em] hover:scale-[1.02] transition-all no-underline shadow-xl shadow-green-100">
              <span class="text-2xl">💬</span> WhatsApp Directo
            </a>
            <a href={`tel:+502${p.telefono}`} id="btnCall" data-id={p.id} class="bg-[#243447] text-white flex items-center justify-center gap-3 py-5 rounded-[22px] font-bold text-[11px] uppercase tracking-[0.15em] hover:bg-black transition-all no-underline shadow-xl shadow-slate-200">
              <span class="text-2xl">📞</span> Llamar ahora
            </a>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  const track = (id: string, tipo: string, exit = false) => {
    const url = '/api/click';
    const payload = JSON.stringify({ proveedorId: id, tipo });
    if (exit && navigator.sendBeacon) {
      const blob = new Blob([payload], { type: 'application/json' });
      navigator.sendBeacon(url, blob);
    } else {
      fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload }).catch(() => {});
    }
  };

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest('a');
    if (!link || !link.dataset.id) return;
    const id = link.dataset.id;
    if (link.id === 'btnWhatsApp') track(id, 'click_whatsapp', true);
    if (link.id === 'btnCall') track(id, 'click_llamada', true);
  });

  window.addEventListener('load', () => {
    const el = document.querySelector('[data-id]') as HTMLElement;
    const id = el?.dataset.id;
    if (id) track(id, 'vista_perfil');
  });
</script>