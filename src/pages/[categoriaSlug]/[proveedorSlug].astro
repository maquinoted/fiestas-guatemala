---
// 1. SSR ABSOLUTO
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

// 2. DATOS DE DB (PROVEEDOR + SILO DE VECINOS)
let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT *, NOW() as db_time FROM proveedores WHERE slug = ${proveedorSlug} AND activo = true LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const otrosVecinos = await sql`
      SELECT nombre, slug, imagen_url, precio_desde 
      FROM proveedores 
      WHERE categoria_slug = ${categoriaSlug} 
      AND municipio = ${p.municipio} 
      AND slug != ${p.slug} 
      AND activo = true 
      LIMIT 3
    `;
    vecinos = otrosVecinos.rows || [];
  }
} catch (e) {
  console.error("Error en DB:", e);
}

if (!p) return Astro.redirect('/404');

// 3. UTILIDADES Y FECHAS
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const categoriaLimpia = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const categoriaCapitalizada = capitalize(categoriaLimpia);
const nombreMunicipio = p.municipio || p.departamento;
const fecha = new Date();
const fechaActualizacion = `Marzo 2026`; 

// 4. SEO Y META DESCRIPTION (INTACTO)
const emoji = categoriaSlug === 'mariachis' ? '🎺' : '✨';
const tituloSEO = `${p.nombre} en ${nombreMunicipio} | Cotiza Hoy | FiestasGuatemala.com`;
const descriptionSEO = `${emoji} ¡Contrata a los mejores! ${p.nombre} en ${nombreMunicipio}. Especialistas en ${categoriaLimpia} con precios desde Q${p.precio_desde}. ✅ Perfil Verificado. ¡Reserva tu fecha hoy mismo!`;

const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const fotoFinal = p.imagen_url || (categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : '/placeholder.jpg');

// 6. LOS 3 SCHEMAS (INTACTO)
const schemaMarkup = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": p.nombre,
    "image": fotoFinal,
    "description": descriptionSEO,
    "brand": { "@type": "Brand", "name": "FiestasGuatemala.com" },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "125"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": `¿Cómo contacto a ${p.nombre}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Puedes contactarlos directamente haciendo clic en el botón de WhatsApp o llamada telefónica en su perfil verificado de FiestasGuatemala.com.`
      }
    }]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteBase },
      { "@type": "ListItem", "position": 2, "name": categoriaCapitalizada, "item": `${siteBase}/${categoriaSlug}` },
      { "@type": "ListItem", "position": 3, "name": p.nombre, "item": canonicalURL }
    ]
  }
];

const whatsappLink = `https://wa.me/502${p.telefono}?text=${encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com y quiero cotizar...`)}`;
---

<Layout title={tituloSEO} description={descriptionSEO}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  
  <meta property="og:type" content="profile" slot="head" />
  <meta property="og:title" content={tituloSEO} slot="head" />
  <meta property="og:image" content={fotoFinal} slot="head" />
  <meta property="og:url" content={canonicalURL} slot="head" />
  <meta property="profile:username" content={p.slug} slot="head" />
  <meta property="business:contact_data:locality" content={p.municipio} slot="head" />
  <meta property="business:contact_data:region" content={p.departamento} slot="head" />
  
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-5xl mx-auto pt-6 pb-20 px-6">
      
      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-serif text-[#243447] leading-none mb-4">
          {p.nombre} <span class="text-[#a68a56]">en {nombreMunicipio}</span>
        </h1>

        <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.1em] text-[#8b7355] font-bold mb-4 border-b border-[#8b7355]/10 pb-4">
          <a href="/" class="no-underline hover:text-[#243447]">Inicio</a> 
          <span class="opacity-50">/</span> 
          <a href={`/${categoriaSlug}`} class="no-underline hover:text-[#243447]">{categoriaCapitalizada}</a>
          <span class="opacity-50">/</span>
          <span class="text-[#a68a56] font-black">{p.nombre}</span>
        </nav>

        <div class="text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold">
          Perfil Actualizado: {fechaActualizacion}
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        <div class="lg:col-span-4">
          <div class="rounded-[30px] overflow-hidden shadow-xl border-4 border-white h-[280px] lg:h-[320px]">
            <img 
              src={fotoFinal} 
              class="w-full h-full object-cover" 
              alt={p.nombre} 
              fetchpriority="high"
              decoding="sync"
              loading="eager"
            />
          </div>
        </div>

        <div class="lg:col-span-8 space-y-4">
          <div class="bg-white p-6 rounded-[35px] shadow-sm border border-white">
            <div class="flex justify-between items-start mb-6">
              <div>
                {p.es_premium && (
                  <div class="inline-flex items-center gap-2 bg-[#243447] text-white text-[8px] font-black px-3 py-1.5 rounded-full uppercase tracking-tighter mb-3">
                    ★ Verificado
                  </div>
                )}
                <p class="text-[9px] uppercase tracking-widest text-[#8b7355] font-black mb-1">Desde</p>
                <p class="text-4xl font-serif text-[#a68a56] leading-none">Q{p.precio_desde}</p>
              </div>
              <div class="text-right text-[10px] uppercase font-bold text-[#243447]">
                📍 {p.municipio}<br/>{p.departamento}
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <a href={whatsappLink} id="btnWhatsApp" data-id={p.id} class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-4 rounded-2xl font-black text-[11px] uppercase no-underline shadow-lg shadow-green-100 hover:scale-[1.02] transition-transform">
                <span class="text-xl">💬</span> WhatsApp Directo
              </a>
              <a href={`tel:+502${p.telefono}`} id="btnCall" data-id={p.id} class="bg-[#243447] text-white flex items-center justify-center gap-3 py-4 rounded-2xl font-black text-[11px] uppercase no-underline shadow-lg hover:bg-black transition-all">
                <span class="text-xl">📞</span> Llamar Ahora
              </a>
            </div>
          </div>

          <div class="bg-[#fcfaf3] p-6 rounded-[35px] border-l-[6px] border-[#a68a56]">
             <p class="text-[15px] md:text-[16px] text-[#243447] leading-relaxed italic font-light">
               "{p.descripcion || `Especialista en ${categoriaLimpia} con amplia trayectoria en eventos.`}"
             </p>
          </div>
        </div>
      </div>

      {vecinos.length > 0 && (
        <section class="mt-20 border-t border-[#8b7355]/10 pt-16">
          <h2 class="text-2xl font-serif text-[#243447] mb-8">Otros {categoriaCapitalizada} en <span class="text-[#a68a56]">{p.municipio}</span></h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            {vecinos.map(v => (
              <a href={`/${categoriaSlug}/${v.slug}`} class="group bg-white rounded-[30px] p-4 border border-gray-100 shadow-sm hover:shadow-xl transition-all no-underline">
                <div class="h-40 rounded-[20px] overflow-hidden mb-4">
                  <img 
                    src={v.imagen_url || (categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : '/placeholder.jpg')} 
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
                    alt={v.nombre} 
                    loading="lazy"
                  />
                </div>
                <h4 class="font-serif text-[#243447] text-base mb-1">{v.nombre}</h4>
                <p class="text-[10px] text-[#a68a56] font-black uppercase tracking-widest">Desde Q{v.precio_desde}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="mt-16 text-center border-t border-[#8b7355]/10 pt-10">
        <a href={`/${p.categoria_slug}`} class="text-[#8b7355] font-black uppercase text-[10px] tracking-[0.2em] no-underline hover:text-[#243447] transition-all">
          ← Volver a {categoriaCapitalizada}
        </a>
      </div>

    </main>
    <Footer />
  </div>
</Layout>

<script define:vars={{ pId: p.id }}>
  const track = (tipo, exit = false) => {
    const url = '/api/click';
    const body = JSON.stringify({ proveedorId: pId, tipo });
    
    if (exit && navigator.sendBeacon) {
      navigator.sendBeacon(url, new Blob([body], { type: 'application/json' }));
    } else {
      fetch(url, { 
        method: 'POST', 
        headers: { 'Content-Type': 'application/json' }, 
        body,
        keepalive: true 
      }).catch(() => {});
    }
  };

  // 1. Rastrear Vista de Perfil (Inmediato)
  track('vista_perfil');

  // 2. Rastrear Clics
  document.getElementById('btnWhatsApp')?.addEventListener('click', () => track('click_whatsapp', true));
  document.getElementById('btnCall')?.addEventListener('click', () => track('click_llamada', true));
</script>