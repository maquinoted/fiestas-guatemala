---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

// 1. DATOS DE DB
const { rows } = await sql`
  SELECT *, NOW() as db_time FROM proveedores WHERE slug = ${proveedorSlug} AND activo = true LIMIT 1
`;
const p = rows[0];

if (!p) return Astro.redirect('/404');

// 2. UTILIDADES
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const categoriaLimpia = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const categoriaCapitalizada = capitalize(categoriaLimpia);
const nombreMunicipio = p.municipio || p.departamento;

const fecha = new Date();
const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
const fechaActualizacion = `${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;

// 3. SEO Y META DESCRIPTION PERSUASIVA
const emoji = categoriaSlug === 'mariachis' ? '🎺' : '✨';
const tituloSEO = `${p.nombre} en ${nombreMunicipio} | Cotiza Hoy | FiestasGuatemala.com`;
const descriptionSEO = `${emoji} ¡Contrata a los mejores! ${p.nombre} en ${nombreMunicipio}. Especialistas en ${categoriaLimpia} con precios desde Q${p.precio_desde}. ✅ Perfil Verificado. ¡Reserva tu fecha para este ${fecha.getFullYear()} hoy mismo!`;

// 4. IMAGEN DE LA DB (FALLBACK MARIACHIS)
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const fotoFinal = p.imagen_url || (categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : '/placeholder.jpg');

// 5. SCHEMAS (LOS 3: PRODUCT, FAQ Y BREADCRUMB)
const schemaMarkup = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": p.nombre,
    "image": fotoFinal,
    "description": descriptionSEO,
    "brand": { "@type": "Brand", "name": "FiestasGuatemala.com" },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "110"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `¿Cómo contacto a ${p.nombre}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Puedes contactarlos directamente haciendo clic en el botón de WhatsApp o llamando al número que aparece en su perfil verificado en FiestasGuatemala.com.`
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteBase },
      { "@type": "ListItem", "position": 2, "name": categoriaCapitalizada, "item": `${siteBase}/${categoriaSlug}` },
      { "@type": "ListItem", "position": 3, "name": p.nombre, "item": canonicalURL }
    ]
  }
];

const whatsappLink = `https://wa.me/502${p.telefono}?text=${encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com y quiero cotizar...`)}`;
---

<Layout title={tituloSEO} description={descriptionSEO}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:image" content={fotoFinal} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />

    <main class="max-w-5xl mx-auto pt-6 pb-20 px-6">
      
      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-serif text-[#243447] leading-none mb-4">
          {p.nombre} <span class="text-[#a68a56]">en {nombreMunicipio}</span>
        </h1>

        <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.1em] text-[#8b7355] font-bold mb-4 border-b border-[#8b7355]/10 pb-4">
          <a href="/" class="no-underline hover:text-[#243447]">Inicio</a> 
          <span class="opacity-50">/</span> 
          <a href={`/${categoriaSlug}`} class="no-underline hover:text-[#243447]">{categoriaCapitalizada}</a>
          <span class="opacity-50">/</span>
          <span class="text-[#a68a56] font-black">{p.nombre}</span>
        </nav>

        <div class="flex items-center gap-2 text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Perfil Actualizado: {fechaActualizacion}
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        
        <div class="lg:col-span-4">
          <div class="rounded-[30px] overflow-hidden shadow-xl border-4 border-white h-[280px] lg:h-[320px]">
            <img src={fotoFinal} class="w-full h-full object-cover" alt={p.nombre} />
          </div>
        </div>

        <div class="lg:col-span-8 space-y-4">
          <div class="bg-white p-6 rounded-[35px] shadow-sm border border-white">
            <div class="flex justify-between items-start mb-6">
              <div>
                <div class="inline-flex items-center gap-2 bg-[#243447] text-white text-[8px] font-black px-3 py-1.5 rounded-full uppercase tracking-tighter mb-3">
                  ★ Verificado
                </div>
                <p class="text-[9px] uppercase tracking-widest text-[#8b7355] font-black mb-1">Inversión desde</p>
                <p class="text-4xl font-serif text-[#a68a56] leading-none">Q{p.precio_desde}</p>
              </div>
              <div class="text-right">
                <span class="text-xs">📍</span>
                <p class="text-[10px] font-black uppercase text-[#243447]">{p.municipio}</p>
                <p class="text-[9px] text-[#8b7355] uppercase font-bold">{p.departamento}</p>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <a href={whatsappLink} class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-4 rounded-2xl font-black text-[11px] uppercase tracking-widest hover:scale-[1.02] transition-all no-underline shadow-lg shadow-green-100">
                <span class="text-xl">💬</span> WhatsApp Directo
              </a>
              <a href={`tel:+502${p.telefono}`} class="bg-[#243447] text-white flex items-center justify-center gap-3 py-4 rounded-2xl font-black text-[11px] uppercase tracking-widest hover:bg-black transition-all no-underline">
                <span class="text-xl">📞</span> Llamar Ahora
              </a>
            </div>
          </div>

          <div class="bg-[#fcfaf3] p-6 rounded-[35px] border-l-[6px] border-[#a68a56]">
             <h3 class="text-[9px] uppercase font-black tracking-widest text-[#8b7355] mb-2">Descripción del servicio:</h3>
             <p class="text-[15px] md:text-[16px] text-[#243447] leading-relaxed italic font-light">
               "{p.descripcion || `Profesionales líderes en ${categoriaLimpia} para eventos en ${nombreMunicipio}. Calidad garantizada.`}"
             </p>
          </div>
        </div>
      </div>

      <div class="mt-10 text-center">
        <a href={`/${p.categoria_slug}`} class="text-[#8b7355] font-black uppercase text-[10px] tracking-[0.2em] no-underline hover:text-[#243447] transition-all group">
          ← Volver a {categoriaCapitalizada}
        </a>
      </div>

    </main>
    <Footer />
  </div>
</Layout>