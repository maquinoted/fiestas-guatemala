---
// 1. SSR ABSOLUTO
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

// 2. DATOS DE DB (PROVEEDOR + ICONO DE CATEGORÍA + VECINOS)
let p = null;
let vecinos = [];

try {
  // Jalamos al proveedor y de una vez su icono de la tabla categorias
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} 
    AND p.activo = true 
    LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const otrosVecinos = await sql`
      SELECT nombre, slug, imagen_url, precio_desde, categoria_slug
      FROM proveedores 
      WHERE categoria_slug = ${categoriaSlug} 
      AND municipio = ${p.municipio} 
      AND slug != ${p.slug} 
      AND activo = true 
      LIMIT 3
    `;
    vecinos = otrosVecinos.rows || [];
  }
} catch (e) {
  console.error("Error en DB:", e);
}

if (!p) return Astro.redirect('/404');

// 3. UTILIDADES
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const categoriaLimpia = p.categoria_nombre || categoriaSlug.replace(/-/g, ' ');
const categoriaCapitalizada = capitalize(categoriaLimpia);
const nombreMunicipio = p.municipio || p.departamento;
const fechaActualizacion = `Marzo 2026`; 

// 4. SEO AGRESIVO PARA CTR (Usando el icono de la DB)
const dbEmoji = p.categoria_emoji || '✨';
// Título con Precio y Emoji: "🎺 Mariachi Aquino en Mixco | Q1,500 | FiestasGuatemala.com"
const tituloSEO = `${dbEmoji} ${p.nombre} en ${nombreMunicipio} | Q${p.precio_desde} | FiestasGuatemala.com`;

// Descripción enfocada en conversión y confianza:
const descriptionSEO = `${dbEmoji} ¡Reserva hoy con confianza! Contrata a ${p.nombre} en ${nombreMunicipio}. Precios reales desde Q${p.precio_desde}. ✅ Perfil Verificado por Fiestas Guatemala.`;

const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}/${proveedorSlug}`;
const fotoFinal = p.imagen_url || '/placeholder.jpg';

// 5. CONTACTO
const numeroWhatsApp = p.whatsapp || p.telefono;
const whatsappLink = `https://wa.me/502${numeroWhatsApp}?text=${encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com y quiero cotizar...`)}`;

// 6. SCHEMA LOCAL BUSINESS
const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": p.nombre,
  "image": fotoFinal,
  "description": descriptionSEO,
  "telephone": p.telefono,
  "priceRange": `GTQ ${p.precio_desde}`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": p.municipio,
    "addressRegion": p.departamento,
    "addressCountry": "GT"
  }
};
---

<Layout title={tituloSEO} description={descriptionSEO}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:image" content={fotoFinal} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-6xl mx-auto pt-6 pb-20 px-6">
      
      <header class="mb-8 border-b border-[#a68a56]/10 pb-6 text-center md:text-left">
        <h1 class="text-4xl md:text-7xl font-serif text-[#243447] leading-tight mb-3">
          {p.nombre} en {p.municipio}, {p.departamento}
        </h1>

        <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.1em] text-[#8b7355] font-bold mb-3 justify-center md:justify-start">
          <a href="/" class="no-underline hover:text-[#243447]">Inicio</a> 
          <span class="opacity-50">/</span> 
          <a href={`/${categoriaSlug}`} class="no-underline hover:text-[#243447]">{categoriaCapitalizada}</a>
          <span class="opacity-50">/</span>
          <span class="text-[#a68a56] font-black">{p.nombre}</span>
        </nav>

        <div class="text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold italic justify-center md:justify-start">
          Perfil Oficial • Actualizado {fechaActualizacion}
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-6">
          <div class="rounded-[50px] overflow-hidden shadow-2xl border-[10px] border-white h-[450px] lg:h-[600px]">
            <img src={fotoFinal} class="w-full h-full object-cover" alt={p.nombre} fetchpriority="high" />
          </div>
        </div>

        <div class="lg:col-span-6 space-y-6">
          <div class="bg-white p-10 rounded-[45px] shadow-sm border border-white">
            <div class="mb-8">
              <p class="text-[10px] uppercase tracking-[0.2em] text-[#8b7355] font-black mb-2 text-center md:text-left">Inversión desde</p>
              <p class="text-6xl md:text-7xl font-serif text-[#a68a56] leading-none text-center md:text-left">Q{p.precio_desde}</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <a href={whatsappLink} id="btnWhatsApp" class="bg-[#25D366] text-white flex items-center justify-center gap-3 py-5 rounded-[25px] font-black text-[13px] uppercase shadow-xl hover:scale-105 transition-all">
                💬 WhatsApp Directo
              </a>
              <a href={`tel:+502${p.telefono}`} id="btnCall" class="bg-[#243447] text-white flex items-center justify-center gap-3 py-5 rounded-[25px] font-black text-[13px] uppercase shadow-xl hover:bg-black transition-all">
                📞 Llamar Ahora
              </a>
            </div>
          </div>

          <div class="bg-[#243447] p-10 rounded-[45px] border-l-[10px] border-[#a68a56] shadow-xl text-white">
             <div class="flex items-center gap-3 mb-6 pb-6 border-b border-white/10">
               <span class="text-2xl">{dbEmoji}</span>
               <div>
                  <h3 class="text-[10px] uppercase font-black tracking-[0.2em] text-[#AD946D]">PERFIL VERIFICADO POR FIESTASGUATEMALA.COM</h3>
                  <p class="text-[9px] text-white/70 italic mt-0.5">La información de contacto y precios son reales y vigentes.</p>
               </div>
             </div>

             <p class="text-xl md:text-2xl leading-relaxed italic font-light font-serif">
               "{p.descripcion || `Brindando el mejor servicio de ${categoriaLimpia} en todo ${p.municipio} y sus alrededores.`}"
             </p>
          </div>
        </div>
      </div>

      {vecinos.length > 0 && (
        <section class="mt-28">
          <h2 class="text-3xl font-serif text-[#243447] mb-12 text-center italic">También te recomendamos en {p.municipio}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
            {vecinos.map(v => (
              <a href={`/${categoriaSlug}/${v.slug}`} class="group no-underline">
                <div class="h-64 rounded-[40px] overflow-hidden mb-6 shadow-lg border-4 border-white transition-transform group-hover:rotate-2">
                  <img src={v.imagen_url || '/placeholder.jpg'} class="w-full h-full object-cover group-hover:scale-110 transition-duration-700" alt={v.nombre} loading="lazy" />
                </div>
                <h4 class="font-serif text-[#243447] text-2xl mb-1 group-hover:text-[#a68a56] transition-colors">{v.nombre}</h4>
                <p class="text-[11px] text-[#a68a56] font-black uppercase tracking-widest">Desde Q{v.precio_desde}</p>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
    <Footer />
  </div>
</Layout>

<script define:vars={{ pId: p.id }}>
  const track = (tipo) => {
    fetch('/api/click', { 
      method: 'POST', 
      headers: { 'Content-Type': 'application/json' }, 
      body: JSON.stringify({ proveedorId: pId, tipo }),
      keepalive: true 
    }).catch(() => {});
  };
  track('vista_perfil');
  document.getElementById('btnWhatsApp')?.addEventListener('click', () => track('click_whatsapp'));
  document.getElementById('btnCall')?.addEventListener('click', () => track('click_llamada'));
</script>