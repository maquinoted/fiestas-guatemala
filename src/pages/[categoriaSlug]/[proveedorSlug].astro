---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug, proveedorSlug } = Astro.params;

let p = null;
let vecinos = [];

try {
  const { rows } = await sql`
    SELECT p.*, c.icono as categoria_emoji, c.nombre as categoria_nombre
    FROM proveedores p
    LEFT JOIN categorias c ON p.categoria_slug = c.slug
    WHERE p.slug = ${proveedorSlug} 
    AND p.activo = true 
    LIMIT 1
  `;
  p = rows[0];

  if (p) {
    const otrosVecinos = await sql`
      SELECT nombre, slug, imagen_url, precio_desde, categoria_slug
      FROM proveedores 
      WHERE categoria_slug = ${categoriaSlug} 
      AND municipio = ${p.municipio} 
      AND slug != ${p.slug} 
      AND activo = true 
      LIMIT 3
    `;
    vecinos = otrosVecinos.rows || [];
  }
} catch (e) { console.error(e); }

if (!p) return Astro.redirect('/404');

const dbEmoji = p.categoria_emoji || '✨';
const tituloSEO = `${dbEmoji} ${p.nombre} en ${p.municipio} | Q${p.precio_desde} | FiestasGuatemala.com`;
const descriptionSEO = `${dbEmoji} Contrata a ${p.nombre} en ${p.municipio}. Precios reales desde Q${p.precio_desde}. ✅ Perfil Verificado por Fiestas Guatemala.`;
const fotoFinal = p.imagen_url || '/placeholder.jpg';
const numeroWhatsApp = p.whatsapp || p.telefono;
const whatsappLink = `https://wa.me/502${numeroWhatsApp}?text=${encodeURIComponent(`Hola ${p.nombre}, vi tu perfil en FiestasGuatemala.com...`)}`;
---

<Layout title={tituloSEO} description={descriptionSEO}>
  <link rel="canonical" href={`https://fiestasguatemala.com/${categoriaSlug}/${proveedorSlug}`} slot="head" />
  
  <div class="bg-[#f8f7f4] min-h-screen font-sans text-[#243447]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 sm:px-6 pt-4 pb-20">
      
      <section class="mb-10 text-center md:text-left">
        <div class="inline-flex items-center gap-2 bg-[#243447] text-white text-[9px] font-black px-4 py-2 rounded-full uppercase tracking-[0.2em] mb-6 shadow-lg">
          <span class="text-[#AD946D]">★</span> Perfil Verificado
        </div>

        <h1 class="text-6xl md:text-9xl font-serif text-[#243447] leading-[0.9] tracking-tighter mb-4 italic">
          {p.nombre}
        </h1>

        <p class="text-lg md:text-2xl font-bold text-[#AD946D] flex items-center justify-center md:justify-start gap-2">
          <span class="text-2xl">📍</span> {p.municipio}, {p.departamento}
        </p>
      </section>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        
        <div class="lg:col-span-7">
          <div class="rounded-[40px] md:rounded-[60px] overflow-hidden shadow-2xl border-[6px] border-white h-[450px] md:h-[650px] relative">
            <img src={fotoFinal} class="w-full h-full object-cover" alt={p.nombre} fetchpriority="high" />
            
            <div class="absolute bottom-6 left-6 bg-white/90 backdrop-blur-md px-6 py-3 rounded-3xl border border-white shadow-xl">
              <p class="text-[10px] font-black uppercase text-[#8b7355] tracking-widest">{dbEmoji} {p.categoria_nombre}</p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-5 space-y-6">
          <div class="bg-white p-8 md:p-12 rounded-[50px] shadow-2xl border border-white flex flex-col justify-between h-full">
            <div>
              <p class="text-[11px] uppercase tracking-[0.3em] text-gray-400 font-black mb-2">Presupuesto sugerido</p>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-serif text-[#AD946D]">Q</span>
                <span class="text-7xl md:text-8xl font-serif text-[#AD946D] leading-none">{p.precio_desde}</span>
              </div>
              <p class="text-[10px] text-gray-400 mt-2 font-medium italic">*Sujeto a cambios según fecha y lugar del evento.</p>
            </div>

            <div class="mt-12 space-y-4">
              <a href={whatsappLink} id="btnWhatsApp" class="bg-[#25D366] text-white flex items-center justify-center gap-4 py-6 rounded-[30px] font-black text-sm uppercase tracking-widest shadow-xl hover:scale-[1.03] transition-all">
                <span class="text-2xl">💬</span> WhatsApp Directo
              </a>
              <a href={`tel:+502${p.telefono}`} id="btnCall" class="bg-[#243447] text-white flex items-center justify-center gap-4 py-6 rounded-[30px] font-black text-sm uppercase tracking-widest shadow-lg hover:bg-black transition-all">
                <span class="text-2xl">📞</span> Llamar Ahora
              </a>
            </div>
          </div>

          <div class="bg-[#243447] p-10 rounded-[50px] text-white shadow-xl">
             <h3 class="text-[10px] uppercase font-black tracking-widest text-[#AD946D] mb-4">Sobre el servicio</h3>
             <p class="text-xl md:text-2xl leading-relaxed italic font-light opacity-90">
               "{p.descripcion || `Brindando excelencia en cada detalle para tus eventos en ${p.municipio}.`}"
             </p>
          </div>
        </div>
      </div>

      {vecinos.length > 0 && (
        <section class="mt-32">
          <h2 class="text-4xl font-serif text-[#243447] mb-12 italic text-center md:text-left">Otros recomendados en {p.municipio}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
            {vecinos.map(v => (
              <a href={`/${categoriaSlug}/${v.slug}`} class="group no-underline">
                <div class="h-72 rounded-[45px] overflow-hidden mb-6 shadow-lg border-4 border-white transition-all group-hover:shadow-2xl">
                  <img src={v.imagen_url || '/placeholder.jpg'} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt={v.nombre} />
                </div>
                <h4 class="font-serif text-[#243447] text-2xl mb-1">{v.nombre}</h4>
                <p class="text-[11px] text-[#AD946D] font-black uppercase tracking-widest">Desde Q{v.precio_desde}</p>
              </a>
            ))}
          </div>
        </section>
      )}

    </main>
    <Footer />
  </div>
</Layout>

<script define:vars={{ pId: p.id }}>
  const track = (tipo) => {
    fetch('/api/click', { 
      method: 'POST', 
      headers: { 'Content-Type': 'application/json' }, 
      body: JSON.stringify({ proveedorId: pId, tipo }),
      keepalive: true 
    }).catch(() => {});
  };
  track('vista_perfil');
  document.getElementById('btnWhatsApp')?.addEventListener('click', () => track('click_whatsapp'));
  document.getElementById('btnCall')?.addEventListener('click', () => track('click_llamada'));
</script>