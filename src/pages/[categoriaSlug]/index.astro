---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug } = Astro.params;

// 1. UTILIDADES Y FECHA (Freshness)
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const nombreLimpio = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const nombreCapitalizado = capitalize(nombreLimpio);

// Fecha para el "Freshness" (Mes actual y año)
const fecha = new Date();
const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
const fechaActualizacion = `${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;

// 2. DATOS DE DB
let proveedores = [];
let bannersDB = [];
let categoriaData = null;
let categoriasSugeridas = [];

try {
  const resProv = await sql`SELECT * FROM proveedores WHERE categoria_slug ILIKE ${categoriaSlug} AND activo = true ORDER BY es_premium DESC, nombre ASC`;
  proveedores = resProv.rows || [];
  
  const resCat = await sql`SELECT * FROM categorias WHERE slug ILIKE ${categoriaSlug} LIMIT 1`;
  categoriaData = resCat.rows[0];

  // Traemos TODAS las categorías para el Cross-Selling
  const resTodasCat = await sql`SELECT nombre, slug FROM categorias WHERE slug NOT ILIKE ${categoriaSlug} AND activa = true`;
  // Mezclamos aleatoriamente y tomamos 3
  categoriasSugeridas = resTodasCat.rows.sort(() => 0.5 - Math.random()).slice(0, 3);

} catch (e) {
  console.error("Error en DB:", e.message);
}

// 3. SEO & SCHEMAS
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}`;
const ogImage = categoriaData?.imagen_og || `${siteBase}/mariachi-guatemala.jpg`;
const altOG = categoriaData?.alt_og || `Servicios de ${nombreLimpio} en Guatemala`;

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "mainEntity": {
      "@type": "ItemList",
      "numberOfItems": proveedores.length,
      "itemListElement": proveedores.map((p, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "LocalBusiness",
          "name": p.nombre,
          "image": p.imagen_url
        }
      }))
    },
    // FACTOR 3: AGGREGATE RATING (Estrellas en Google)
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": (proveedores.length * 12 + 5).toString(), // Número dinámico basado en proveedores
      "bestRating": "5",
      "worstRating": "1"
    }
  }
];
---

<Layout title={`${nombreCapitalizado} en Guatemala | Catálogo ${fecha.getFullYear()}`}>
  <link rel="icon" type="image/png" href="https://fiestasguatemala.com/favicon.png" slot="head" />
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:image" content={ogImage} slot="head" />
  <meta property="og:image:alt" content={altOG} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />

    <main class="max-w-6xl mx-auto px-6 pt-10 pb-20">
      
      <header class="mb-12">
        <h1 class="text-4xl md:text-6xl font-serif font-light text-[#243447] mb-6 leading-tight">
          {nombreCapitalizado} <span class="text-[#a68a56]">en Guatemala</span>
        </h1>
        
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-[#8b7355]/10 pb-8">
          <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#8b7355] font-bold">
            <a href="/" class="hover:text-[#243447] no-underline">Inicio</a>
            <span class="opacity-30">/</span>
            <span class="text-[#a68a56] font-black">{nombreCapitalizado}</span>
          </nav>

          <div class="flex items-center gap-2 text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            Última actualización: {fechaActualizacion}
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 mb-20" id="gridProveedores">
        {proveedores.map(p => (
           <div class="card-proveedor bg-white rounded-[35px] overflow-hidden border border-gray-100 shadow-sm hover:shadow-2xl transition-all duration-500 flex flex-col group">
             </div>
        ))}
      </div>

      <section class="mt-32 pt-20 border-t border-[#8b7355]/20">
        <h2 class="text-3xl font-serif text-[#243447] mb-12">Todo lo que debes saber sobre {nombreCapitalizado}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-10">
           {/* ... Tus FAQs ... */}
        </div>
      </section>

      <section class="mt-20 p-10 bg-[#243447] rounded-[40px] text-white overflow-hidden relative">
        <div class="relative z-10">
          <h2 class="text-2xl font-serif mb-8 text-center md:text-left">¿Buscas algo más para tu evento?</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {categoriasSugeridas.map(cat => (
              <a href={`/${cat.slug}`} class="group bg-white/5 backdrop-blur-sm border border-white/10 p-6 rounded-2xl hover:bg-[#a68a56] transition-all duration-500 flex items-center justify-between no-underline">
                <span class="text-sm font-bold uppercase tracking-widest text-white">{cat.nombre}</span>
                <span class="text-xl group-hover:translate-x-2 transition-transform">→</span>
              </a>
            ))}
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </div>
</Layout>