---
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug } = Astro.params;

// Traemos todos los proveedores de esa categoría
const { rows: proveedores } = await sql`
  SELECT * FROM proveedores WHERE categoria_slug = ${categoriaSlug} ORDER BY es_premium DESC, nombre ASC
`;

// Simulación de Banners (Aquí podrías luego traerlos de otra tabla de la DB)
const banners = [
  {
    posicion: 2, // Aparecerá después de la 2da tarjeta
    img: "https://images.unsplash.com/photo-1504196606672-aef5c9cefc92?q=80&w=1000",
    url: "https://wa.me/50200000000",
    titulo: "¡Anúnciate Aquí!",
    desc: "Llega a más de 10,000 personas al mes buscando servicios en Guate."
  },
  {
    posicion: 5, // Aparecerá después de la 5ta tarjeta
    img: "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?q=80&w=1000",
    url: "https://fiestasguatemala.com/contacto",
    titulo: "Paquetes Premium",
    desc: "Sube al primer lugar y duplica tus cotizaciones hoy mismo."
  }
];
---

<Layout title={`Mejores ${categoriaSlug} en Guatemala`}>
  <main class="max-w-6xl mx-auto px-4 py-12">
    
    <section class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-4xl font-black text-[#243447] capitalize mb-2">{categoriaSlug}</h1>
        <p class="text-gray-500 font-medium">Hemos encontrado <span class="text-[#AD946D] font-bold">{proveedores.length}</span> proveedores disponibles</p>
      </div>

      <div class="relative w-full md:w-96">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 opacity-40">📍</span>
        <input 
          type="text" 
          id="deptSearch" 
          placeholder="Busca por municipio o departamento..." 
          class="w-full pl-12 pr-4 py-4 rounded-2xl border border-gray-200 shadow-sm outline-none focus:ring-2 focus:ring-[#AD946D]/50 transition-all text-sm font-medium"
        />
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="gridProveedores">
      {proveedores.map((p, index) => {
        const bannerEncontrado = banners.find(b => b.posicion === index);
        
        return (
          <>
            {/* INYECCIÓN DE BANNER PUBLICITARIO */}
            {bannerEncontrado && (
              <a href={bannerEncontrado.url} target="_blank" class="card-banner group relative bg-[#243447] rounded-[30px] overflow-hidden shadow-xl border-4 border-[#AD946D]/30 flex flex-col justify-end p-6 min-h-[350px]">
                <img src={bannerEncontrado.img} class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-105 transition-transform duration-700" alt="Publicidad" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#243447] via-[#243447]/20 to-transparent"></div>
                <div class="relative z-10">
                  <span class="bg-[#AD946D] text-white text-[9px] font-black px-3 py-1 rounded-full uppercase tracking-widest mb-3 inline-block">Patrocinado</span>
                  <h3 class="text-2xl font-bold text-white mb-2">{bannerEncontrado.titulo}</h3>
                  <p class="text-gray-300 text-sm mb-4 leading-relaxed">{bannerEncontrado.desc}</p>
                  <div class="inline-block bg-white text-[#243447] px-6 py-2 rounded-full font-bold text-xs uppercase tracking-tighter">Más info</div>
                </div>
              </a>
            )}

            {/* TARJETA DE PROVEEDOR */}
            <div 
              class="card-proveedor bg-white rounded-[30px] shadow-md border border-gray-100 overflow-hidden hover:shadow-2xl transition-all duration-500 flex flex-col" 
              data-depto={p.departamento?.toLowerCase()}
              data-muni={p.municipio?.toLowerCase()}
            >
              <div class="h-48 relative overflow-hidden">
                <img 
                  src={p.imagen_url || '/placeholder-vendor.jpg'} 
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                  alt={p.nombre} 
                />
                <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full shadow-sm">
                  <span class="text-[10px] font-bold text-gray-700 uppercase tracking-tight">
                    📍 {p.municipio ? `${p.municipio}, ` : ''}{p.departamento}
                  </span>
                </div>
              </div>
              
              <div class="p-6 flex flex-col flex-1">
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-[#243447] mb-2">{p.nombre}</h3>
                  <p class="text-gray-500 text-[13px] line-clamp-3 mb-6 leading-relaxed">
                    {p.descripcion}
                  </p>
                </div>
                
                <div class="flex items-center justify-between pt-5 border-t border-gray-100">
                  <div>
                    <p class="text-[9px] text-gray-400 font-bold uppercase tracking-tighter italic">Cotiza desde</p>
                    <p class="text-xl font-black text-[#AD946D]">Q{p.precio_desde}</p>
                  </div>
                  <a href={`/${categoriaSlug}/${p.slug}`} class="bg-[#243447] text-white px-6 py-3 rounded-2xl font-bold text-xs hover:bg-black transition-all hover:scale-105 active:scale-95 shadow-lg shadow-slate-200">
                    Ver Perfil
                  </a>
                </div>
              </div>
            </div>
          </>
        )
      })}
    </div>

    <div id="noResults" class="hidden text-center py-24 bg-white rounded-[40px] border-2 border-dashed border-gray-200 mt-10">
      <div class="text-5xl mb-4">📍</div>
      <p class="text-[#243447] font-bold text-xl mb-2">No hay resultados en esta zona</p>
      <p class="text-gray-400 font-medium text-sm">Prueba buscando en departamentos aledaños <br/>o escribe el nombre de un municipio cercano.</p>
    </div>

  </main>
</Layout>

<script>
  const input = document.getElementById('deptSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.card-proveedor');
  const banners = document.querySelectorAll('.card-banner');
  const grid = document.getElementById('gridProveedores');
  const noResults = document.getElementById('noResults');

  function filterResults(searchTerm: string) {
    let count = 0;
    const term = searchTerm.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();

    cards.forEach(card => {
      const el = card as HTMLElement;
      const depto = el.dataset.depto || "";
      const muni = el.dataset.muni || "";
      
      if (depto.includes(term) || muni.includes(term)) {
        el.style.display = 'flex';
        count++;
      } else {
        el.style.display = 'none';
      }
    });

    // Ocultamos banners si el usuario está filtrando activamente (para no estorbar)
    banners.forEach(b => {
      (b as HTMLElement).style.display = term.length > 0 ? 'none' : 'flex';
    });

    if (count === 0) {
      grid?.classList.add('hidden');
      noResults?.classList.remove('hidden');
    } else {
      grid?.classList.remove('hidden');
      noResults?.classList.add('hidden');
    }
  }

  input?.addEventListener('input', (e) => filterResults((e.target as HTMLInputElement).value));

  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const initialLoc = params.get('ubicacion');
    if (initialLoc) {
      const decodedLoc = initialLoc.replace(/-/g, ' ');
      input.value = decodedLoc;
      filterResults(decodedLoc);
    }
  });
</script>