---
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug } = Astro.params;

// 1. Traemos los proveedores ordenados: Primero los Premium, luego por Nombre
const { rows: proveedores } = await sql`
  SELECT * FROM proveedores WHERE categoria_slug = ${categoriaSlug} ORDER BY es_premium DESC, nombre ASC
`;

// 2. Traemos los BANNERS de la base de datos para esta categoría
const { rows: bannersDB } = await sql`
  SELECT * FROM banners WHERE categoria_slug = ${categoriaSlug} AND activo = true ORDER BY posicion ASC
`;
---

<Layout title={`Mejores ${categoriaSlug} en Guatemala`}>
  <main class="max-w-6xl mx-auto px-4 py-12">
    
    <section class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-4xl font-black text-[#243447] capitalize mb-2">{categoriaSlug}</h1>
        <p class="text-gray-500 font-medium">Hemos encontrado <span class="text-[#AD946D] font-bold">{proveedores.length}</span> proveedores</p>
      </div>

      <div class="relative w-full md:w-96">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 opacity-40">📍</span>
        <input type="text" id="deptSearch" placeholder="Busca por municipio o departamento..." class="w-full pl-12 pr-4 py-4 rounded-2xl border border-gray-200 shadow-sm outline-none focus:ring-2 focus:ring-[#AD946D]/50 text-sm font-medium"/>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="gridProveedores">
      
      {proveedores.map((p, index) => {
        const banner = bannersDB.find(b => b.posicion === index);

        return (
          <>
            {/* INYECCIÓN DE BANNER (PUBLICIDAD) */}
            {banner && (
              <a href={banner.enlace_url} target="_blank" class="card-banner group relative bg-[#243447] rounded-[30px] overflow-hidden shadow-xl border-4 border-[#AD946D]/30 flex flex-col justify-end p-6 min-h-[350px]">
                <img src={banner.imagen_url} class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-105 transition-transform duration-700" alt={banner.titulo} />
                <div class="absolute inset-0 bg-gradient-to-t from-[#243447] via-[#243447]/20 to-transparent"></div>
                <div class="relative z-10">
                  <span class="bg-[#AD946D] text-white text-[9px] font-black px-3 py-1 rounded-full uppercase tracking-widest mb-3 inline-block">Patrocinado</span>
                  <h3 class="text-2xl font-bold text-white mb-2">{banner.titulo}</h3>
                  <p class="text-gray-300 text-sm mb-4 leading-relaxed">{banner.descripcion}</p>
                  <div class="inline-block bg-white text-[#243447] px-6 py-2 rounded-full font-bold text-xs uppercase tracking-tighter">Más info</div>
                </div>
              </a>
            )}

            {/* TARJETA DE PROVEEDOR (CON LOGICA VIP Y DATA-ID PARA MÉTRICAS) */}
            <div 
              class={`card-proveedor rounded-[30px] shadow-md border transition-all duration-500 flex flex-col relative
              ${p.es_premium 
                ? 'bg-white border-[#AD946D] ring-4 ring-[#AD946D]/10 scale-[1.02] z-10' 
                : 'bg-white border-gray-100'}`}
              data-depto={p.departamento?.toLowerCase()}
              data-muni={p.municipio?.toLowerCase()}
              data-proveedor-id={p.id} 
            >
              <div class="h-48 relative overflow-hidden">
                <img src={p.imagen_url || '/placeholder.jpg'} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt={p.nombre} />
                
                {p.es_premium && (
                  <div class="absolute top-4 left-4 bg-[#243447] text-white text-[9px] font-black px-3 py-1.5 rounded-full uppercase tracking-widest shadow-xl flex items-center gap-1.5 border border-[#AD946D]/50">
                    <svg class="w-3 h-3 text-[#AD946D]" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    VERIFICADO
                  </div>
                )}

                <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full shadow-sm text-[10px] font-bold">
                  📍 {p.municipio ? `${p.municipio}, ` : ''}{p.departamento}
                </div>
              </div>

              <div class="p-6 flex flex-col flex-1">
                <h3 class={`text-xl font-bold mb-2 ${p.es_premium ? 'text-[#AD946D]' : 'text-[#243447]'}`}>
                  {p.nombre}
                </h3>
                <p class="text-gray-500 text-[13px] line-clamp-3 mb-6 flex-1 italic">
                  {p.descripcion}
                </p>
                <div class="flex items-center justify-between pt-5 border-t border-gray-100">
                  <div>
                    <p class="text-[9px] text-gray-400 font-bold uppercase tracking-tighter italic">Cotiza desde</p>
                    <p class="text-xl font-black text-[#AD946D]">Q{p.precio_desde}</p>
                  </div>
                  <a 
                    href={`/${categoriaSlug}/${p.slug}`} 
                    class={`px-6 py-3 rounded-2xl font-bold text-xs transition-all shadow-lg 
                    ${p.es_premium 
                      ? 'bg-[#AD946D] text-white hover:bg-[#8e7858] shadow-[#AD946D]/20' 
                      : 'bg-[#243447] text-white hover:bg-black shadow-slate-200'}`}
                  >
                    Ver Perfil
                  </a>
                </div>
              </div>
            </div>
          </>
        );
      })}
    </div>

    <div id="noResults" class="hidden text-center py-24 bg-white rounded-[40px] border-2 border-dashed border-gray-200 mt-10">
      <p class="text-[#243447] font-bold text-xl">No hay resultados en esta zona</p>
    </div>
  </main>
</Layout>

<script>
  const input = document.getElementById('deptSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.card-proveedor');
  const banners = document.querySelectorAll('.card-banner');
  const grid = document.getElementById('gridProveedores');
  const noResults = document.getElementById('noResults');

  // REGISTRO DE IMPRESIONES (CTR LISTADO)
  window.addEventListener('DOMContentLoaded', () => {
    const visibleCards = document.querySelectorAll('[data-proveedor-id]');
    const cat = window.location.pathname.split('/')[1];

    visibleCards.forEach(card => {
      const id = card.getAttribute('data-proveedor-id');
      if (id) {
        fetch('/api/click', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ proveedorId: id, tipo: 'impresion_listado', categoria: cat })
        });
      }
    });
  });

  function filterResults(searchTerm: string) {
    let count = 0;
    const term = searchTerm.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();

    cards.forEach(card => {
      const el = card as HTMLElement;
      const depto = el.dataset.depto || "";
      const muni = el.dataset.muni || "";
      
      if (depto.includes(term) || muni.includes(term)) {
        el.style.display = 'flex';
        count++;
      } else {
        el.style.display = 'none';
      }
    });

    banners.forEach(b => {
      (b as HTMLElement).style.display = term.length > 0 ? 'none' : 'flex';
    });

    if (count === 0) {
      grid?.classList.add('hidden');
      noResults?.classList.remove('hidden');
    } else {
      grid?.classList.remove('hidden');
      noResults?.classList.add('hidden');
    }
  }

  input?.addEventListener('input', (e) => filterResults((e.target as HTMLInputElement).value));

  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const initialLoc = params.get('ubicacion');
    if (initialLoc) {
      const decodedLoc = initialLoc.replace(/-/g, ' ');
      input.value = decodedLoc;
      filterResults(decodedLoc);
    }
  });
</script>