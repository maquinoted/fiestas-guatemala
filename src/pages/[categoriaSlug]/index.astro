---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug } = Astro.params;

// 1. UTILIDADES
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const nombreLimpio = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const nombreCapitalizado = capitalize(nombreLimpio);

const fecha = new Date();
const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
const fechaActualizacion = `${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;

// 2. DATOS DE DB
let proveedores = [];
let todasLasCategorias = [];
let categoriaData = null;

try {
  // Búsqueda de proveedores
  const resProv = await sql`SELECT * FROM proveedores WHERE categoria_slug ILIKE ${categoriaSlug} AND activo = true ORDER BY es_premium DESC, nombre ASC`;
  proveedores = resProv.rows || [];
  
  // Datos de la categoría actual
  const resCat = await sql`SELECT * FROM categorias WHERE slug ILIKE ${categoriaSlug} LIMIT 1`;
  categoriaData = resCat.rows[0];

  // CORRECCIÓN: Intentamos con "activo" (masculino) que es el estándar que usamos en proveedores
  const resTodas = await sql`SELECT nombre, slug FROM categorias WHERE activo = true ORDER BY nombre ASC`;
  todasLasCategorias = resTodas.rows || [];

  // SI SIGUE VACÍO: Probamos traer todas sin filtro para ver si el problema es la columna 'activo'
  if (todasLasCategorias.length === 0) {
    const backupCat = await sql`SELECT nombre, slug FROM categorias ORDER BY nombre ASC`;
    todasLasCategorias = backupCat.rows || [];
  }
} catch (e) {
  console.error("Error técnico en DB:", e.message);
}

// 3. SEO
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}`;
const titleSEO = `${nombreCapitalizado} en Guatemala | Catálogo Actualizado ${fecha.getFullYear()}`;
const descriptionSEO = `¿Buscas ${nombreLimpio} en Guatemala? Encuentra proveedores verificados con precios reales a ${fechaActualizacion}. Fotos reales y contacto directo.`;

const ogImage = categoriaData?.imagen_og || `${siteBase}/mariachi-guatemala.jpg`;
---

<Layout title={titleSEO} description={descriptionSEO}>
  <link rel="canonical" href={canonicalURL} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify({})} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />

    <main class="max-w-6xl mx-auto px-6 pt-10 pb-20">
      
      <header class="mb-12">
        <h1 class="text-4xl md:text-6xl font-serif font-light text-[#243447] mb-4 leading-tight">
          {nombreCapitalizado} <span class="text-[#a68a56]">en Guatemala</span>
        </h1>

        <div class="flex items-center gap-2 text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold mb-4">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Actualizado: {fechaActualizacion}
        </div>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-[#8b7355]/10 pb-8">
          <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#8b7355] font-bold">
            <a href="/" class="hover:text-[#243447] no-underline">Inicio</a>
            <span class="opacity-30">/</span>
            <span class="text-[#a68a56] font-black">{nombreCapitalizado}</span>
          </nav>

          <div class="relative w-full md:w-[350px]">
            <div class="flex items-center bg-[#243447] p-1 rounded-full shadow-lg">
               <span class="pl-4 text-white/40 text-sm">📍</span>
               <input type="text" id="deptSearch" placeholder="Busca por destino" class="flex-1 bg-transparent pl-2 pr-4 py-2 text-white outline-none placeholder:text-white text-xs font-light" />
            </div>
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 mb-24" id="gridProveedores">
        {proveedores.map(p => {
          const urlPerfil = `/${categoriaSlug}/${p.slug}`;
          // 1. REVISIÓN DE IMAGEN: Si no sale la de la DB, revisa si la columna se llama 'imagen' o 'foto'
          const fotoFinal = p.imagen_url || p.imagen || p.foto || '/placeholder.jpg';

          return (
            <div class="card-proveedor bg-white rounded-[35px] overflow-hidden border border-gray-100 shadow-sm flex flex-col group" data-depto={p.departamento?.toLowerCase()}>
              <a href={urlPerfil} class="relative block h-64 overflow-hidden">
                <img src={fotoFinal} alt={p.nombre} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
                
                {/* 3. PALABRA VERIFICADO (Restaurada) */}
                {p.es_premium && (
                  <div class="absolute bottom-4 right-4 bg-white/95 px-3 py-1.5 rounded-full flex items-center gap-1.5 shadow-sm border border-gray-100">
                    <span class="text-[#a68a56] text-[10px]">★</span>
                    <span class="text-[8px] font-black uppercase tracking-widest text-[#243447]">Verificado</span>
                  </div>
                )}
              </a>

              <div class="p-7 flex flex-col flex-1">
                <a href={urlPerfil} class="no-underline"><h2 class="font-serif text-xl text-[#243447] mb-2">{p.nombre}</h2></a>
                <div class="text-[#8b7355] text-[10px] font-bold uppercase mb-6 tracking-wider">📍 {p.municipio || p.departamento}</div>
                
                <div class="flex items-center justify-between pt-6 border-t border-gray-50 mt-auto">
                   <div class="flex flex-col">
                      <span class="text-[8px] uppercase text-gray-400 font-bold tracking-tighter">Desde</span>
                      <span class="text-xl font-serif text-[#a68a56]">Q{p.precio_desde}</span>
                   </div>
                   <a href={urlPerfil} class="bg-[#243447] text-white px-6 py-2.5 rounded-full text-[10px] uppercase font-bold hover:bg-[#a68a56] transition-colors no-underline">Ver Perfil</a>
                </div>
              </div>
           </div>
          )
        })}
      </div>

      <section class="mt-20 p-10 bg-[#243447] rounded-[40px] text-white relative shadow-2xl overflow-hidden">
        <h2 class="text-2xl font-serif mb-10 text-center">Explora todas nuestras categorías</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-y-4 gap-x-12 relative z-10">
          {todasLasCategorias.length > 0 ? todasLasCategorias.map(cat => (
            <a href={`/${cat.slug}`} class="text-white/70 hover:text-[#a68a56] transition-colors text-sm flex items-center gap-3 no-underline group">
              <span class="text-[#a68a56] text-[8px] group-hover:scale-125 transition-transform">◆</span>
              <span class="border-b border-transparent group-hover:border-[#a68a56]">{cat.nombre}</span>
            </a>
          )) : (
            <p class="text-white/30 italic text-xs col-span-full text-center">No se encontraron categorías adicionales.</p>
          )}
        </div>
        <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-[#a68a56] rounded-full blur-[100px] opacity-10"></div>
      </section>

    </main>
    <Footer />
  </div>
</Layout>