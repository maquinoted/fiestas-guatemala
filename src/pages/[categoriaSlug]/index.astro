---
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug } = Astro.params;

// Traemos todos los proveedores de esa categoría
const { rows: proveedores } = await sql`
  SELECT * FROM proveedores WHERE categoria_slug = ${categoriaSlug} ORDER BY es_premium DESC, nombre ASC
`;

// Extraemos la lista de departamentos únicos para las sugerencias del buscador
const departamentos = [...new Set(proveedores.map(p => p.departamento))].sort();
---

<Layout title={`Mejores ${categoriaSlug} en Guatemala`}>
  <main class="max-w-6xl mx-auto px-4 py-12">
    
    <section class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-4xl font-black text-[#243447] capitalize mb-2">{categoriaSlug}</h1>
        <p class="text-gray-500 font-medium">Hemos encontrado <span class="text-[#AD946D]">{proveedores.length}</span> proveedores disponibles</p>
      </div>

      <div class="relative w-full md:w-96">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 opacity-40">📍</span>
        <input 
          type="text" 
          id="deptSearch" 
          placeholder="Filtrar por departamento (ej. Xela, Jutiapa...)" 
          class="w-full pl-12 pr-4 py-4 rounded-2xl border border-gray-200 shadow-sm outline-none focus:ring-2 focus:ring-[#AD946D]/50 transition-all text-sm"
        />
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="gridProveedores">
      {proveedores.map(p => (
        <div class="card-proveedor bg-white rounded-[30px] shadow-md border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300" data-depto={p.departamento.toLowerCase()}>
          <div class="h-40 relative">
            <img src={p.imagen_url} class="w-full h-full object-cover" alt={p.nombre} />
            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full shadow-sm">
              <span class="text-[10px] font-bold text-gray-700 uppercase tracking-tight">📍 {p.departamento}</span>
            </div>
          </div>
          
          <div class="p-6">
            <h3 class="text-xl font-bold text-[#243447] mb-1">{p.nombre}</h3>
            <p class="text-gray-500 text-[13px] line-clamp-2 mb-4 leading-relaxed">{p.descripcion}</p>
            
            <div class="flex items-center justify-between pt-4 border-t border-gray-50">
              <div>
                <p class="text-[10px] text-gray-400 font-bold uppercase">Precio desde</p>
                <p class="text-lg font-black text-[#AD946D]">Q{p.precio_desde}</p>
              </div>
              <a href={`/${categoriaSlug}/${p.slug}`} class="bg-[#243447] text-white px-5 py-2.5 rounded-xl font-bold text-xs hover:bg-black transition-colors">
                Ver Perfil
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div id="noResults" class="hidden text-center py-20 bg-white rounded-[40px] border-2 border-dashed border-gray-200 mt-6">
      <p class="text-gray-400 font-medium">No encontramos proveedores en ese departamento. <br/>Intenta buscar otro lugar.</p>
    </div>

  </main>
</Layout>

<script>
  const input = document.getElementById('deptSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.card-proveedor');
  const grid = document.getElementById('gridProveedores');
  const noResults = document.getElementById('noResults');

  // Función de búsqueda en tiempo real
  input?.addEventListener('input', (e) => {
    const searchTerm = (e.target as HTMLInputElement).value.toLowerCase().trim();
    let count = 0;

    cards.forEach(card => {
      const depto = (card as HTMLElement).dataset.depto;
      if (depto?.includes(searchTerm)) {
        (card as HTMLElement).style.display = 'block';
        count++;
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    // Mostrar mensaje si no hay resultados
    if (count === 0) {
      grid?.classList.add('hidden');
      noResults?.classList.remove('hidden');
    } else {
      grid?.classList.remove('hidden');
      noResults?.classList.add('hidden');
    }
  });
</script>