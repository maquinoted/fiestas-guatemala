---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug } = Astro.params;

// Utilidades
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const nombreLimpio = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const nombreCapitalizado = capitalize(nombreLimpio);

// Freshness
const fecha = new Date();
const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
const fechaActualizacion = `${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;

// 1. Datos de DB
let proveedores = [];
let bannersDB = [];
let categoriaData = null;
let todasLasCategorias = [];

try {
  // Proveedores de esta categoría
  const resProv = await sql`SELECT * FROM proveedores WHERE categoria_slug ILIKE ${categoriaSlug} AND activo = true ORDER BY es_premium DESC, nombre ASC`;
  proveedores = resProv.rows || [];
  
  // Info de la categoría actual
  const resCat = await sql`SELECT * FROM categorias WHERE slug ILIKE ${categoriaSlug} LIMIT 1`;
  categoriaData = resCat.rows[0];

  // TODAS las categorías para el listado final (ordenadas alfabéticamente)
  const resTodas = await sql`SELECT nombre, slug FROM categorias WHERE activa = true ORDER BY nombre ASC`;
  todasLasCategorias = resTodas.rows || [];

  // Banners
  const resBann = await sql`SELECT * FROM banners WHERE categoria_slug ILIKE ${categoriaSlug} AND activo = true ORDER BY posicion ASC`;
  bannersDB = resBann.rows || [];
} catch (e) {
  console.error("Error en DB:", e.message);
}

// 2. SEO & METAS
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}`;
const titleSEO = `${nombreCapitalizado} en Guatemala | Catálogo Actualizado ${fecha.getFullYear()}`;
const descriptionSEO = `Encuentra los mejores ${nombreLimpio} en Guatemala. Directorio verificado con precios actualizados y contacto directo.`;
const ogImage = categoriaData?.imagen_og || `${siteBase}/mariachi-guatemala.jpg`;
const altOG = categoriaData?.alt_og || `Servicios de ${nombreLimpio} en Guatemala`;

// 3. SCHEMAS
const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": titleSEO,
    "url": canonicalURL,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": (proveedores.length * 5 + 12).toString()
    }
  }
];
---

<Layout title={titleSEO} description={descriptionSEO}>
  <link rel="icon" type="image/png" href="https://fiestasguatemala.com/favicon.png" slot="head" />
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:image" content={ogImage} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />

    <main class="max-w-6xl mx-auto px-6 pt-10 pb-20">
      
      <header class="mb-12">
        <h1 class="text-4xl md:text-6xl font-serif font-light text-[#243447] mb-6 leading-tight">
          {nombreCapitalizado} <span class="text-[#a68a56]">en Guatemala</span>
        </h1>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-[#8b7355]/10 pb-8">
          <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#8b7355] font-bold">
            <a href="/" class="hover:text-[#243447] no-underline">Inicio</a>
            <span class="opacity-30">/</span>
            <span class="text-[#a68a56] font-black">{nombreCapitalizado}</span>
          </nav>

          <div class="flex items-center gap-6">
            <div class="hidden sm:flex items-center gap-2 text-[9px] uppercase tracking-widest text-[#8b7355]/60 font-bold">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
              </span>
              Actualizado: {fechaActualizacion}
            </div>

            <div class="relative w-full md:w-[300px]">
              <div class="flex items-center bg-[#243447] p-1 rounded-full shadow-lg">
                 <span class="pl-4 text-white/40 text-sm">📍</span>
                 <input type="text" id="deptSearch" placeholder="Municipio..." class="flex-1 bg-transparent pl-2 pr-4 py-2 text-white outline-none placeholder:text-white text-xs font-light" />
              </div>
            </div>
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 mb-24" id="gridProveedores">
        {proveedores.length > 0 ? proveedores.map((p) => {
          const urlPerfil = `/${categoriaSlug}/${p.slug}`;
          const fotoFinal = categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : (p.imagen_url || '/placeholder.jpg');

          return (
            <div class="card-proveedor bg-white rounded-[35px] overflow-hidden border border-gray-100 shadow-sm hover:shadow-2xl transition-all duration-500 flex flex-col group" data-depto={p.departamento?.toLowerCase()}>
              <a href={urlPerfil} class="relative h-48 overflow-hidden block">
                <img src={fotoFinal} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" alt={p.nombre} loading="lazy" />
                {p.es_premium && (
                  <div class="absolute bottom-4 right-4 bg-white/95 px-3 py-1.5 rounded-full flex items-center gap-1 shadow-sm">
                    <span class="text-[#a68a56] text-[10px]">★</span>
                    <span class="text-[8px] font-black uppercase tracking-widest text-[#243447]">Verificado</span>
                  </div>
                )}
              </a>

              <div class="p-7 flex flex-col flex-1">
                <a href={urlPerfil} class="no-underline group">
                  <h2 class="font-serif font-light text-xl text-[#243447] mb-1 group-hover:text-[#a68a56] transition-colors leading-tight">{p.nombre}</h2>
                </a>
                <div class="text-[#8b7355] text-[10px] font-bold uppercase tracking-widest mb-4 opacity-70">📍 {p.municipio || p.departamento}</div>
                <p class="text-gray-400 text-[13px] font-light line-clamp-2 italic mb-8">"{p.descripcion}"</p>
                
                <div class="flex items-center justify-between pt-6 border-t border-gray-50 mt-auto">
                  <div>
                    <span class="text-[8px] text-gray-400 uppercase font-black block mb-0.5 tracking-tighter">Desde</span>
                    <span class="text-xl font-serif text-[#a68a56]">Q{p.precio_desde}</span>
                  </div>
                  <a href={urlPerfil} class="text-[9px] font-black uppercase tracking-widest text-white bg-[#243447] px-6 py-3 rounded-full hover:bg-[#a68a56] transition-all no-underline shadow-md">Ver Perfil</a>
                </div>
              </div>
            </div>
          );
        }) : (
          <div class="col-span-full py-20 text-center bg-white rounded-[40px] border-2 border-dashed border-gray-100">
            <span class="text-4xl mb-4 block">✨</span>
            <p class="text-gray-400 font-serif italic text-lg">Estamos preparando los mejores servicios de {nombreCapitalizado} para ti.</p>
          </div>
        )}
      </div>

      <section class="mt-32 pt-20 border-t border-[#8b7355]/20">
        <h2 class="text-3xl font-serif text-[#243447] mb-12">Todo lo que debes saber sobre {nombreCapitalizado}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-10 text-sm text-[#243447]/70 font-light leading-relaxed">
          <div class="space-y-4">
            <h3 class="font-serif text-lg text-[#a68a56]">¿Cómo contratar en FiestasGuatemala.com?</h3>
            <p>Elige al proveedor que mejor se adapte a tu evento y utiliza los botones de contacto directo en su perfil verificado.</p>
          </div>
          <div class="space-y-4">
            <h3 class="font-serif text-lg text-[#a68a56]">¿Tienen cobertura nacional?</h3>
            <p>Nuestros proveedores atienden principalmente en Ciudad de Guatemala, Antigua y departamentos principales.</p>
          </div>
        </div>
      </section>

      <section class="mt-20 p-8 md:p-14 bg-[#243447] rounded-[40px] text-white relative overflow-hidden shadow-2xl">
        <div class="relative z-10">
          <h2 class="text-2xl md:text-3xl font-serif mb-10 text-center">Explora más categorías para tu fiesta</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-12 gap-y-4">
            {todasLasCategorias.map(cat => (
              <a href={`/${cat.slug}`} class="text-white/70 hover:text-[#a68a56] transition-colors text-sm font-light flex items-center gap-3 no-underline group">
                <span class="text-[#a68a56] text-[8px] group-hover:scale-125 transition-transform">◆</span>
                <span class="border-b border-transparent group-hover:border-[#a68a56]">{cat.nombre}</span>
              </a>
            ))}
          </div>
        </div>
        <div class="absolute -top-24 -right-24 w-80 h-80 bg-[#a68a56] rounded-full blur-[120px] opacity-10"></div>
      </section>

    </main>
    <Footer />
  </div>
</Layout>

<script>
  const input = document.getElementById('deptSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.card-proveedor');

  input?.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
    cards.forEach(card => {
      const el = card as HTMLElement;
      const depto = el.dataset.depto || "";
      const match = depto.includes(term);
      el.style.display = match ? 'flex' : 'none';
    });
  });
</script>