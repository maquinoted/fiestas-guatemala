---
import Layout from '../../layouts/Layout.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug } = Astro.params;

// 1. Datos de DB
const { rows: proveedores } = await sql`
  SELECT * FROM proveedores WHERE categoria_slug = ${categoriaSlug} ORDER BY es_premium DESC, nombre ASC
`;

const { rows: bannersDB } = await sql`
  SELECT * FROM banners WHERE categoria_slug = ${categoriaSlug} AND activo = true ORDER BY posicion ASC
`;

const nombreCategoria = categoriaSlug.replace(/-/g, ' ');

// 2. Esquema JSON-LD para la lista de proveedores (SEO Local)
const listSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": proveedores.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.nombre,
      "image": p.imagen_url || 'https://fiestasguatemala.com/logo-fiestas-guatemala.jpg',
      "address": {
        "@type": "PostalAddress",
        "addressLocality": p.municipio || p.departamento,
        "addressRegion": p.departamento,
        "addressCountry": "GT"
      }
    }
  }))
};
---

<Layout title={`${nombreCategoria} en Guatemala | FiestasGuatemala.com`}>
  <script type="application/ld+json" set:html={JSON.stringify(listSchema)} />

  <div class="bg-[#fcfaf4] min-h-screen font-sans text-[#243447]">
    
    <nav class="max-w-7xl mx-auto px-10 py-4 flex justify-between items-center text-[13px] text-[#8b7355] font-light border-b border-gray-100/50">
      <div class="flex gap-8 items-center flex-1">
        <a href="/" class="hover:text-[#a68a56] transition-colors font-medium">Categorías ▾</a>
        <a href="#" class="hover:text-[#a68a56] transition-colors font-medium">Departamentos</a>
      </div>
      <div class="flex flex-col items-center px-10">
        <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-20 w-auto object-contain" />
      </div>
      <div class="flex gap-8 items-center flex-1 justify-end font-medium">
        <a href="#" class="hover:text-[#a68a56] transition-colors">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-6 py-2 rounded-full text-xs font-medium">Login / Registrarse</a>
      </div>
    </nav>

    <div class="text-center pt-6 pb-2">
      <h2 class="text-2xl font-serif font-light text-[#243447] tracking-tight mb-1">FiestasGuatemala<span class="text-[#a68a56]">.com</span></h2>
      <p class="text-[9px] font-medium text-gray-400 uppercase tracking-[0.4em]">Aquí tú eres el alma de la fiesta</p>
    </div>

    <main class="max-w-7xl mx-auto px-10 py-8">
      <nav class="flex items-center gap-2 text-[10px] uppercase tracking-widest text-gray-400 mb-8 font-bold">
        <a href="/" class="hover:text-[#a68a56]">Inicio</a>
        <span>/</span>
        <span class="text-[#a68a56] font-black">{nombreCategoria} En Guatemala</span>
      </nav>

      <header class="mb-16 flex flex-col lg:flex-row lg:items-center justify-between gap-10">
        <div>
          <h1 class="text-4xl font-serif font-light text-[#243447] capitalize leading-tight">
            {nombreCategoria} <span class="text-[#a68a56]">en Guatemala</span>
          </h1>
          <p class="text-[12px] text-gray-400 font-light mt-2.5 uppercase tracking-wider">Servicios profesionales para tu evento</p>
        </div>

        <div class="relative w-full lg:w-[450px]">
          <div class="flex items-center bg-[#243447] p-1 rounded-full shadow-2xl border border-[#a68a56]/10">
             <span class="pl-5 text-white/30 text-base">🔍</span>
             <input type="text" id="deptSearch" placeholder="Busca por municipio o departamento..." class="flex-1 bg-transparent pl-3 pr-4 py-3.5 text-white outline-none placeholder:text-white/20 text-sm font-light" />
             <button class="bg-[#a68a56] text-white px-7 py-3.5 rounded-full text-[10px] font-bold uppercase tracking-widest shadow-lg">Filtrar</button>
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12" id="gridProveedores">
        {proveedores.map((p, index) => {
          const banner = bannersDB.find(b => b.posicion === index);
          const fotoFinal = categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : (p.imagen_url || '/placeholder.jpg');

          return (
            <>
              {banner && (
                <a href={banner.enlace_url} target="_blank" class="card-banner relative bg-[#243447] rounded-[40px] overflow-hidden shadow-2xl h-[340px] flex flex-col justify-end p-8 group border border-white/5 transition-all">
                  <img src={banner.imagen_url} class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:scale-105 transition-transform duration-700" alt={banner.titulo} />
                  <div class="relative z-10 text-white">
                    <span class="text-[9px] font-black text-[#a68a56] uppercase tracking-widest mb-3 block">Recomendación Especial</span>
                    <h3 class="text-2xl font-serif font-light mb-3 leading-tight">{banner.titulo}</h3>
                    <div class="inline-block bg-[#a68a56] text-white px-6 py-2.5 rounded-full text-[10px] font-bold uppercase tracking-widest shadow-lg">Saber más</div>
                  </div>
                </a>
              )}

              <div class="card-proveedor bg-white rounded-[40px] overflow-hidden border border-gray-100 shadow-sm hover:shadow-2xl transition-all duration-500 flex flex-col group" data-depto={p.departamento?.toLowerCase()} data-muni={p.municipio?.toLowerCase()}>
                <div class="relative h-48 overflow-hidden bg-gray-50 border-b border-gray-100">
                  <img src={fotoFinal} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" alt={p.nombre} />
                  
                  {p.es_premium && (
                    <div class="absolute bottom-4 right-4 bg-white/95 backdrop-blur px-3 py-1.5 rounded-full flex items-center gap-1.5 shadow-sm border border-gray-100">
                      <span class="text-[#a68a56] text-sm">★</span>
                      <span class="text-[9px] font-black uppercase tracking-widest text-[#a68a56]">Perfil Verificado</span>
                    </div>
                  )}
                </div>

                <div class="p-8 pt-6 flex flex-col flex-1">
                  <h2 class="font-serif font-light text-xl text-[#243447] mb-1 leading-snug group-hover:text-[#a68a56] transition-colors">{p.nombre}</h2>
                  
                  <div class="text-[#8b8b8b] text-[11px] font-medium uppercase tracking-[0.15em] mb-4 flex items-center gap-1.5 opacity-80">
                    <span class="text-[#a68a56]">📍</span> {p.municipio || p.departamento}, Guatemala
                  </div>

                  <p class="text-gray-400 text-[13px] font-light line-clamp-2 italic mb-8 leading-relaxed">"{p.descripcion}"</p>
                  
                  <div class="flex items-center justify-between pt-6 border-t border-gray-50 mt-auto">
                    <div>
                      <span class="text-[9px] text-gray-400 uppercase font-bold block mb-1">Cotiza desde</span>
                      <span class="text-2xl font-light text-[#a68a56]">Q{p.precio_desde}</span>
                    </div>
                    <a href={`/${categoriaSlug}/${p.slug}`} class="text-[10px] font-bold uppercase tracking-widest text-white bg-[#243447] px-7 py-3 rounded-full hover:bg-[#a68a56] transition-all shadow-lg active:scale-95">Ver Perfil</a>
                  </div>
                </div>
              </div>
            </>
          );
        })}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-20 pb-12 px-10 text-[13px]">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-16">
        <div class="space-y-6">
          <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-10 brightness-0 invert" />
          <div class="text-gray-400 leading-relaxed font-light text-[12px]">
            <p>Boulevard Los Proceres 24-69 zona 10,</p>
            <p>Edificio Zona Pradera, torre 2, oficina 1108</p>
            <p class="mt-4 font-bold text-[#a68a56]">PBX: 2302-2201</p>
          </div>
        </div>
        <div>
          <h4 class="font-bold mb-6 text-[#a68a56] text-[11px] uppercase tracking-widest">Explorar</h4>
          <ul class="space-y-3 text-gray-400 font-light">
            <li>Todas las Categorías</li>
            <li>Directorio de Departamentos</li>
            <li>Soporte Técnico</li>
          </ul>
        </div>
        <div class="flex gap-4 md:justify-end items-start pt-6">
          <div class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[#a68a56] transition-all cursor-pointer">f</div>
          <div class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[#a68a56] transition-all cursor-pointer">i</div>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script>
  const input = document.getElementById('deptSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.card-proveedor');

  input?.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
    cards.forEach(card => {
      const el = card as HTMLElement;
      const match = el.dataset.depto?.includes(term) || el.dataset.muni?.includes(term);
      el.style.display = match ? 'flex' : 'none';
    });
  });
</script>