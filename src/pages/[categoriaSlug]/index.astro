---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
// CORRECCIÓN DEFINITIVA DEL IMPORT (con diagonal)
import { sql } from '@vercel/postgres'; 

const { categoriaSlug } = Astro.params;

// 1. Datos de DB
const { rows: proveedores } = await sql`
  SELECT * FROM proveedores WHERE categoria_slug = ${categoriaSlug} ORDER BY es_premium DESC, nombre ASC
`;

const { rows: bannersDB } = await sql`
  SELECT * FROM banners WHERE categoria_slug = ${categoriaSlug} AND activo = true ORDER BY posicion ASC
`;

const nombreCategoria = categoriaSlug.replace(/-/g, ' ');

// 2. Esquema JSON-LD para SEO Local
const listSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": proveedores.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.nombre,
      "image": p.imagen_url || 'https://fiestasguatemala.com/Logo-Fiestas-Guatemala.jpg',
      "address": {
        "@type": "PostalAddress",
        "addressLocality": p.municipio || p.departamento,
        "addressRegion": p.departamento,
        "addressCountry": "GT"
      }
    }
  }))
};
---

<Layout title={`${nombreCategoria} en Guatemala | FiestasGuatemala.com`}>
  <script type="application/ld+json" set:html={JSON.stringify(listSchema)} />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    
    <Header />

    <main class="max-w-6xl mx-auto px-6 pt-10 pb-20">
      
      <header class="mb-16">
        <h1 class="text-4xl md:text-6xl font-serif font-light text-[#243447] capitalize leading-tight mb-6">
          {nombreCategoria} <span class="text-[#a68a56]">en Guatemala</span>
        </h1>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
          <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#8b7355] font-bold">
            <a href="/" class="hover:text-[#243447] transition-colors">Inicio</a>
            <span class="opacity-30">/</span>
            <span class="text-[#a68a56] font-black">{nombreCategoria} En Guatemala</span>
          </nav>

          <div class="relative w-full lg:w-[400px]">
            <div class="flex items-center bg-[#243447] p-1 rounded-full shadow-2xl border border-white/5">
               <span class="pl-5 text-white/30 text-base">📍</span>
               <input 
                  type="text" 
                  id="deptSearch" 
                  placeholder="Municipio o departamento..." 
                  class="flex-1 bg-transparent pl-3 pr-4 py-3 text-white outline-none placeholder:text-white text-sm font-light" 
               />
            </div>
          </div>
        </div>

        <p class="text-[15px] text-[#243447]/70 font-light leading-relaxed max-w-4xl italic">
          Encuentra los mejores <strong>{nombreCategoria}</strong> en Guatemala para elevar el nivel de tu celebración. En FiestasGuatemala.com nos dedicamos a seleccionar proveedores verificados que garantizan puntualidad, profesionalismo y el ambiente perfecto para bodas, cumpleaños y eventos corporativos. Explora nuestro directorio especializado, compara opciones por ubicación y solicita tu cotización directamente con expertos que entienden que, en tu evento, <strong>tú eres el alma de la fiesta.</strong>
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" id="gridProveedores">
        {proveedores.map((p, index) => {
          const banner = bannersDB.find(b => b.posicion === index);
          
          // Lógica de foto: Mariachis usa la foto institucional
          const fotoFinal = categoriaSlug === 'mariachis' 
            ? '/mariachi-guatemala.jpg' 
            : (p.imagen_url || '/placeholder-eventos.jpg');

          return (
            <>
              {banner && (
                <a href={banner.enlace_url} target="_blank" class="relative bg-[#243447] rounded-[35px] overflow-hidden shadow-2xl h-[400px] flex flex-col justify-end p-8 group border border-white/5 transition-all">
                  <img src={banner.imagen_url} class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 transition-transform duration-700" alt={banner.titulo} />
                  <div class="relative z-10 text-white">
                    <span class="text-[9px] font-black text-[#a68a56] uppercase tracking-widest mb-3 block">Recomendación</span>
                    <h3 class="text-2xl font-serif font-light mb-4 leading-tight">{banner.titulo}</h3>
                    <div class="inline-block bg-[#a68a56] text-white px-6 py-2 rounded-full text-[10px] font-bold uppercase tracking-widest shadow-lg">Ver Detalles</div>
                  </div>
                </a>
              )}

              <div class="card-proveedor bg-white rounded-[35px] overflow-hidden border border-gray-100 shadow-[0_15px_40px_rgba(0,0,0,0.05)] hover:shadow-2xl transition-all duration-500 flex flex-col group" data-depto={p.departamento?.toLowerCase()} data-muni={p.municipio?.toLowerCase()}>
                <div class="relative h-48 overflow-hidden bg-gray-50">
                  <img src={fotoFinal} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" alt={p.nombre} loading="lazy" />
                  
                  {p.es_premium && (
                    <div class="absolute bottom-4 right-4 bg-white/95 backdrop-blur px-3 py-1.5 rounded-full flex items-center gap-1.5 shadow-sm border border-gray-100">
                      <span class="text-[#a68a56] text-xs leading-none">★</span>
                      <span class="text-[8px] font-black uppercase tracking-widest text-[#243447]">Verificado</span>
                    </div>
                  )}
                </div>

                <div class="p-7 flex flex-col flex-1">
                  <h2 class="font-serif font-light text-xl text-[#243447] mb-1 group-hover:text-[#a68a56] transition-colors leading-tight">{p.nombre}</h2>
                  
                  <div class="text-[#8b7355] text-[10px] font-bold uppercase tracking-[0.15em] mb-4 flex items-center gap-1.5 opacity-80">
                    <span class="opacity-50">📍</span> {p.municipio || p.departamento}
                  </div>

                  <p class="text-gray-400 text-[13px] font-light line-clamp-2 italic mb-8 leading-relaxed">"{p.descripcion}"</p>
                  
                  <div class="flex items-center justify-between pt-6 border-t border-gray-50 mt-auto">
                    <div>
                      <span class="text-[8px] text-gray-400 uppercase font-black block mb-0.5 tracking-tighter">Desde</span>
                      <span class="text-xl font-serif text-[#a68a56]">Q{p.precio_desde}</span>
                    </div>
                    <a href={`/${categoriaSlug}/${p.slug}`} class="text-[9px] font-black uppercase tracking-widest text-white bg-[#243447] px-6 py-3 rounded-full hover:bg-[#a68a56] transition-all shadow-md active:scale-95">Ver Perfil</a>
                  </div>
                </div>
              </div>
            </>
          );
        })}
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  const input = document.getElementById('deptSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.card-proveedor');

  input?.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
    cards.forEach(card => {
      const el = card as HTMLElement;
      const depto = el.dataset.depto || "";
      const muni = el.dataset.muni || "";
      const match = depto.includes(term) || muni.includes(term);
      el.style.display = match ? 'flex' : 'none';
    });
  });
</script>