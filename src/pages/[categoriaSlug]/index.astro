---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sql } from '@vercel/postgres';

const { categoriaSlug } = Astro.params;

// Funciones de utilidad
const capitalize = (str) => str ? str.replace(/\b\w/g, l => l.toUpperCase()) : "";
const nombreLimpio = categoriaSlug ? categoriaSlug.replace(/-/g, ' ') : "";
const nombreCapitalizado = capitalize(nombreLimpio);

// 1. Datos de DB
let proveedores = [];
let bannersDB = [];

try {
  const resProv = await sql`SELECT * FROM proveedores WHERE categoria_slug ILIKE ${categoriaSlug} AND activo = true ORDER BY es_premium DESC, nombre ASC`;
  proveedores = resProv.rows || [];
  
  const resBann = await sql`SELECT * FROM banners WHERE categoria_slug ILIKE ${categoriaSlug} AND activo = true ORDER BY posicion ASC`;
  bannersDB = resBann.rows || [];
} catch (e) {
  console.error("Error en DB:", e.message);
}

// 2. SEO DINÁMICO MEJORADO
const titleSEO = `${nombreCapitalizado} en Guatemala | Los mejores proveedores para tu evento`;
const descriptionSEO = `¿Buscas ${nombreLimpio} en Guatemala? Encuentra aquí una selección exclusiva de proveedores verificados para bodas, fiestas y eventos. Precios actualizados, fotos reales y contacto directo.`;
const siteBase = 'https://fiestasguatemala.com';
const canonicalURL = `${siteBase}/${categoriaSlug}`;
const ogImage = `${siteBase}/mariachi-guatemala.jpg`;

// 3. SCHEMAS (JSON-LD) - Combinamos Collection y FAQ
const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": titleSEO,
    "description": descriptionSEO,
    "url": canonicalURL,
    "mainEntity": {
      "@type": "ItemList",
      "numberOfItems": proveedores.length,
      "itemListElement": proveedores.map((p, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "LocalBusiness",
          "name": p.nombre,
          "image": p.imagen_url || ogImage,
          "priceRange": `Q${p.precio_desde || '500'}+`,
          "address": {
            "@type": "PostalAddress",
            "addressLocality": p.municipio || p.departamento,
            "addressRegion": p.departamento,
            "addressCountry": "GT"
          }
        }
      }))
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `¿Cómo contratar ${nombreLimpio} en Guatemala?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Puedes contratar ${nombreLimpio} directamente a través de nuestro directorio. Solo debes elegir al proveedor que más te guste, revisar su perfil verificado y contactarlo por los medios proporcionados.`
        }
      },
      {
        "@type": "Question",
        "name": `¿Cuál es el precio promedio de los ${nombreLimpio}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Los precios varían según la ubicación y el tipo de servicio. En nuestra lista puedes encontrar opciones que inician desde Q${proveedores[0]?.precio_desde || '500'}.`
        }
      }
    ]
  }
];
---

<Layout title={titleSEO} description={descriptionSEO}>
  <link rel="icon" type="image/png" href="https://fiestasguatemala.com/favicon.png" slot="head" />
  <link rel="canonical" href={canonicalURL} slot="head" />
  <meta property="og:title" content={titleSEO} slot="head" />
  <meta property="og:description" content={descriptionSEO} slot="head" />
  <meta property="og:image" content={ogImage} slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} slot="head" />

  <div class="bg-[#f0efec] min-h-screen font-sans text-[#243447]">
    <Header />

    <main class="max-w-6xl mx-auto px-6 pt-10 pb-20">
      
      <header class="mb-12">
        <h1 class="text-4xl md:text-6xl font-serif font-light text-[#243447] mb-6 leading-tight">
          {nombreCapitalizado} <span class="text-[#a68a56]">en Guatemala</span>
        </h1>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-[#8b7355]/10 pb-8">
          <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#8b7355] font-bold">
            <a href="/" class="hover:text-[#243447] no-underline">Inicio</a>
            <span class="opacity-30">/</span>
            <span class="text-[#a68a56] font-black">{nombreCapitalizado} En Guatemala</span>
          </nav>

          <div class="relative w-full md:w-[350px]">
            <div class="flex items-center bg-[#243447] p-1 rounded-full shadow-lg">
               <span class="pl-4 text-white/40 text-sm">📍</span>
               <input type="text" id="deptSearch" placeholder="Filtrar por municipio..." class="flex-1 bg-transparent pl-2 pr-4 py-2 text-white outline-none placeholder:text-white text-xs font-light" />
            </div>
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" id="gridProveedores">
        {proveedores.map((p, index) => {
          const urlPerfil = `/${categoriaSlug}/${p.slug}`;
          const fotoFinal = categoriaSlug === 'mariachis' ? '/mariachi-guatemala.jpg' : (p.imagen_url || '/placeholder.jpg');

          return (
            <div class="card-proveedor bg-white rounded-[35px] overflow-hidden border border-gray-100 shadow-sm hover:shadow-2xl transition-all duration-500 flex flex-col group" data-depto={p.departamento?.toLowerCase()}>
              
              <a href={urlPerfil} class="relative h-48 overflow-hidden block">
                <img src={fotoFinal} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" alt={p.nombre} loading="lazy" />
                {p.es_premium && (
                  <div class="absolute bottom-4 right-4 bg-white/95 px-3 py-1.5 rounded-full flex items-center gap-1 shadow-sm border border-gray-100">
                    <span class="text-[#a68a56] text-[10px]">★</span>
                    <span class="text-[8px] font-black uppercase tracking-widest text-[#243447]">Verificado</span>
                  </div>
                )}
              </a>

              <div class="p-7 flex flex-col flex-1">
                <a href={urlPerfil} class="no-underline group">
                  <h2 class="font-serif font-light text-xl text-[#243447] mb-1 group-hover:text-[#a68a56] transition-colors leading-tight">{p.nombre}</h2>
                </a>
                
                <div class="text-[#8b7355] text-[10px] font-bold uppercase tracking-widest mb-4 opacity-70">📍 {p.municipio || p.departamento}</div>
                <p class="text-gray-400 text-[13px] font-light line-clamp-2 italic mb-8 leading-relaxed">"{p.descripcion}"</p>
                
                <div class="flex items-center justify-between pt-6 border-t border-gray-50 mt-auto">
                  <div>
                    <span class="text-[8px] text-gray-400 uppercase font-black block mb-0.5 tracking-tighter">Desde</span>
                    <span class="text-xl font-serif text-[#a68a56]">Q{p.precio_desde}</span>
                  </div>
                  <a href={urlPerfil} class="text-[9px] font-black uppercase tracking-widest text-white bg-[#243447] px-6 py-3 rounded-full hover:bg-[#a68a56] transition-all no-underline shadow-md">Ver Perfil</a>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <section class="mt-32 pt-20 border-t border-[#8b7355]/20">
        <h2 class="text-3xl font-serif text-[#243447] mb-12">Preguntas Frecuentes sobre {nombreCapitalizado}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-10">
          <div class="space-y-4">
            <h3 class="font-serif text-lg text-[#a68a56]">¿Cómo elijo al mejor proveedor?</h3>
            <p class="text-sm text-[#243447]/70 leading-relaxed font-light">
              Recomendamos revisar la etiqueta "Verificado" en nuestros proveedores. Esto garantiza que han pasado por un filtro de calidad y profesionalismo para eventos en Guatemala.
            </p>
          </div>
          <div class="space-y-4">
            <h3 class="font-serif text-lg text-[#a68a56]">¿Qué incluye el precio base?</h3>
            <p class="text-sm text-[#243447]/70 leading-relaxed font-light">
              Generalmente, los {nombreLimpio} ofrecen paquetes por hora o por evento. Siempre consulta qué incluye la tarifa para evitar cargos sorpresa.
            </p>
          </div>
          <div class="space-y-4">
            <h3 class="font-serif text-lg text-[#a68a56]">¿Atienden en todo el país?</h3>
            <p class="text-sm text-[#243447]/70 leading-relaxed font-light">
              Muchos de nuestros proveedores viajan a departamentos como Antigua Guatemala, Xela y Escuintla, aunque pueden aplicar cargos de transporte.
            </p>
          </div>
          <div class="space-y-4">
            <h3 class="font-serif text-lg text-[#a68a56]">¿Tienen garantía de servicio?</h3>
            <p class="text-sm text-[#243447]/70 leading-relaxed font-light">
              En FiestasGuatemala.com trabajamos con expertos. Si tienes algún inconveniente, puedes reportarlo para que mantengamos nuestro directorio con la mejor calidad.
            </p>
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </div>
</Layout>

<script>
  // Script de filtrado por municipio (Optimizado)
  const input = document.getElementById('deptSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.card-proveedor');

  input?.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
    cards.forEach(card => {
      const el = card as HTMLElement;
      const depto = el.dataset.depto || "";
      const match = depto.includes(term);
      el.style.display = match ? 'flex' : 'none';
    });
  });
</script>