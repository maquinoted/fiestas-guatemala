---
import Layout from '../../layouts/Layout.astro';

// 1. Generamos las rutas dinámicas basadas en tus categorías existentes
export function getStaticPaths() {
  return [
    { params: { categoriaSlug: 'fincas-para-bodas' }, props: { nombre: 'Fincas para Bodas' } },
    { params: { categoriaSlug: 'salones-de-eventos' }, props: { nombre: 'Salones de Eventos' } },
    { params: { categoriaSlug: 'catering-banquetes' }, props: { nombre: 'Catering / Banquetes' } },
    { params: { categoriaSlug: 'juegos-infantiles' }, props: { nombre: 'Juegos Infantiles' } },
    { params: { categoriaSlug: 'decoradores' }, props: { nombre: 'Decoradores' } },
    { params: { categoriaSlug: 'organizadores-de-eventos' }, props: { nombre: 'Organizadores de Eventos' } },
    { params: { categoriaSlug: 'mariachis' }, props: { nombre: 'Mariachis' } },
    { params: { categoriaSlug: 'fotografos' }, props: { nombre: 'Fotógrafos' } },
    { params: { categoriaSlug: 'pasteles' }, props: { nombre: 'Pasteles' } },
  ];
}

const { categoriaSlug } = Astro.params;
const { nombre } = Astro.props;

// 2. Simulamos la data de proveedores (En el futuro esto vendrá de una API o base de datos)
const proveedores = [
  { 
    nombre: `Premium ${nombre} Gt`, 
    img: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=800', 
    zona: 'Zona 10, Guatemala',
    precio: 'Desde Q1,500',
    verificado: true,
    slug: 'proveedor-1'
  },
  { 
    nombre: `${nombre} del Bosque`, 
    img: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=800', 
    zona: 'Carretera a El Salvador',
    precio: 'Desde Q2,200',
    verificado: true,
    slug: 'proveedor-2'
  },
  { 
    nombre: `${nombre} Económicos`, 
    img: 'https://images.unsplash.com/photo-1469334031218-e382a71b716b?q=80&w=800', 
    zona: 'Mixco',
    precio: 'Desde Q850',
    verificado: false,
    slug: 'proveedor-3'
  },
];
---

<Layout title={`${nombre} en Guatemala | FiestasGuatemala.com`}>
  <div class="bg-[#fcfaf4] min-h-screen font-sans text-[#243447]">
    
    <a href="https://wa.me/50223022201" target="_blank" class="fixed bottom-8 right-8 z-50 bg-[#25D366] text-white w-16 h-16 rounded-full shadow-2xl flex items-center justify-center hover:scale-110 transition-transform">
        <svg width="35" height="35" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12.004 2C6.48 2 2 6.48 2 12.004c0 1.764.462 3.42 1.267 4.86L2 22l5.315-1.395c1.37.747 2.936 1.173 4.594 1.173 5.524 0 10.004-4.48 10.004-10.004C21.913 6.48 17.528 2 12.004 2zM17.43 16.48c-.23.65-.964 1.185-1.597 1.32-.435.09-1.002.162-2.912-.628-2.443-1.01-4.02-3.49-4.142-3.653-.122-.163-1.002-1.335-1.002-2.545 0-1.21.632-1.805.856-2.05.224-.245.49-.306.654-.306.163 0 .326.002.467.008.15.006.35-.057.548.423.2.484.685 1.67.746 1.792.06.122.102.264.02.427-.08.163-.122.265-.245.408-.122.143-.257.32-.367.428-.122.122-.25.255-.108.496.143.24.636 1.053 1.368 1.704.943.84 1.74 1.1 1.984 1.223.245.122.388.102.53-.06.143-.164.613-.715.776-.96.163-.245.327-.204.55-.122.225.082 1.43.673 1.675.795.245.122.408.184.47.286.06.102.06.59-.17 1.24z" fill="white"/></svg>
    </a>

    <nav class="max-w-7xl mx-auto px-10 py-2 flex justify-between items-center text-[13px] text-[#5d4d37] font-medium">
      <div class="flex gap-8 items-center flex-1">
        <a href="/" class="hover:text-[#a68a56]">Inicio</a>
        <a href="#" class="hover:text-[#a68a56]">Categorías</a>
      </div>
      <div class="flex flex-col items-center">
        <img src="/Logo-Fiestas-Guatemala.jpg" alt="Fiestas Guatemala" class="h-16 w-auto object-contain" />
      </div>
      <div class="flex gap-8 items-center flex-1 justify-end">
        <a href="#" class="hover:text-[#a68a56]">Favoritos ♡</a>
        <a href="#" class="bg-[#243447] text-white px-5 py-2 rounded-full text-xs font-bold">Login</a>
      </div>
    </nav>

    <header class="pt-8 pb-10 px-10 max-w-7xl mx-auto">
        <div class="flex flex-col items-start">
            <nav class="flex gap-2 text-[10px] uppercase tracking-widest text-[#8b8b8b] mb-4">
                <a href="/" class="hover:text-[#a68a56]">Inicio</a>
                <span>/</span>
                <span class="text-[#a68a56]">{nombre}</span>
            </nav>
            <h1 class="text-3xl font-serif font-light text-[#243447]">
              {nombre} <span class="text-[#a68a56]">en Guatemala</span>
            </h1>
            <p class="text-[12px] font-medium text-[#8b8b8b] uppercase tracking-[0.2em] mt-2">
              Selección exclusiva de proveedores verificados
            </p>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-10 pb-32">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {proveedores.map((p) => (
          <a href={`/${categoriaSlug}/${p.slug}`} class="bg-white rounded-[35px] overflow-hidden shadow-sm border border-gray-100 flex flex-col group hover:shadow-xl transition-all duration-500">
            <div class="relative h-60">
              <img src={p.img} alt={p.nombre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              
              {p.verificado && (
                <div class="absolute top-4 right-4 bg-white/95 backdrop-blur px-3 py-1.5 rounded-full flex items-center gap-2 shadow-sm border border-gray-100">
                    <div class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></div>
                    <span class="text-[9px] font-black uppercase tracking-widest text-[#a68a56]">Sello de Verificado</span>
                </div>
              )}
            </div>
            
            <div class="p-6 flex flex-col flex-1">
              <h3 class="font-light text-xl text-[#243447] leading-tight mb-4">{p.nombre}</h3>
              
              <div class="space-y-2 mb-6">
                  <div class="flex items-center gap-2 text-[#8b8b8b] text-[13px] font-light">
                      <span>📍</span> {p.zona}
                  </div>
                  <div class="flex items-center gap-2 text-[#5d4d37] text-sm font-bold">
                      <span>💰</span> {p.precio}
                  </div>
              </div>

              <div class="mt-auto pt-4 border-t border-gray-50 flex items-center justify-between">
                  <span class="text-[10px] font-bold text-[#a68a56] uppercase tracking-widest">Ver Perfil</span>
                  <span class="text-gray-300">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <footer class="bg-[#243447] text-white pt-16 pb-12 px-10 text-[12px]">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="space-y-4">
          <img src="/Logo-Fiestas-Guatemala.jpg" alt="Logo" class="h-10 brightness-0 invert" />
          <div class="text-gray-400 leading-relaxed font-light">
            <p>Boulevard Los Proceres 24-69 zona 10,</p>
            <p>Edificio Zona Pradera, torre 2, oficina 1108</p>
            <p class="mt-2 font-bold text-[#a68a56]">PBX: 2302-2201</p>
          </div>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-[#a68a56] text-[10px] uppercase tracking-widest">Explorar</h4>
          <ul class="space-y-2 text-gray-400 font-light">
            <li>Todas las Categorías</li>
            <li>Proveedores Destacados</li>
          </ul>
        </div>
        <div class="flex gap-4 md:justify-end items-start">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-bold">f</div>
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-bold">i</div>
        </div>
      </div>
    </footer>
  </div>
</Layout>